
{% comment %}
  Enhanced Header with Japanese-inspired hamburger menu
  統合されたヘッダーセクション（日本風ハンバーガーメニュー付き）
{% endcomment %}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-items.css' | asset_url }}" media="print" onload="this.media='all'">
{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="{{ 'component-loading-overlay.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'component-mega-menu.css' | asset_url | stylesheet_tag }}</noscript>
{%- endif -%}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  {{ 'component-localization-form.css' | asset_url | stylesheet_tag: preload: true }}
{%- endif -%}

{%- if settings.cart_type == "drawer" -%}
  {{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
  {{ 'component-totals.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-discounts.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<noscript>{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-search.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-menu-drawer.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-cart-notification.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}</noscript>

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  /* Hamburger Menu Button Styles */
  .japanese-menu-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    color: {{ section.settings.menu_text_color | default: '#333333' }};
  }

  .japanese-menu-trigger span {
    position: relative;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .japanese-menu-trigger .icon {
    width: 20px;
    height: 20px;
    transition: opacity 0.3s ease;
  }

  .japanese-menu-trigger .icon-close {
    position: absolute;
    opacity: 0;
  }

  .japanese-menu-trigger .icon-hamburger {
    opacity: 1;
  }

  /* Show close icon when menu is active */
  .japanese-menu-overlay.active ~ header .japanese-menu-trigger .icon-hamburger {
    opacity: 0;
  }

  .japanese-menu-overlay.active ~ header .japanese-menu-trigger .icon-close {
    opacity: 1;
  }

  /* Responsive hamburger menu visibility */
  @media screen and (min-width: 990px) {
    .japanese-menu-trigger {
      {%- if section.settings.menu_type_desktop != 'drawer' -%}
        display: none;
      {%- endif -%}
    }
  }

  /* Japanese Menu Styles */
  .japanese-menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: #E7EAF0;
    backdrop-filter: none;
    z-index: 1000;
    transform: translateX(-100%);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow-y: auto;
    visibility: hidden;
}

  .japanese-menu-overlay.active {
    transform: translateX(0);
    visibility: visible;
  }

  /* PC Layout - Partial Width */
  @media screen and (min-width: 990px) {
    .japanese-menu-overlay {
      width: {{ section.settings.desktop_menu_width | default: 35 }}%;
      max-width: 400px;
      min-width: 320px;
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.1);
    }
  }

  .japanese-menu-container {
    padding: {{ section.settings.mobile_padding | default: 24 }}px {{ section.settings.mobile_padding | default: 24 }}px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 99999;
  }

  /* Header section */
  .japanese-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.1);
  }

  .japanese-menu-logo {
    font-family: {{ section.settings.heading_font.family | default: 'assistant' }}, 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
    font-size: {{ section.settings.menu_title_size | default: 24 }}px;
    font-weight: {{ section.settings.heading_font.weight | default: 600 }};
    color: {{ section.settings.menu_text_color | default: '#333333' }};
    letter-spacing: 0.1em;
  }

  .japanese-menu-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: {{ section.settings.menu_text_color | default: '#333333' }};
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.3s ease;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .japanese-menu-close:hover {
    background: rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.05);
    transform: rotate(90deg);
  }

  /* Menu items */
  .japanese-menu-items {
    flex: 1;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .japanese-menu-item {
    margin-bottom: 0.5rem;
    opacity: 0;
    transform: translateX(-20px);
    animation: slideInLeft 0.3s ease forwards;
  }

  .japanese-menu-item:nth-child(1) { animation-delay: 0.05s; }
  .japanese-menu-item:nth-child(2) { animation-delay: 0.1s; }
  .japanese-menu-item:nth-child(3) { animation-delay: 0.15s; }
  .japanese-menu-item:nth-child(4) { animation-delay: 0.2s; }
  .japanese-menu-item:nth-child(5) { animation-delay: 0.25s; }
  .japanese-menu-item:nth-child(6) { animation-delay: 0.3s; }
  .japanese-menu-item:nth-child(7) { animation-delay: 0.35s; }

  .japanese-menu-link {
    display: block;
    z-index: 9999;
    padding: {{ section.settings.menu_item_height | default: 64 | divided_by: 4 }}px 0;
    font-family: {{ section.settings.body_font.family | default: 'assistant' }}, 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Hiragino Sans', Meiryo, sans-serif;
    font-size: {{ section.settings.menu_text_size | default: 18 }}px;
    font-weight: {{ section.settings.body_font.weight | default: 400 }};
    color: {{ section.settings.menu_text_color | default: '#333333' }};
    text-decoration: none;
    border-bottom: 1px solid rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.05);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .japanese-menu-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba({{ section.settings.menu_accent_color | color_extract: 'red' }}, {{ section.settings.menu_accent_color | color_extract: 'green' }}, {{ section.settings.menu_accent_color | color_extract: 'blue' }}, 0.1),
      transparent
    );
    transition: left {{ section.settings.animation_speed | default: 1.0 | times: 0.5 }}s ease;
  }

  .japanese-menu-link:hover::before {
    left: 100%;
  }

  .japanese-menu-link:hover {
    color: {{ section.settings.menu_accent_color | default: '#FFB7C5' }};
    padding-left: 1rem;
  }

  .japanese-menu-link.has-submenu::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 2.2rem;
    color: {{ section.settings.menu_accent_color | default: '#FFB7C5' }};
    transition: transform 0.3s ease;
  }

  .japanese-menu-link.has-submenu.active::after {
    transform: translateY(-50%) rotate(45deg);
  }

  /* Expandable menu items */
  .japanese-submenu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.25s ease;
    padding-left: 1rem;
  }

  .japanese-submenu.active {
    max-height: 500px;
  }

  .japanese-submenu-item {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.03);
  }

  .japanese-submenu-link {
    font-size: {{ section.settings.menu_text_size | default: 18 | minus: 2 }}px;
    color: rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .japanese-submenu-link:hover {
    color: {{ section.settings.menu_accent_color | default: '#FFB7C5' }};
  }

  /* Footer section */
  .japanese-menu-footer {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba({{ section.settings.menu_text_color | color_extract: 'red' }}, {{ section.settings.menu_text_color | color_extract: 'green' }}, {{ section.settings.menu_text_color | color_extract: 'blue' }}, 0.1);
  }

  .japanese-menu-auth {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .japanese-auth-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    background: {{ section.settings.button_bg_color | default: '#333333' }};
    color: {{ section.settings.button_text_color | default: '#FFFFFF' }};
    text-decoration: none;
    border-radius: {{ section.settings.button_border_radius | default: 8 }}px;
    font-weight: 500;
    font-size: {{ section.settings.button_text_size | default: 16 }}px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .japanese-auth-button::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.6s ease, height 0.6s ease;
  }

  .japanese-auth-button:hover::before {
    width: 300px;
    height: 300px;
  }

  .japanese-auth-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
  }

  /* Floating sakura animation */
  {%- if section.settings.enable_sakura_animation -%}
    .sakura-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: hidden;
    }

    .sakura {
      position: absolute;
      width: {{ section.settings.sakura_size | default: 10 }}px;
      height: {{ section.settings.sakura_size | default: 10 }}px;
      background: radial-gradient(circle, {{ section.settings.menu_accent_color | default: '#FFB7C5' }} 0%, transparent 70%);
      border-radius: 50% 0 50% 0;
      opacity: {{ section.settings.sakura_opacity | default: 0.6 }};
      animation: sakuraFall {{ section.settings.animation_speed | default: 1.0 | times: 8 }}s linear infinite;
    }

    .sakura:nth-child(odd) {
      animation-duration: {{ section.settings.animation_speed | default: 1.0 | times: 10 }}s;
      animation-delay: {{ section.settings.animation_speed | default: 1.0 | times: -2 }}s;
    }

    .sakura:nth-child(even) {
      animation-duration: {{ section.settings.animation_speed | default: 1.0 | times: 12 }}s;
      animation-delay: {{ section.settings.animation_speed | default: 1.0 | times: -4 }}s;
    }
  {%- endif -%}

  /* Hide search modal if disabled */
  {%- if section.settings.hide_search_modal -%}
    details-modal.header__search {
      display: none !important;
    }
  {%- endif -%}

  /* Animations */
  @keyframes slideInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  {%- if section.settings.enable_sakura_animation -%}
    @keyframes sakuraFall {
      0% {
        transform: translateY(-100px) rotate(0deg);
        opacity: 0;
      }
      10% {
        opacity: {{ section.settings.sakura_opacity | default: 0.6 }};
      }
      90% {
        opacity: {{ section.settings.sakura_opacity | default: 0.6 }};
      }
      100% {
        transform: translateY(100vh) rotate(360deg);
        opacity: 0;
      }
    }
  {%- endif -%}

  /* Responsive adjustments */
  @media (max-width: 480px) {
    .japanese-menu-container {
      padding: {{ section.settings.mobile_padding | default: 24 | minus: 8 }}px {{ section.settings.mobile_padding | default: 24 | minus: 8 }}px;
    }
    
    .japanese-menu-link {
      font-size: {{ section.settings.menu_text_size | default: 18 | minus: 2 }}px;
    }

    .japanese-menu-logo {
      font-size: {{ section.settings.menu_title_size | default: 24 | minus: 4 }}px;
    }
  }
</style>

{%- style -%}
  .header {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }
  
  .section-header {
    margin-bottom: {{ section.settings.margin_bottom | times: 0.5 | round: 0 }}px!important;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'search-form.js' | asset_url }}" defer="defer"></script>
{%- if settings.cart_type == "drawer" -%}
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
{%- if section.settings.enable_country_selector or section.settings.enable_language_selector -%}
  <script src="{{ 'localization-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  <symbol id="icon-search" viewbox="0 0 18 19" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 112.85 3.5a5.784 5.784 0 018.18 8.18zm.26 1.12a6.78 6.78 0 11.72-.7l5.4 5.4a.5.5 0 11-.71.7l-5.41-5.4z" fill="currentColor"/>
  </symbol>

  <symbol id="icon-reset" class="icon icon-close"  fill="none" viewBox="0 0 18 18" stroke="currentColor">
    <circle r="8.5" cy="9" cx="9" stroke-opacity="0.2"/>
    <path d="M6.82972 6.82915L1.17193 1.17097" stroke-linecap="round" stroke-linejoin="round" transform="translate(5 5)"/>
    <path d="M1.22896 6.88502L6.77288 1.11523" stroke-linecap="round" stroke-linejoin="round" transform="translate(5 5)"/>
  </symbol>

  <symbol id="icon-close" class="icon icon-close" fill="none" viewBox="0 0 18 17">
    <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
  </symbol>
</svg>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

<{% if section.settings.sticky_header_type != 'none' %}sticky-header data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %}div{% endif %} class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}">
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif

    if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
      assign localization_forms = true
    endif
  -%}
  
  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}">
    
    {%- comment -%} Japanese Menu Integration {%- endcomment -%}
    {%- if section.settings.enable_japanese_menu -%}
      <!-- Japanese Hamburger Menu Button -->
      <header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
        <details id="Details-japanese-menu-container" class="menu-drawer-container">
          <summary
            class="header__icon header__icon--menu header__icon--summary link focus-inset japanese-menu-trigger"
            aria-label="{{ 'sections.header.menu' | t }}"
            id="japanese-hamburger-trigger"
          >
            <span>
              {% comment %} Hamburger Icon {% endcomment %}
              <svg class="icon icon-hamburger" aria-hidden="true" focusable="false" viewBox="0 0 18 16">
                <path d="M0 1h18v2H0V1zm0 6h18v2H0V7zm0 6h18v2H0v-2z" fill="currentColor"/>
              </svg>
              {% comment %} Close Icon {% endcomment %}
              <svg class="icon icon-close" aria-hidden="true" focusable="false" viewBox="0 0 18 17">
                <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor"/>
              </svg>
            </span>
          </summary>
        </details>
      </header-drawer>
    {%- else -%}
      {%- liquid
        if section.settings.menu != blank
          render 'header-drawer'
        endif

        if section.settings.logo_position == 'top-center' or section.settings.menu == blank
          render 'header-search', input_id: 'Search-In-Modal-1'
        endif
      -%}
    {%- endif -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
          <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
            {%- if settings.logo != blank -%}
              <div class="header__heading-logo-wrapper">
                {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
                {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
                {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
                {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
                {{ settings.logo | image_url: width: 600 | image_tag:
                  class: 'header__heading-logo motion-reduce',
                  widths: widths,
                  height: logo_height,
                  width: settings.logo_width,
                  alt: logo_alt,
                  sizes: sizes,
                  preload: true
                }}
              </div>
            {%- else -%}
              <span class="h2">{{ shop.name }}</span>
            {%- endif -%}
          </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
