{% comment %}
====================================================
Product Cross Sell Section for Shopify Online Store 2.0
レスポンシブ対応クロスセル商品セクション
====================================================
{% endcomment %}

{%- assign collection_handle = section.settings.collection -%}
{%- assign cross_sell_collection = collections[collection_handle] -%}
{%- assign products_to_show = section.settings.products_limit | default: 4 -%}

{%- if cross_sell_collection and cross_sell_collection.products.size > 0 -%}
<section 
  class="cross-sell-section"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --bg-color: {{ section.settings.background_color }};
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --title-size: {{ section.settings.title_size }}px;
    --text-size: {{ section.settings.text_size }}px;
  "
  data-section-id="{{ section.id }}"
  data-section-type="cross-sell"
>
  <div class="cross-sell-container">
    
    {%- if section.settings.title != blank -%}
    <div class="cross-sell-header">
      <h2 class="cross-sell-title">{{ section.settings.title | escape }}</h2>
      {%- if section.settings.description != blank -%}
      <div class="cross-sell-description">
        {{ section.settings.description }}
      </div>
      {%- endif -%}
    </div>
    {%- endif -%}

    <!-- デバッグ情報 (開発時のみ表示) -->
    {%- if section.settings.show_debug -%}
    <div style="background: #f0f0f0; padding: 10px; margin: 10px 0; font-size: 12px;">
      <strong>デバッグ情報:</strong><br>
      コレクション: {{ collection_handle | default: '未設定' }}<br>
      コレクション商品数: {{ cross_sell_collection.products.size | default: 0 }}<br>
      表示予定数: {{ products_to_show }}<br>
      現在の商品ID: {{ product.id | default: 'なし（商品ページ以外）' }}
    </div>
    {%- endif -%}

    <div class="cross-sell-grid" role="list">
      {%- assign products_shown = 0 -%}
      {%- for cross_sell_product in cross_sell_collection.products limit: products_to_show -%}
        {%- comment %} 現在の商品ページと同じ商品は除外 {% endcomment -%}
        {%- unless cross_sell_product.id == product.id -%}
          {%- assign products_shown = products_shown | plus: 1 -%}
          
          <div class="cross-sell-item" role="listitem" data-product-id="{{ cross_sell_product.id }}">
            
            <div class="cross-sell-image-wrapper">
              {%- if cross_sell_product.featured_image -%}
              <img 
                src="{{ cross_sell_product.featured_image | image_url: width: 300 }}"
                srcset="
                  {{ cross_sell_product.featured_image | image_url: width: 150 }} 150w,
                  {{ cross_sell_product.featured_image | image_url: width: 300 }} 300w,
                  {{ cross_sell_product.featured_image | image_url: width: 450 }} 450w
                "
                sizes="(max-width: 767px) 150px, (max-width: 1023px) 200px, 250px"
                alt="{{ cross_sell_product.featured_image.alt | default: cross_sell_product.title | escape }}"
                class="cross-sell-image"
                loading="lazy"
                width="300"
                height="300"
              >
              {%- else -%}
              <div class="cross-sell-placeholder" aria-label="商品画像なし">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <circle cx="8.5" cy="8.5" r="1.5"></circle>
                  <polyline points="21,15 16,10 5,21"></polyline>
                </svg>
              </div>
              {%- endif -%}
            </div>

            <div class="cross-sell-content">
              <h3 class="cross-sell-product-title">
                <a href="{{ cross_sell_product.url }}" class="cross-sell-product-link">
                  {{ cross_sell_product.title | escape }}
                </a>
              </h3>
              
              {%- if section.settings.show_vendor and cross_sell_product.vendor != blank -%}
              <div class="cross-sell-vendor">{{ cross_sell_product.vendor | escape }}</div>
              {%- endif -%}

              <div class="cross-sell-price">
                {%- if cross_sell_product.compare_at_price > cross_sell_product.price -%}
                <span class="cross-sell-price-compare" aria-label="通常価格">
                  {{ cross_sell_product.compare_at_price | money }}
                </span>
                {%- endif -%}
                <span class="cross-sell-price-current" aria-label="現在価格">
                  {{ cross_sell_product.price | money }}
                </span>
              </div>

              {%- assign first_variant = cross_sell_product.selected_or_first_available_variant -%}
              {%- if first_variant.available -%}
              <form class="cross-sell-form" data-product-form>
                <input type="hidden" name="id" value="{{ first_variant.id }}">
                <button 
                  type="submit" 
                  class="cross-sell-add-to-cart"
                  data-add-to-cart
                  aria-describedby="cart-success-{{ cross_sell_product.id }}"
                >
                  <span class="add-to-cart-text">
                    {{ section.settings.button_text | default: 'カートに追加' | escape }}
                  </span>
                  <span class="add-to-cart-success" id="cart-success-{{ cross_sell_product.id }}" aria-live="polite">
                    {{ section.settings.success_text | default: 'カートに追加しました' | escape }}
                  </span>
                  <span class="loading-spinner" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 12a9 9 0 11-6.219-8.56"></path>
                    </svg>
                  </span>
                </button>
              </form>
              {%- else -%}
              <button class="cross-sell-add-to-cart" disabled>
                {{ section.settings.soldout_text | default: '売り切れ' | escape }}
              </button>
              {%- endif -%}
            </div>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <!-- 商品が表示されない場合のメッセージ -->
    {%- if products_shown == 0 -%}
    <div class="cross-sell-empty">
      {%- if section.settings.show_debug -%}
      <p style="color: #ff0000;">デバッグ: 表示する商品がありません。</p>
      <ul style="font-size: 12px; color: #666;">
        <li>コレクションが選択されているか確認してください</li>
        <li>コレクション内に公開された商品があるか確認してください</li>
        <li>商品に在庫があるか確認してください</li>
        <li>現在の商品と異なる商品がコレクションに含まれているか確認してください</li>
      </ul>
      {%- else -%}
      <p class="cross-sell-empty-text">{{ section.settings.empty_text | default: '現在おすすめ商品はありません' | escape }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    {%- if section.settings.show_view_all and cross_sell_collection.products.size > products_to_show -%}
    <div class="cross-sell-footer">
      <a href="{{ cross_sell_collection.url }}" class="cross-sell-view-all">
        {{ section.settings.view_all_text | default: 'すべて見る' | escape }}
      </a>
    </div>
    {%- endif -%}
  </div>

  {%- if section.settings.show_modal -%}
  <div class="cross-sell-modal" data-modal role="dialog" aria-labelledby="modal-title" aria-hidden="true">
    <div class="cross-sell-modal-overlay" data-modal-close></div>
    <div class="cross-sell-modal-content">
      <div class="cross-sell-modal-header">
        <h3 id="modal-title">{{ section.settings.modal_title | default: 'カートに追加されました' | escape }}</h3>
        <button class="cross-sell-modal-close" data-modal-close aria-label="モーダルを閉じる">×</button>
      </div>
      <div class="cross-sell-modal-body">
        <p>{{ section.settings.modal_text | default: '他にもおすすめ商品があります' | escape }}</p>
        <div class="cross-sell-modal-actions">
          <button class="cross-sell-modal-continue" data-modal-close>
            {{ section.settings.continue_shopping_text | default: '買い物を続ける' | escape }}
          </button>
          <a href="/cart" class="cross-sell-modal-cart">
            {{ section.settings.view_cart_text | default: 'カートを見る' | escape }}
          </a>
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}
</section>

<style>
.cross-sell-section {
  padding: var(--section-padding-top, 40px) 0 var(--section-padding-bottom, 40px);
  background-color: var(--bg-color, #ffffff);
  color: var(--text-color, #333333);
}

.cross-sell-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

.cross-sell-header {
  text-align: center;
  margin-bottom: 32px;
}

.cross-sell-title {
  font-size: var(--title-size, 28px);
  font-weight: 600;
  margin: 0 0 16px;
  line-height: 1.3;
}

.cross-sell-description {
  font-size: var(--text-size, 16px);
  line-height: 1.6;
  opacity: 0.8;
}

.cross-sell-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
  margin-bottom: 32px;
}

@media (max-width: 767px) {
  .cross-sell-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
}

@media (max-width: 480px) {
  .cross-sell-grid {
    grid-template-columns: 1fr;
  }
}

.cross-sell-item {
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  overflow: hidden;
  transition: all 0.3s ease;
  background: #ffffff;
}

.cross-sell-item:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

.cross-sell-item:focus-within {
  outline: 2px solid var(--accent-color, #007bff);
  outline-offset: 2px;
}

.cross-sell-image-wrapper {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
}

.cross-sell-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.cross-sell-item:hover .cross-sell-image {
  transform: scale(1.05);
}

.cross-sell-placeholder {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

.cross-sell-content {
  padding: 16px;
}

.cross-sell-product-title {
  font-size: 16px;
  font-weight: 500;
  margin: 0 0 8px;
  line-height: 1.4;
}

.cross-sell-product-link {
  color: inherit;
  text-decoration: none;
}

.cross-sell-product-link:hover {
  text-decoration: underline;
}

.cross-sell-vendor {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
}

.cross-sell-price {
  margin-bottom: 16px;
}

.cross-sell-price-compare {
  font-size: 14px;
  color: #999;
  text-decoration: line-through;
  margin-right: 8px;
}

.cross-sell-price-current {
  font-size: 16px;
  font-weight: 600;
  color: var(--accent-color, #007bff);
}

.cross-sell-form {
  position: relative;
}

.cross-sell-add-to-cart {
  width: 100%;
  padding: 12px 16px;
  background: var(--accent-color, #007bff);
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.cross-sell-add-to-cart:hover:not(:disabled) {
  background: color-mix(in srgb, var(--accent-color, #007bff) 90%, black);
  transform: translateY(-1px);
}

.cross-sell-add-to-cart:disabled {
  background: #ccc;
  cursor: not-allowed;
  transform: none;
}

.cross-sell-add-to-cart.loading .add-to-cart-text {
  opacity: 0;
}

.cross-sell-add-to-cart.loading .loading-spinner {
  opacity: 1;
}

.cross-sell-add-to-cart.success .add-to-cart-text {
  opacity: 0;
}

.cross-sell-add-to-cart.success .add-to-cart-success {
  opacity: 1;
}

.add-to-cart-success,
.loading-spinner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.loading-spinner svg {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.cross-sell-footer {
  text-align: center;
}

.cross-sell-view-all {
  display: inline-block;
  padding: 12px 24px;
  color: var(--accent-color, #007bff);
  text-decoration: none;
  border: 2px solid var(--accent-color, #007bff);
  border-radius: 6px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cross-sell-view-all:hover {
  background: var(--accent-color, #007bff);
  color: white;
}

.cross-sell-empty {
  text-align: center;
  padding: 40px 20px;
  background: #f9f9f9;
  border-radius: 8px;
  margin: 20px 0;
}

.cross-sell-empty-text {
  color: #666;
  font-size: 16px;
  margin: 0;
}

.cross-sell-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.cross-sell-modal.active {
  opacity: 1;
  pointer-events: all;
}

.cross-sell-modal-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  cursor: pointer;
}

.cross-sell-modal-content {
  background: white;
  border-radius: 8px;
  padding: 0;
  max-width: 90%;
  width: 400px;
  position: relative;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.cross-sell-modal.active .cross-sell-modal-content {
  transform: scale(1);
}

.cross-sell-modal-header {
  padding: 20px 20px 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cross-sell-modal-close {
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  padding: 0;
  width: 30px;
  height: 30px;
}

.cross-sell-modal-body {
  padding: 20px;
}

.cross-sell-modal-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.cross-sell-modal-continue,
.cross-sell-modal-cart {
  flex: 1;
  padding: 12px;
  text-align: center;
  text-decoration: none;
  border-radius: 6px;
  font-weight: 500;
  cursor: pointer;
  border: none;
}

.cross-sell-modal-continue {
  background: #f5f5f5;
  color: #333;
}

.cross-sell-modal-cart {
  background: var(--accent-color, #007bff);
  color: white;
}

@media (max-width: 767px) {
  .cross-sell-container {
    padding: 0 16px;
  }
  
  .cross-sell-title {
    font-size: 24px;
  }
  
  .cross-sell-content {
    padding: 12px;
  }
  
  .cross-sell-modal-content {
    margin: 20px;
    width: auto;
  }
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

@media (prefers-color-scheme: dark) {
  .cross-sell-section {
    --bg-color: #1a1a1a;
    --text-color: #ffffff;
  }
  
  .cross-sell-item {
    background: #2a2a2a;
    border-color: #404040;
  }
  
  .cross-sell-modal-content {
    background: #2a2a2a;
    color: white;
  }
}
</style>

<script>
(function() {
  'use strict';
  
  const section = document.querySelector('[data-section-type="cross-sell"]');
  if (!section) return;

  const forms = section.querySelectorAll('[data-product-form]');
  const modal = section.querySelector('[data-modal]');
  
  forms.forEach(form => {
    form.addEventListener('submit', handleFormSubmit);
  });

  if (modal) {
    const closeButtons = modal.querySelectorAll('[data-modal-close]');
    closeButtons.forEach(button => {
      button.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  }

  async function handleFormSubmit(event) {
    event.preventDefault();
    
    const form = event.target;
    const button = form.querySelector('[data-add-to-cart]');
    const formData = new FormData(form);
    
    button.classList.add('loading');
    button.disabled = true;
    
    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      });
      
      if (response.ok) {
        button.classList.remove('loading');
        button.classList.add('success');
        
        updateCartCount();
        
        if (modal && section.dataset.showModal !== 'false') {
          showModal();
        }
        
        setTimeout(() => {
          button.classList.remove('success');
          button.disabled = false;
        }, 3000);
        
      } else {
        throw new Error('カートへの追加に失敗しました');
      }
      
    } catch (error) {
      console.error('Cart add error:', error);
      
      button.classList.remove('loading');
      button.disabled = false;
      
      showErrorMessage(button, 'カートへの追加に失敗しました');
    }
  }

  async function updateCartCount() {
    try {
      const response = await fetch('/cart.js');
      const cart = await response.json();
      
      const cartCounters = document.querySelectorAll('[data-cart-count]');
      cartCounters.forEach(counter => {
        counter.textContent = cart.item_count;
      });
      
      const cartIcons = document.querySelectorAll('[data-cart-icon]');
      cartIcons.forEach(icon => {
        icon.style.transform = 'scale(1.1)';
        setTimeout(() => {
          icon.style.transform = 'scale(1)';
        }, 200);
      });
      
    } catch (error) {
      console.error('Cart count update error:', error);
    }
  }

  function showModal() {
    if (!modal) return;
    
    modal.classList.add('active');
    modal.setAttribute('aria-hidden', 'false');
    
    const closeButton = modal.querySelector('[data-modal-close]');
    if (closeButton) {
      closeButton.focus();
    }
    
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden', 'true');
    
    document.body.style.overflow = '';
  }

  function showErrorMessage(button, message) {
    const existingError = button.parentNode.querySelector('.error-message');
    if (existingError) {
      existingError.remove();
    }
    
    const errorElement = document.createElement('div');
    errorElement.className = 'error-message';
    errorElement.textContent = message;
    errorElement.style.cssText = `
      color: #dc3545;
      font-size: 14px;
      margin-top: 8px;
      text-align: center;
    `;
    
    button.parentNode.appendChild(errorElement);
    
    setTimeout(() => {
      errorElement.remove();
    }, 5000);
  }

  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, observerOptions);

  const items = section.querySelectorAll('.cross-sell-item');
  items.forEach((item, index) => {
    item.style.opacity = '0';
    item.style.transform = 'translateY(20px)';
    item.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
    observer.observe(item);
  });

})();
</script>
{%- else -%}
<!-- コレクションが設定されていない場合、または商品がない場合 -->
{%- if section.settings.show_debug -%}
<div style="background: #fff3cd; border: 1px solid #ffeaa7; padding: 15px; margin: 20px; border-radius: 5px;">
  <strong>⚠️ デバッグ情報:</strong><br>
  {%- if collection_handle == blank -%}
    コレクションが設定されていません。セクション設定でコレクションを選択してください。
  {%- elsif cross_sell_collection == blank -%}
    指定されたコレクション「{{ collection_handle }}」が見つかりません。
  {%- elsif cross_sell_collection.products.size == 0 -%}
    コレクション「{{ cross_sell_collection.title }}」に商品がありません。
  {%- endif -%}
</div>
{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "クロスセル商品",
  "tag": "section",
  "class": "section-cross-sell",
  "settings": [
    {
      "type": "header",
      "content": "基本設定"
    },
    {
      "type": "text",
      "id": "title",
      "label": "セクション見出し",
      "default": "こちらもおすすめ",
      "info": "セクションの見出しを設定します"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "説明文",
      "default": "<p>これらのアイテムもチェックしてみてください</p>",
      "info": "見出し下に表示される説明文です"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "商品コレクション",
      "info": "表示する商品のコレクションを選択してください"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "表示する商品数",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "info": "表示する商品の最大数を設定します"
    },
    {
      "type": "header",
      "content": "表示設定"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "ブランド名を表示",
      "default": false,
      "info": "商品のブランド名を表示します"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "「すべて見る」リンクを表示",
      "default": true,
      "info": "コレクションページへのリンクを表示します"
    },
    {
      "type": "text",
      "id": "view_all_text",
