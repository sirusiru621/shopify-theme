<!-- Media Gallery Grid Section -->
<section class="media-gallery-section" id="media-gallery-{{ section.id }}">
  <div class="media-gallery-container">
    {% if section.settings.section_title %}
      <h2 class="gallery-title">{{ section.settings.section_title }}</h2>
    {% endif %}
    
    {% if section.settings.section_description %}
      <div class="gallery-description">
        {{ section.settings.section_description }}
      </div>
    {% endif %}

    <div class="media-grid" data-layout="{{ section.settings.grid_layout }}">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'media_item' %}
            <div class="media-item" 
                 data-size="{{ block.settings.item_size }}"
                 {{ block.shopify_attributes }}>
              <div class="media-wrapper">
                {% if block.settings.media_file %}
                  {% assign media = block.settings.media_file %}
                  
                  {% if media.media_type == 'video' %}
                    <!-- Video Content -->
                    <div class="video-container">
                      <video 
                        class="media-video"
                        {% if block.settings.video_autoplay %}autoplay{% endif %}
                        {% if block.settings.video_loop %}loop{% endif %}
                        {% if block.settings.video_muted %}muted{% endif %}
                        {% if block.settings.video_controls %}controls{% endif %}
                        playsinline
                        preload="metadata"
                      >
                        {% for source in media.sources %}
                          <source src="{{ source.url }}" type="{{ source.mime_type }}">
                        {% endfor %}
                        Your browser does not support the video tag.
                      </video>
                      
                      {% if block.settings.video_overlay_text %}
                        <div class="video-overlay">
                          <span class="video-overlay-text">{{ block.settings.video_overlay_text }}</span>
                        </div>
                      {% endif %}
                    </div>
                  {% else %}
                    <!-- Image Content -->
                    {% if block.settings.media_file.preview_image %}
                      {% assign image = block.settings.media_file.preview_image %}
                    {% elsif block.settings.media_file %}
                      {% assign image = block.settings.media_file %}
                    {% endif %}
                    
                    {% if image %}
                      <img 
                        src="{{ image | image_url: width: 800 }}"
                        srcset="{{ image | image_url: width: 400 }} 400w,
                                {{ image | image_url: width: 600 }} 600w,
                                {{ image | image_url: width: 800 }} 800w,
                                {{ image | image_url: width: 1200 }} 1200w"
                        sizes="(max-width: 480px) 100vw, 
                               (max-width: 768px) 50vw, 
                               33vw"
                        alt="{{ image.alt | escape }}"
                        class="media-image"
                        loading="lazy"
                      >
                    {% endif %}
                  {% endif %}
                {% endif %}

                <!-- Overlay Content -->
                {% if block.settings.overlay_text or block.settings.overlay_link %}
                  <div class="media-overlay">
                    {% if block.settings.overlay_text %}
                      <div class="overlay-content">
                        <span class="overlay-text">{{ block.settings.overlay_text }}</span>
                      </div>
                    {% endif %}
                    
                    {% if block.settings.overlay_link %}
                      <a href="{{ block.settings.overlay_link }}" 
                         class="overlay-link"
                         {% if block.settings.link_target %}target="_blank"{% endif %}>
                        <span class="sr-only">{{ block.settings.overlay_text | default: 'View content' }}</span>
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* Media Gallery Section Styles */
  .media-gallery-section {
    width: 100%;
    background-color: {{ section.settings.section_bg_color | default: '#ffffff' }};
    padding: {{ section.settings.section_padding_top | default: 60 }}px 20px {{ section.settings.section_padding_bottom | default: 60 }}px;
  }

  .media-gallery-container {
    max-width: {{ section.settings.container_width | default: 1200 }}px;
    margin: 0 auto;
  }

  .gallery-title {
    font-size: {{ section.settings.title_font_size | default: 32 }}px;
    font-weight: 700;
    color: {{ section.settings.title_color | default: '#333333' }};
    text-align: {{ section.settings.title_alignment | default: 'center' }};
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .gallery-description {
    font-size: {{ section.settings.description_font_size | default: 16 }}px;
    color: {{ section.settings.description_color | default: '#666666' }};
    text-align: {{ section.settings.description_alignment | default: 'center' }};
    margin-bottom: 48px;
    line-height: 1.6;
  }

  /* Grid Layout Styles */
  .media-grid {
    display: grid;
    gap: {{ section.settings.grid_gap | default: 16 }}px;
    width: 100%;
  }

  /* Masonry Layout */
  .media-grid[data-layout="masonry"] {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    grid-auto-rows: max-content;
  }

  /* Equal Height Layout */
  .media-grid[data-layout="equal"] {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    grid-auto-rows: 250px;
  }

  /* Custom Grid Layout */
  .media-grid[data-layout="custom"] {
    grid-template-columns: repeat(6, 1fr);
    grid-template-rows: repeat(4, 200px);
  }

  /* Media Item Styles */
  .media-item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.border_radius | default: 8 }}px;
    background-color: {{ section.settings.item_bg_color | default: '#f5f5f5' }};
    transition: all 0.3s ease;
  }

  .media-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
  }

  /* Custom Grid Sizes */
  .media-grid[data-layout="custom"] .media-item[data-size="small"] {
    grid-column: span 2;
    grid-row: span 2;
  }

  .media-grid[data-layout="custom"] .media-item[data-size="medium"] {
    grid-column: span 3;
    grid-row: span 2;
  }

  .media-grid[data-layout="custom"] .media-item[data-size="large"] {
    grid-column: span 4;
    grid-row: span 3;
  }

  .media-grid[data-layout="custom"] .media-item[data-size="full"] {
    grid-column: span 6;
    grid-row: span 2;
  }

  .media-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Image Styles */
  .media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
  }

  .media-item:hover .media-image {
    transform: scale(1.05);
  }

  /* Video Styles */
  .video-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .media-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .video-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 14px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .video-container:hover .video-overlay {
    opacity: 1;
  }

  /* Media Overlay Styles */
  .media-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | default: 0.4 }});
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .media-item:hover .media-overlay {
    opacity: 1;
  }

  .overlay-content {
    text-align: center;
    color: {{ section.settings.overlay_text_color | default: '#ffffff' }};
    z-index: 2;
  }

  .overlay-text {
    font-size: {{ section.settings.overlay_font_size | default: 16 }}px;
    font-weight: 600;
    line-height: 1.4;
  }

  .overlay-link {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    text-decoration: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .media-grid[data-layout="custom"] {
      grid-template-columns: repeat(4, 1fr);
    }

    .media-grid[data-layout="custom"] .media-item[data-size="large"],
    .media-grid[data-layout="custom"] .media-item[data-size="full"] {
      grid-column: span 4;
    }

    .media-grid[data-layout="custom"] .media-item[data-size="medium"] {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .gallery-title {
      font-size: {{ section.settings.title_font_size_mobile | default: 24 }}px;
    }

    .gallery-description {
      font-size: {{ section.settings.description_font_size_mobile | default: 14 }}px;
      margin-bottom: 32px;
    }

    .media-grid {
      gap: {{ section.settings.grid_gap_mobile | default: 12 }}px;
    }

    .media-grid[data-layout="masonry"],
    .media-grid[data-layout="equal"] {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }

    .media-grid[data-layout="custom"] {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(auto, 150px);
    }

    .media-grid[data-layout="custom"] .media-item {
      grid-column: span 1;
      grid-row: span 1;
    }

    .overlay-text {
      font-size: {{ section.settings.overlay_font_size_mobile | default: 14 }}px;
    }

    .media-gallery-section {
      padding: {{ section.settings.section_padding_top_mobile | default: 40 }}px 15px {{ section.settings.section_padding_bottom_mobile | default: 40 }}px;
    }
  }

  @media (max-width: 480px) {
    .media-grid[data-layout="masonry"],
    .media-grid[data-layout="equal"],
    .media-grid[data-layout="custom"] {
      grid-template-columns: 1fr;
    }

    .media-grid[data-layout="equal"] {
      grid-auto-rows: 200px;
    }

    .media-grid[data-layout="custom"] .media-item {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  /* Animation Styles */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .media-item.animate-in {
    animation: fadeInUp 0.6s ease forwards;
  }

  .media-item {
    opacity: 0;
  }

  /* Custom Grid Templates for Different Layouts */
  .media-grid[data-layout="pinterest"] {
    columns: {{ section.settings.pinterest_columns | default: 4 }};
    column-gap: {{ section.settings.grid_gap | default: 16 }}px;
  }

  .media-grid[data-layout="pinterest"] .media-item {
    break-inside: avoid;
    margin-bottom: {{ section.settings.grid_gap | default: 16 }}px;
    display: inline-block;
    width: 100%;
  }

  @media (max-width: 768px) {
    .media-grid[data-layout="pinterest"] {
      columns: {{ section.settings.pinterest_columns_mobile | default: 2 }};
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Intersection Observer for scroll animations
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -20px 0px'
    };

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('animate-in');
          }, index * 100); // Stagger animation
        }
      });
    }, observerOptions);

    // Observe all media items
    const mediaItems = document.querySelectorAll('.media-item');
    mediaItems.forEach(item => {
      observer.observe(item);
    });

    // Video play/pause on hover (optional)
    const videos = document.querySelectorAll('.media-video');
    videos.forEach(video => {
      const mediaItem = video.closest('.media-item');
      
      mediaItem.addEventListener('mouseenter', () => {
        if (!video.hasAttribute('autoplay')) {
          video.play().catch(e => {
            console.log('Video play failed:', e);
          });
        }
      });

      mediaItem.addEventListener('mouseleave', () => {
        if (!video.hasAttribute('autoplay')) {
          video.pause();
        }
      });
    });

    // Masonry layout adjustment (for browsers that need it)
    function adjustMasonryLayout() {
      const masonryGrids = document.querySelectorAll('.media-grid[data-layout="masonry"]');
      
      masonryGrids.forEach(grid => {
        const items = grid.querySelectorAll('.media-item');
        
        items.forEach(item => {
          const image = item.querySelector('.media-image');
          if (image && image.complete) {
            item.style.gridRowEnd = `span ${Math.ceil(image.naturalHeight / 10)}`;
          } else if (image) {
            image.addEventListener('load', () => {
              item.style.gridRowEnd = `span ${Math.ceil(image.naturalHeight / 10)}`;
            });
          }
        });
      });
    }

    // Call masonry adjustment
    setTimeout(adjustMasonryLayout, 100);
    window.addEventListener('resize', adjustMasonryLayout);
  });
</script>

