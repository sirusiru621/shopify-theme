<script>
// ギフト設定関連のJavaScript
let currentItemKey = '';
let currentItemIndex = 0;

function openGiftPopup(itemKey, itemIndex) {
  currentItemKey = itemKey;
  currentItemIndex = itemIndex;
  
  const overlay = document.getElementById('giftPopupOverlay');
  overlay.classList.add('active');
  overlay.setAttribute('aria-hidden', 'false');
  
  // 既存の設定を読み込み
  loadExistingGiftSettings(itemKey);
  
  // フォーカス管理
  const firstInput = overlay.querySelector('select, input');
  if (firstInput) {
    firstInput.focus();
  }
  
  // ESCキーで閉じる
  document.addEventListener('keydown', handleEscapeKey);
  
  // 背景クリックで閉じる
  overlay.addEventListener('click', handleOverlayClick);
}

function closeGiftPopup() {
  const overlay = document.getElementById('giftPopupOverlay');
  overlay.classList.remove('active');
  overlay.setAttribute('aria-hidden', 'true');
  
  // イベントリスナーを削除
  document.removeEventListener('keydown', handleEscapeKey);
  overlay.removeEventListener('click', handleOverlayClick);
  
  // フォーカスを戻す
  const triggerButton = document.querySelector(`[onclick*="${currentItemKey}"]`);
  if (triggerButton) {
    triggerButton.focus();
  }
}

function handleEscapeKey(event) {
  if (event.key === 'Escape') {
    closeGiftPopup();
  }
}

function handleOverlayClick(event) {
  if (event.target === event.currentTarget) {
    closeGiftPopup();
  }
}

function loadExistingGiftSettings(itemKey) {
  // カート属性から既存の設定を読み込む
  const quantitySelect = document.getElementById('giftQuantitySelect');
  const noshiSelect = document.getElementById('giftNoshiSelect');
  const purposeSelect = document.getElementById('giftPurposeSelect');
  const noshiPositionSelect = document.getElementById('giftNoshiPositionSelect');
  
  // 既存の属性値を取得（実装に応じて調整）
  // この部分は実際のカート属性の取得方法に合わせて実装
}

function saveGiftSettings() {
  const quantityValue = document.getElementById('giftQuantitySelect').value;
  const noshiValue = document.getElementById('giftNoshiSelect').value;
  const purposeValue = document.getElementById('giftPurposeSelect').value;
  const inscriptionValue = document.querySelector('input[name="giftInscription"]:checked')?.value || '';
  const noshiPositionValue = document.getElementById('giftNoshiPositionSelect').value;
  
  // カート属性として保存
  const giftSettings = {
    quantity: quantityValue,
    noshi: noshiValue,
    purpose: purposeValue,
    inscription: inscriptionValue,
    noshi_position: noshiPositionValue
  };
  
  // カート更新のAPIコール
  updateCartWithGiftSettings(currentItemKey, giftSettings)
    .then(() => {
      closeGiftPopup();
      // 成功メッセージを表示（オプション）
      showNotification('{{ section.settings.success_message | default: "ギフト設定が保存されました" }}');
    })
    .catch((error) => {
      console.error('ギフト設定の保存に失敗しました:', error);
      showNotification('{{ section.settings.error_message | default: "保存に失敗しました。もう一度お試しください。" }}', 'error');
    });
}

async function updateCartWithGiftSettings(itemKey, settings) {
  const body = JSON.stringify({
    attributes: {
      [`gift_settings_${itemKey}`]: JSON.stringify(settings)
    }
  });
  
  const response = await fetch(window.Shopify.routes.root + 'cart/update.js', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
    },
    body: body
  });
  
  if (!response.ok) {
    throw new Error('カート更新に失敗しました');
  }
  
  return response.json();
}

function showNotification(message, type = 'success') {
  // 通知表示の実装（必要に応じて）
  console.log(`${type.toUpperCase()}: ${message}`);
}

// カスタムオプションの変更を監視
document.addEventListener('change', function(event) {
  if (event.target.matches('.custom-option-select')) {
    const itemIndex = event.target.closest('.cart-custom-options').dataset.itemIndex;
    const attributeName = event.target.dataset.cartAttribute;
    const attributeValue = event.target.value;
    
    // カート属性を即座に更新
    updateCartAttribute(attributeName, attributeValue);
  }
});

async function updateCartAttribute(name, value) {
  try {
    const body = JSON.stringify({
      attributes: {
        [name]: value
      }
    });
    
    const response = await fetch(window.Shopify.routes.root + 'cart/update.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: body
    });
    
    if (response.ok) {
      console.log(`属性 ${name} を ${value} に更新しました`);
    }
  } catch (error) {
    console.error('属性更新エラー:', error);
  }
}

// ラジオボタンの選択状態を管理
document.addEventListener('change', function(event) {
  if (event.target.matches('input[name="giftInscription"]')) {
    // 選択されたオプションのハイライト
    document.querySelectorAll('.gift-option-item').forEach(item => {
      item.classList.remove('selected');
    });
    
    const selectedItem = event.target.closest('.gift-option-item');
    if (selectedItem) {
      selectedItem.classList.add('selected');
    }
  }
});

// アクセシビリティ: フォーカストラップ
function trapFocus(element) {
  const focusableElements = element.querySelectorAll(
    'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
  );
  
  const firstFocusable = focusableElements[0];
  const lastFocusable = focusableElements[focusableElements.length - 1];
  
  element.addEventListener('keydown', function(event) {
    if (event.key === 'Tab') {
      if (event.shiftKey) {
        if (document.activeElement === firstFocusable) {
          lastFocusable.focus();
          event.preventDefault();
        }
      } else {
        if (document.activeElement === lastFocusable) {
          firstFocusable.focus();
          event.preventDefault();
        }
      }
    }
  });
}

// ポップアップが開いた時にフォーカストラップを適用
const observer = new MutationObserver(function(mutations) {
  mutations.forEach(function(mutation) {
    if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
      const overlay = mutation.target;
      if (overlay.classList.contains('active')) {
        trapFocus(overlay);
      }
    }
  });
});

document.addEventListener('DOMContentLoaded', function() {
  const overlay = document.getElementById('giftPopupOverlay');
  if (overlay) {
    observer.observe(overlay, { attributes: true });
  }
});
</script>

        
