    { "type": "text", "id": "delivery_company_label", "label": "配送業者ラベル", "default": "配送業者" },
    { "type": "text", "id": "delivery_company_attribute", "label": "配送業者属性名", "default": "配送業者" },
    { "type": "textarea", "id": "company_options", "label": "配送業者選択肢", "default": "ヤマト運輸,佐川急便,日本郵便,西濃運輸", "info": "カンマ区切りの表示名のみ（例：ヤマト運輸,佐川急便）" },

