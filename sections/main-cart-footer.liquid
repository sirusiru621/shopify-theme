    { "type": "text", "id": "date_placeholder_text", "label": "日付選択プレースホルダー", "default": "日付を選択してください" },
    { "type": "checkbox", "id": "exclude_weekends", "label": "土日を除外する", "default": false, "info": "土曜日・日曜日を配送日から除外" },
    { "type": "checkbox", "id": "exclude_holidays", "label": "祝日を除外する", "default": true, "info": "日本の祝日を配送日から除外" },
