</style>
  <!-- 配送オプション用JavaScript -->
  <script>
   document.addEventListener('DOMContentLoaded', function() {
  /**
   * 配送オプション機能初期化（改良版）
   * @param {string} blockId - ブロック固有ID
   */
  const blockId = '{{ unique_id }}';
  const container = document.querySelector(`[data-cart-delivery-options="${blockId}"]`);
  
  if (!container) {
    console.warn('配送オプションコンテナが見つかりません');
    return;
  }

  // DOM要素の取得
  const elements = {
    // 日時指定セクション
    datetimeToggle: container.querySelector('#datetime-toggle-{{ unique_id }}'),
    datetimeContent: container.querySelector('#datetime-content-{{ unique_id }}'),
    companySelect: container.querySelector('#delivery-company-{{ unique_id }}'),
    dateSelect: container.querySelector('#delivery-date-{{ unique_id }}'),
    timeSelect: container.querySelector('#delivery-time-{{ unique_id }}'),
    
    // ギフトセクション
    giftToggle: container.querySelector('#gift-toggle-{{ unique_id }}'),
    giftContent: container.querySelector('#gift-content-{{ unique_id }}'),
    noshiSelect: container.querySelector('#noshi-select-{{ unique_id }}'),
    noshiNameField: container.querySelector('#noshi-name-field-{{ unique_id }}'),
    
    // 共通
    updateButton: container.querySelector('.delivery-options-update')
  };

  // 設定値
  const config = {
    excludeWeekends: {{ block.settings.exclude_weekends | json }},
    excludeHolidays: {{ block.settings.exclude_holidays | json }},
    minDeliveryDays: {{ block.settings.min_delivery_days | default: 3 | json }},
    maxDeliveryDays: {{ block.settings.max_delivery_days | default: 30 | json }},
    cutoffTime: '{{ block.settings.cutoff_time | default: "15:00" }}',
    customHolidays: '{{ block.settings.custom_holidays | default: "" }}'.split(',').filter(d => d.trim()),
    showDeliveryCompany: {{ block.settings.show_delivery_company | json }}
  };

  // 配送業者別時間帯マッピング（配送業者選択が有効な場合のみ使用）
  const timeSlotMapping = {
    'ヤマト運輸': ['午前中(8-12時)', '14-16時', '16-18時', '18-20時', '19-21時'],
    '佐川急便': ['午前中', '12-14時', '14-16時', '16-18時', '18-21時'],
    '日本郵便': ['午前中', '12-14時', '14-16時', '16-18時', '18-20時', '19-21時'],
    '西濃運輸': ['午前中', '12-14時', '14-16時', '16-18時', '18-20時']
  };

  /**
   * 初期化処理
   */
  function init() {
    setupDateOptions();
    setupEventListeners();
    setupCharacterCount();
  }

  /**
   * イベントリスナー設定
   */
  function setupEventListeners() {
    // 日時指定セクショントグル
    if (elements.datetimeToggle) {
      elements.datetimeToggle.addEventListener('change', handleDatetimeToggle);
    }

    // ギフトセクショントグル
    if (elements.giftToggle) {
      elements.giftToggle.addEventListener('change', handleGiftToggle);
    }

    // 配送業者変更時の時間帯更新（配送業者選択が有効な場合のみ）
    if (config.showDeliveryCompany && elements.companySelect && elements.timeSelect) {
      elements.companySelect.addEventListener('change', updateTimeSlots);
    }

    // のし選択
    if (elements.noshiSelect) {
      elements.noshiSelect.addEventListener('change', handleNoshiSelect);
      handleNoshiSelect(); // 初期状態設定
    }

    // 更新ボタン
    if (elements.updateButton) {
      elements.updateButton.addEventListener('click', updateCartAttributes);
    }
  }

  /**
   * 日時指定セクション切り替え処理
   */
  function handleDatetimeToggle() {
    if (!elements.datetimeToggle || !elements.datetimeContent) return;

    if (elements.datetimeToggle.checked) {
      elements.datetimeContent.style.display = 'block';
    } else {
      elements.datetimeContent.style.display = 'none';
      clearDatetimeOptions();
    }
  }

  /**
   * ギフトセクション切り替え処理
   */
  function handleGiftToggle() {
    if (!elements.giftToggle || !elements.giftContent) return;

    if (elements.giftToggle.checked) {
      elements.giftContent.style.display = 'block';
    } else {
      elements.giftContent.style.display = 'none';
      clearGiftOptions();
    }
  }

  /**
   * 日時指定オプションクリア
   */
  function clearDatetimeOptions() {
    if (!elements.datetimeContent) return;

    const selects = elements.datetimeContent.querySelectorAll('select');
    selects.forEach(select => select.selectedIndex = 0);
  }

  /**
   * ギフトオプションクリア
   */
  function clearGiftOptions() {
    if (!elements.giftContent) return;

    const selects = elements.giftContent.querySelectorAll('select');
    const inputs = elements.giftContent.querySelectorAll('input[type="text"], textarea');

    selects.forEach(select => select.selectedIndex = 0);
    inputs.forEach(input => input.value = '');

    if (elements.noshiNameField) {
      elements.noshiNameField.style.display = 'none';
    }
  }

  /**
   * 配送業者別時間帯更新
   */
  function updateTimeSlots() {
    if (!config.showDeliveryCompany || !elements.companySelect || !elements.timeSelect) return;

    const selectedCompany = elements.companySelect.value;
    const currentValue = elements.timeSelect.value;

    // 既存オプション削除（最初のオプション以外）
    while (elements.timeSelect.children.length > 1) {
      elements.timeSelect.removeChild(elements.timeSelect.lastChild);
    }

    // 時間帯オプション生成
    const timeSlots = timeSlotMapping[selectedCompany] || [
      '午前中', '12-14時', '14-16時', '16-18時', '18-20時', '19-21時'
    ];

    timeSlots.forEach(timeSlot => {
      const option = document.createElement('option');
      option.value = timeSlot;
      option.textContent = timeSlot;
      
      if (currentValue === timeSlot) {
        option.selected = true;
      }
      
      elements.timeSelect.appendChild(option);
    });
  }

  /**
   * のし選択処理
   */
  function handleNoshiSelect() {
    if (!elements.noshiSelect || !elements.noshiNameField) return;

    if (elements.noshiSelect.value && elements.noshiSelect.value !== '') {
      elements.noshiNameField.style.display = 'block';
    } else {
      elements.noshiNameField.style.display = 'none';
      const nameInput = elements.noshiNameField.querySelector('input');
      if (nameInput) nameInput.value = '';
    }
  }

  /**
   * 配送日オプション生成
   */
  function setupDateOptions() {
    if (!elements.dateSelect) return;

    const today = new Date();
    const currentHour = today.getHours();
    const currentMinute = today.getMinutes();
    const cutoffTime = config.cutoffTime.split(':');
    const cutoffHour = parseInt(cutoffTime[0]);
    const cutoffMinute = parseInt(cutoffTime[1] || 0);

    // 締切時間判定
    const isPastCutoff = (currentHour > cutoffHour) || 
                        (currentHour === cutoffHour && currentMinute >= cutoffMinute);

    let startDate = new Date(today);
    let minDays = config.minDeliveryDays;

    if (isPastCutoff) {
      minDays += 1;
    }

    startDate.setDate(today.getDate() + minDays);

    // 現在の選択値保存
    const currentValue = elements.dateSelect.value;
    const savedValue = '{{ cart.attributes[block.settings.delivery_date_attribute] }}';

    // 既存オプション削除
    while (elements.dateSelect.children.length > 1) {
      elements.dateSelect.removeChild(elements.dateSelect.lastChild);
    }

    // 日付オプション生成
    const maxOptions = config.maxDeliveryDays - config.minDeliveryDays;
    
    for (let i = 0; i < maxOptions; i++) {
      const currentDate = new Date(startDate);
      currentDate.setDate(startDate.getDate() + i);

      // 除外日判定
      if (config.excludeWeekends && isWeekend(currentDate)) continue;
      if (config.excludeHolidays && isHoliday(currentDate)) continue;
      if (isCustomHoliday(currentDate)) continue;

      const option = document.createElement('option');
      const formattedValue = formatDisplayDate(currentDate);
      option.value = formattedValue;
      option.textContent = formattedValue;

      if (savedValue === formattedValue || currentValue === formattedValue) {
        option.selected = true;
      }

      elements.dateSelect.appendChild(option);
    }
  }

  /**
   * 土日判定
   */
  function isWeekend(date) {
    const dayOfWeek = date.getDay();
    return dayOfWeek === 0 || dayOfWeek === 6;
  }

  /**
   * 祝日判定（2025年日本の祝日）
   */
  function isHoliday(date) {
    const holidays = [
      '2025-01-01', '2025-01-13', '2025-02-11', '2025-02-23',
      '2025-03-20', '2025-04-29', '2025-05-03', '2025-05-04',
      '2025-05-05', '2025-07-21', '2025-08-11', '2025-09-15',
      '2025-09-23', '2025-10-13', '2025-11-03', '2025-11-23'
    ];
    return holidays.includes(formatDate(date));
  }

  /**
   * カスタム休業日判定
   */
  function isCustomHoliday(date) {
    if (!config.customHolidays.length) return false;
    return config.customHolidays.includes(formatDate(date));
  }

  /**
   * 日付フォーマット（YYYY-MM-DD）
   */
  function formatDate(date) {
    return date.toLocaleDateString('sv-SE');
  }

  /**
   * 表示用日付フォーマット
   */
  function formatDisplayDate(date) {
    return date.toLocaleDateString('ja-JP', {
      month: 'numeric',
      day: 'numeric',
      weekday: 'short'
    });
  }

  /**
   * 文字数カウンター設定
   */
  function setupCharacterCount() {
    const countElements = container.querySelectorAll('input[maxlength], textarea[maxlength]');

    countElements.forEach(element => {
      const maxLength = parseInt(element.getAttribute('maxlength')) || 100;
      const countElement = element.parentElement.querySelector('.current-count');

      if (!countElement) return;

      function updateCount() {
        const currentLength = element.value.length;
        countElement.textContent = currentLength;

        // 文字数に応じた色変更
        if (currentLength > maxLength * 0.9) {
          countElement.style.color = '#dc3545';
        } else if (currentLength > maxLength * 0.7) {
          countElement.style.color = '#ffc107';
        } else {
          countElement.style.color = '';
        }
      }

      element.addEventListener('input', updateCount);
      updateCount(); // 初期値設定
    });
  }

  /**
   * カート属性更新
   */
  function updateCartAttributes() {
    if (!elements.updateButton) return;

    const buttonText = elements.updateButton.querySelector('.button-text');
    const buttonLoading = elements.updateButton.querySelector('.button-loading');

    // ボタン状態変更
    elements.updateButton.disabled = true;
    if (buttonText) buttonText.style.display = 'none';
    if (buttonLoading) buttonLoading.style.display = 'flex';

    // フォーム送信
    const form = document.getElementById('cartForm') || document.querySelector('form[action*="/cart"]');
    if (form) {
      const submitButton = document.createElement('button');
      submitButton.type = 'submit';
      submitButton.name = 'update';
      submitButton.style.display = 'none';
      form.appendChild(submitButton);
      submitButton.click();
      form.removeChild(submitButton);

      // 成功メッセージ表示
      setTimeout(() => {
        showMessage('配送オプションを更新しました');
      }, 500);
    }

    // ボタン復元
    setTimeout(() => {
      elements.updateButton.disabled = false;
      if (buttonText) buttonText.style.display = 'inline';
      if (buttonLoading) buttonLoading.style.display = 'none';
    }, 2000);
  }

  /**
   * メッセージ表示
   */
  function showMessage(text) {
    // 既存メッセージ削除
    const existingMessage = document.querySelector('.delivery-success-message');
    if (existingMessage) {
      existingMessage.remove();
    }

    // メッセージ作成
    const message = document.createElement('div');
    message.className = 'delivery-success-message';
    message.textContent = text;

    document.body.appendChild(message);

    // アニメーション表示
    setTimeout(() => {
      message.style.transform = 'translateX(0)';
    }, 100);

    // 自動削除
    setTimeout(() => {
      message.style.transform = 'translateX(400px)';
      setTimeout(() => {
        if (message.parentNode) {
          message.parentNode.removeChild(message);
        }
      }, 300);
    }, 3000);
  }

  // 初期化実行
  init();

  // ページ読み込み完了時の追加処理
  window.addEventListener('load', function() {
    if (config.showDeliveryCompany && elements.companySelect && elements.companySelect.value) {
      updateTimeSlots();
    }
  });
});
  </script>
            {%- when 'subtotal' -%}
              <div class="js-contents" {{ block.shopify_attributes }}>
                <div class="totals">
                  <h2 class="totals__subtotal">{{ 'sections.cart.subtotal' | t }}</h2>
                  <p class="totals__subtotal-value">{{ cart.total_price | money_with_currency }}</p>
                </div>

                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          {%- render 'icon-discount' -%}
                          {{ discount.title }}
                          (-{{ discount.total_allocated_amount | money }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <small class="tax-note caption-large rte">
                  {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- elsif cart.taxes_included -%}
                    {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                  {%- elsif shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                  {%- else -%}
                    {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                  {%- endif -%}
                </small>
              </div>
            {%- else -%}
              <div class="cart__ctas" {{ block.shopify_attributes }}>
                <noscript>
                  <button type="submit" class="cart__update-button button button--secondary" form="cart">
                    {{ 'sections.cart.update' | t }}
                  </button>
                </noscript>

                <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  {{ 'sections.cart.checkout' | t }}
                </button>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>

