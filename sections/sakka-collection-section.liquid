{% comment %}
Artist Collection Template Section
作家コレクションテンプレート - 左サイドバーにShopifyメニュー、右エリアに複数バナーブロックと説明セクション、コレクション商品を表示
{% endcomment %}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- if section.settings.enable_quick_add -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* アーティストコレクション専用スタイル */
  .artist-collection-wrapper {
    display: grid;
    grid-template-columns: {{ section.settings.sidebar_width }}px 1fr;
    gap: {{ section.settings.content_gap }}px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .artist-sidebar {
    background: {{ section.settings.sidebar_bg_color }};
    padding: {{ section.settings.sidebar_padding }}px;
    border-radius: {{ section.settings.sidebar_border_radius }}px;
    height: fit-content;
    position: sticky;
    top: 20px;
  }

  .artist-sidebar__title {
    font-size: {{ section.settings.sidebar_title_size }}px;
    font-weight: {{ section.settings.sidebar_title_weight }};
    color: {{ section.settings.sidebar_title_color }};
    margin-bottom: 20px;
    text-align: center;
    border-bottom: 2px solid {{ section.settings.sidebar_border_color }};
    padding-bottom: 10px;
  }

  .artist-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .artist-menu__item {
    margin-bottom: 8px;
  }

  .artist-menu__link {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: {{ section.settings.menu_link_color }};
    font-size: {{ section.settings.menu_link_size }}px;
    font-weight: {{ section.settings.menu_link_weight }};
    border-radius: 0px;
    transition: all 0.3s ease;
    border-left: 0px!important;
    position: relative;
  }

  .artist-menu__link:hover,
  .artist-menu__link.active {
    background: {{ section.settings.menu_link_hover_bg }};
    color: {{ section.settings.menu_link_hover_color }};
    border-left-color: {{ section.settings.accent_color }};
    transform: translateX(4px);
  }

  .artist-menu__link.current {
    background: {{ section.settings.menu_link_active_bg }};
    color: {{ section.settings.menu_link_active_color }};
    border-left-color: {{ section.settings.accent_color }};
    font-weight: {{ section.settings.menu_link_weight | plus: 200 }};
  }

  .main-content {
    min-height: 100vh;
  }

  /* 説明セクションスタイル */
  .description-section {
    margin-bottom: {{ section.settings.description_section_margin }}px;
    padding: {{ section.settings.description_padding }}px;
    background: {{ section.settings.description_bg_color }};
    border-radius: {{ section.settings.description_border_radius }}px;
    border: 1px solid {{ section.settings.description_border_color }};
  }

  .description-header {
    text-align: center;
    margin-bottom: {{ section.settings.description_header_margin }}px;
    padding-bottom: {{ section.settings.description_header_padding }}px;
    border-bottom: 2px solid {{ section.settings.description_border_color }};
  }

  .description-title {
    font-size: {{ section.settings.description_title_size }}px;
    font-weight: {{ section.settings.description_title_weight }};
    color: {{ section.settings.description_title_color }};
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .description-subtitle {
    font-size: {{ section.settings.description_subtitle_size }}px;
    font-weight: {{ section.settings.description_subtitle_weight }};
    color: {{ section.settings.description_subtitle_color }};
    opacity: 0.9;
  }

  .description-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ section.settings.description_content_gap }}px;
  }

  .description-text {
    font-size: {{ section.settings.description_text_size }}px;
    line-height: {{ section.settings.description_text_line_height }};
    color: {{ section.settings.description_text_color }};
    margin-bottom: 20px;
  }

  .description-text p {
    margin-bottom: 16px;
  }

  .description-text p:last-child {
    margin-bottom: 0;
  }

  .career-section {
    margin-top: 30px;
  }

  .career-title {
    font-size: {{ section.settings.career_title_size }}px;
    font-weight: {{ section.settings.career_title_weight }};
    color: {{ section.settings.career_title_color }};
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid {{ section.settings.description_border_color }};
  }

  .career-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .career-item {
    display: grid;
    grid-template-columns: {{ section.settings.career_year_width }}px 1fr;
    gap: 20px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid {{ section.settings.career_border_color }};
  }

  .career-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .career-year {
    font-size: {{ section.settings.career_year_size }}px;
    font-weight: {{ section.settings.career_year_weight }};
    color: {{ section.settings.career_year_color }};
    text-align: right;
    align-self: start;
  }

  .career-content {
    font-size: {{ section.settings.career_content_size }}px;
    color: {{ section.settings.career_content_color }};
    line-height: 1.6;
  }

  /* バナーセクション - 複数バナー対応 */
  .banner-grid {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.banner_gap }}px;
    margin-bottom: {{ section.settings.banner_section_margin }}px;
  }

  .banner-item {
    border-radius: {{ section.settings.banner_border_radius }}px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    margin: 0 auto;
  }

  /* バナーサイズバリエーション */
  .banner-item.size-full {
    width: 100%;
    height: {{ section.settings.banner_height }}px;
  }

  .banner-item.size-large {
    width: 80%;
    height: {{ section.settings.banner_height | times: 0.8 | round: 0 }}px;
  }

  .banner-item.size-medium {
    width: 60%;
    height: {{ section.settings.banner_height | times: 0.6 | round: 0 }}px;
  }

  .banner-item.size-small {
    width: 40%;
    height: {{ section.settings.banner_height | times: 0.4 | round: 0 }}px;
  }

  .banner-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  .banner-item.clickable {
    cursor: pointer;
  }

  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient({{ section.settings.overlay_direction }}deg, 
                              rgba(0,0,0,{{ section.settings.overlay_opacity_start | divided_by: 100.0 }}) 0%, 
                              rgba(0,0,0,{{ section.settings.overlay_opacity_end | divided_by: 100.0 }}) 100%);
  }

  .banner-content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20px;
  }

  .banner-text-left {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    align-self: flex-start;
    text-align: start;
  }

  .banner-text-right {
    writing-mode: horizontal-tb;
    text-align: right;
    align-self: flex-start;
    max-width: 50%;
  }

  .banner-title {
    font-size: {{ section.settings.banner_title_size }}px;
    font-weight: {{ section.settings.banner_title_weight }};
    margin-bottom: 12px;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    line-height: 1.3;
    color: #ffffff;
  }

  .banner-subtitle {
    font-size: {{ section.settings.banner_subtitle_size }}px;
    font-weight: {{ section.settings.banner_subtitle_weight }};
    opacity: 0.95;
    text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
    line-height: 1.4;
    color: #ffffff;
  }

  .banner-title-mobile,
  .banner-subtitle-mobile {
    display: none;
  }

  /* マルチカラムセクション - 新規追加 */
  .multi-column-section {
    margin-bottom: {{ section.settings.banner_section_margin }}px;
  }

  .multi-column-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.banner_gap }}px;
  }

  .multi-column-item {
    position: relative;
    border-radius: {{ section.settings.banner_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 300px;
    display: block;
    text-decoration: none;
  }

  .multi-column-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }

  .multi-column-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .multi-column-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.3);
    transition: background 0.3s ease;
  }

  .multi-column-item:hover .multi-column-overlay {
    background: rgba(0, 0, 0, 0.4);
  }

  .multi-column-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    text-align: center;
    width: 90%;
  }

  .multi-column-title {
    font-size: 24px;
    font-weight: 600;
    color: #ffffff;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
    line-height: 1.3;
    margin: 0;
  }

  /* レスポンシブ対応 */
  @media screen and (max-width: 768px) {
    .artist-collection-wrapper {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 0 16px;
    }

    .artist-sidebar {
      position: static;
      order: {{ section.settings.mobile_sidebar_order }};
    }

    .artist-sidebar__title {
      font-size: {{ section.settings.sidebar_title_size | minus: 4 }}px;
    }

    .artist-menu {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .artist-menu__item {
      margin-bottom: 0;
    }

    .artist-menu__link {
      padding: 8px 12px;
      font-size: {{ section.settings.menu_link_size | minus: 2 }}px;
      white-space: nowrap;
    }

    .description-section {
      padding: {{ section.settings.description_padding | minus: 8 }}px;
      margin-bottom: {{ section.settings.description_section_margin | minus: 10 }}px;
    }

    .description-title {
      font-size: {{ section.settings.description_title_size | minus: 4 }}px;
    }

    .description-subtitle {
      font-size: {{ section.settings.description_subtitle_size | minus: 2 }}px;
    }

    .description-text {
      font-size: {{ section.settings.description_text_size | minus: 2 }}px;
    }

    .career-item {
      grid-template-columns: {{ section.settings.career_year_width | minus: 20 }}px 1fr;
      gap: 12px;
      margin-bottom: 12px;
      padding-bottom: 12px;
    }

    .career-year {
      font-size: {{ section.settings.career_year_size | minus: 2 }}px;
      text-align: left;
    }

    .career-content {
      font-size: {{ section.settings.career_content_size | minus: 2 }}px;
    }

    .career-title {
      font-size: {{ section.settings.career_title_size | minus: 4 }}px;
    }

    .banner-grid {
      gap: {{ section.settings.banner_gap | divided_by: 2 }}px;
    }

    .banner-item {
      width: 100% !important;
      height: {{ section.settings.banner_height_mobile }}px !important;
    }

    .banner-content {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 16px;
    }

    .banner-text-left,
    .banner-text-right {
      writing-mode: horizontal-tb;
      text-align: center;
      max-width: 100%;
      align-self: center;
    }

    .banner-title {
      display: none;
    }

    .banner-subtitle {
      display: none;
    }

    .banner-title-mobile {
      display: block;
      font-size: {{ section.settings.banner_title_size | minus: 8 }}px;
      font-weight: {{ section.settings.banner_title_weight }};
      margin-bottom: 8px;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.7);
      line-height: 1.3;
      color: #ffffff;
    }

    .banner-subtitle-mobile {
      display: block;
      font-size: {{ section.settings.banner_subtitle_size | minus: 4 }}px;
      font-weight: {{ section.settings.banner_subtitle_weight }};
      opacity: 0.95;
      text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
      line-height: 1.4;
      color: #ffffff;
    }

    /* マルチカラム - モバイル1列対応 */
    .multi-column-grid {
      grid-template-columns: 1fr;
      gap: {{ section.settings.banner_gap | divided_by: 2 }}px;
    }

    .multi-column-item {
      height: 250px;
    }

    .multi-column-title {
      font-size: 20px;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* スクロールアニメーション */
  @media (prefers-reduced-motion: no-preference) {
    .artist-collection-wrapper {
      opacity: 0;
      animation: fadeInUp 0.8s ease-out forwards;
    }

    .artist-sidebar {
      transform: translateX(-20px);
      opacity: 0;
      animation: slideInLeft 0.6s ease-out 0.2s forwards;
    }

    .banner-item {
      transform: translateY(20px);
      opacity: 0;
      animation: slideInUp 0.6s ease-out forwards;
    }

    .banner-item:nth-child(1) { animation-delay: 0.4s; }
    .banner-item:nth-child(2) { animation-delay: 0.5s; }
    .banner-item:nth-child(3) { animation-delay: 0.6s; }
    .banner-item:nth-child(4) { animation-delay: 0.7s; }

    .multi-column-item {
      transform: translateY(20px);
      opacity: 0;
      animation: slideInUp 0.6s ease-out forwards;
    }

    .multi-column-item:nth-child(1) { animation-delay: 0.4s; }
    .multi-column-item:nth-child(2) { animation-delay: 0.5s; }
    .multi-column-item:nth-child(3) { animation-delay: 0.6s; }
    .multi-column-item:nth-child(4) { animation-delay: 0.7s; }
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slideInLeft {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="artist-collection-wrapper">
    
    <!-- 作家メニューサイドバー -->
    <aside class="artist-sidebar" role="complementary" aria-label="{{ section.settings.sidebar_title }}">
      {% if section.settings.sidebar_title != blank %}
        <h2 class="artist-sidebar__title">{{ section.settings.sidebar_title }}</h2>
      {% endif %}
      
      {% if section.settings.menu_handle != blank %}
        {% assign selected_menu = linklists[section.settings.menu_handle] %}
        {% if selected_menu.links.size > 0 %}
          <nav aria-label="作家メニュー">
            <ul class="artist-menu">
              {% for link in selected_menu.links %}
                <li class="artist-menu__item">
                  <a href="{{ link.url }}" 
                     class="artist-menu__link{% if link.active %} current{% endif %}"
                     {% if link.current %}aria-current="page"{% endif %}>
                    {{ link.title }}
                  </a>
                </li>
              {% endfor %}
            </ul>
          </nav>
        {% else %}
          <p>メニュー「{{ section.settings.menu_handle }}」にリンクが設定されていません。</p>
        {% endif %}
      {% else %}
        <p>メニューが選択されていません。セクション設定からメニューを選択してください。</p>
      {% endif %}
    </aside>

    <!-- メインコンテンツ -->
    <main class="main-content" role="main">
      
      <!-- 説明セクション（複数説明ブロック対応） -->
      {% assign description_blocks = section.blocks | where: 'type', 'description' %}
      {% if description_blocks.size > 0 %}
        {% for block in description_blocks %}
          <section class="description-section" {{ block.shopify_attributes }}>
            {% if block.settings.show_header %}
              <div class="description-header">
                {% if block.settings.description_title != blank %}
                  <h2 class="description-title">{{ block.settings.description_title }}</h2>
                {% endif %}
                {% if block.settings.description_subtitle != blank %}
                  <p class="description-subtitle">{{ block.settings.description_subtitle }}</p>
                {% endif %}
              </div>
            {% endif %}

            <div class="description-content">
              {% if block.settings.description_text != blank %}
                <div class="description-text">
                  {{ block.settings.description_text }}
                </div>
              {% endif %}

              {% if block.settings.show_career and block.settings.career_items != blank %}
                <div class="career-section">
                  {% if block.settings.career_section_title != blank %}
                    <h3 class="career-title">{{ block.settings.career_section_title }}</h3>
                  {% endif %}
                  
                  {% assign career_lines = block.settings.career_items | newline_to_br | split: '<br />' %}
                  {% if career_lines.size > 0 %}
                    <ul class="career-list">
                      {% for line in career_lines %}
                        {% assign trimmed_line = line | strip %}
                        {% if trimmed_line != blank %}
                          {% assign parts = trimmed_line | split: '|' %}
                          {% if parts.size >= 2 %}
                            <li class="career-item">
                              <div class="career-year">{{ parts[0] | strip }}</div>
                              <div class="career-content">{{ parts[1] | strip }}</div>
                            </li>
                          {% endif %}
                        {% endif %}
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </section>
        {% endfor %}
      {% endif %}


      <!-- バナーセクション（複数バナー対応） -->
      {% assign banner_blocks = section.blocks | where: 'type', 'banner' %}
      {% if banner_blocks.size > 0 %}
        <section class="banner-grid">
          {% for block in banner_blocks %}
            <div class="banner-item size-{{ block.settings.banner_size }}{% if block.settings.banner_url != blank %} clickable{% endif %}" 
                 {{ block.shopify_attributes }}
                 {% if block.settings.banner_url != blank %}
                   onclick="window.{% if block.settings.open_new_tab %}open('{{ block.settings.banner_url }}', '_blank'){% else %}location.href='{{ block.settings.banner_url }}'{% endif %}"
                 {% endif %}>
              
              {% if block.settings.banner_image != blank %}
                <img 
                  src="{{ block.settings.banner_image | image_url: width: 1200 }}"
                  srcset="{{ block.settings.banner_image | image_url: width: 600 }} 600w,
                          {{ block.settings.banner_image | image_url: width: 1200 }} 1200w,
                          {{ block.settings.banner_image | image_url: width: 1800 }} 1800w"
                  sizes="(max-width: 768px) 100vw, 
                         {% case block.settings.banner_size %}
                           {% when 'full' %}100vw
                           {% when 'large' %}80vw
                           {% when 'medium' %}60vw
                           {% when 'small' %}40vw
                         {% endcase %}"
                  alt="{{ block.settings.banner_image.alt | default: block.settings.banner_title }}"
                  class="banner-image"
                  loading="lazy"
                >
              {% endif %}
              
              {% if block.settings.show_overlay %}
                <div class="banner-overlay"></div>
              {% endif %}
              
              {% if block.settings.banner_title != blank or block.settings.banner_subtitle != blank or 
                     block.settings.banner_title_mobile != blank or block.settings.banner_subtitle_mobile != blank %}
                <div class="banner-content">
                  
                  <!-- 左上:縦書きタイトル -->
                  {% if block.settings.banner_title != blank %}
                    <div class="banner-text-left">
                      <h3 class="banner-title">{{ block.settings.banner_title }}</h3>
                    </div>
                  {% endif %}
                  
                  <!-- 右上:横書きサブタイトル -->
                  {% if block.settings.banner_subtitle != blank %}
                    <div class="banner-text-right">
                      <p class="banner-subtitle">{{ block.settings.banner_subtitle }}</p>
                    </div>
                  {% endif %}
                  
                  <!-- モバイル用テキスト -->
                  {% if block.settings.banner_title_mobile != blank %}
                    <h3 class="banner-title-mobile">{{ block.settings.banner_title_mobile }}</h3>
                  {% endif %}
                  {% if block.settings.banner_subtitle_mobile != blank %}
                    <p class="banner-subtitle-mobile">{{ block.settings.banner_subtitle_mobile }}</p>
                  {% endif %}
                  
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% endif %}

      <!-- マルチカラムセクション（新規追加） -->
      {% assign multi_column_blocks = section.blocks | where: 'type', 'multi_column' %}
      {% if multi_column_blocks.size > 0 %}
        <section class="multi-column-section">
          <div class="multi-column-grid">
            {% for block in multi_column_blocks %}
              {% if block.settings.column_link != blank %}
                <a href="{{ block.settings.column_link }}" 
                   class="multi-column-item"
                   {{ block.shopify_attributes }}
                   {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}>
              {% else %}
                <div class="multi-column-item" {{ block.shopify_attributes }}>
              {% endif %}
                
                {% if block.settings.column_image != blank %}
                  <img 
                    src="{{ block.settings.column_image | image_url: width: 800 }}"
                    srcset="{{ block.settings.column_image | image_url: width: 400 }} 400w,
                            {{ block.settings.column_image | image_url: width: 800 }} 800w"
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt="{{ block.settings.column_image.alt | default: block.settings.column_title }}"
                    class="multi-column-image"
                    loading="lazy"
                  >
                {% endif %}
                
                <div class="multi-column-overlay"></div>
                
                {% if block.settings.column_title != blank %}
                  <div class="multi-column-content">
                    <h3 class="multi-column-title">{{ block.settings.column_title }}</h3>
                  </div>
                {% endif %}
              
              {% if block.settings.column_link != blank %}
                </a>
              {% else %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </section>
      {% endif %}
      <!-- 商品グリッド -->
      {%- paginate collection.products by section.settings.products_per_page -%}
        
        {% comment %} フィルタリング・ソート機能 {% endcomment %}
        {%- if section.settings.enable_sorting and section.settings.filter_type == 'vertical' -%}
          <facet-filters-form class="facets facets-vertical-sort small-hide no-js-hidden">
            <form class="facets-vertical-form" id="FacetSortForm">
              <div class="facet-filters sorting caption">
                <div class="facet-filters__field">
                  <h2 class="facet-filters__label caption-large text-body">
                    <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                  </h2>
                  <div class="select">
                    {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
                    <select
                      name="sort_by"
                      class="facet-filters__sort select__select caption-large"
                      id="SortBy"
                      aria-describedby="a11y-refresh-page-message"
                    >
                      {%- for option in collection.sort_options -%}
                        <option
                          value="{{ option.value | escape }}"
                          {% if option.value == sort_by %}selected="selected"{% endif %}
                        >
                          {{ option.name | escape }}
                        </option>
                      {%- endfor -%}
                    </select>
                    {% render 'icon-caret' %}
                  </div>
                </div>
                <noscript>
                  <button type="submit" class="facets__button-no-js button button--secondary">
                    {{ 'products.facets.sort_button' | t }}
                  </button>
                </noscript>
              </div>
            </form>
          </facet-filters-form>
        {%- endif -%}

        <div class="{% if section.settings.filter_type == 'vertical' %} facets-vertical{% endif %}">
          {{ 'component-facets.css' | asset_url | stylesheet_tag }}
          <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
          
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}"
              id="main-collection-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: collection,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}

          <div
            class="product-grid-container{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            id="ProductGridContainer"
            {% if settings.animations_reveal_on_scroll %}data-cascade{% endif %}
          >
            {%- if collection.products.size == 0 -%}
              <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay gradient"></div>
                <div class="title-wrapper center">
                  <h2 class="title title--primary">
                    {{ 'sections.collection_template.empty' | t -}}
                    <br>
                    {{ 'sections.collection_template.use_fewer_filters_html' | t: link: collection.url, class: 'underlined-link link' }}
                  </h2>
                </div>
              </div>
            {%- else -%}
              <div class="collection">
                <div class="loading-overlay gradient"></div>

                <ul
                  id="product-grid"
                  data-id="{{ section.id }}"
                  class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                >
                  {%- for product in collection.products -%}
                    {% assign lazy_load = false %}
                    {%- if forloop.index > 2 -%}
                      {%- assign lazy_load = true -%}
                    {%- endif -%}
                    <li
                      class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                      {% if settings.animations_reveal_on_scroll %}
                        data-cascade
                        style="--animation-order: {{ forloop.index }};"
                      {% endif %}
                    >
                      {% render 'card-product',
                        card_product: product,
                        media_aspect_ratio: section.settings.image_ratio,
                        image_shape: section.settings.image_shape,
                        show_secondary_image: section.settings.show_secondary_image,
                        show_vendor: section.settings.show_vendor,
                        show_rating: section.settings.show_rating,
                        lazy_load: lazy_load,
                        show_quick_add: section.settings.enable_quick_add,
                        section_id: section.id
                      %}
                    </li>
                  {%- endfor -%}
                </ul>

                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate, anchor: '' %}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endpaginate -%}
    </main>
  </div>
  
  {% if section.settings.image_shape == 'arch' %}
    {% render 'mask-arch' %}
  {%- endif -%}
</div>

