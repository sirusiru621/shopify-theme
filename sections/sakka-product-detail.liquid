    },
    {
      "type": "range",
      "id": "thumbnail_size",
      "min": 40,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "サムネイルサイズ",
      "default": 60
    },
    {
      "type": "range",
      "id": "thumbnail_gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "サムネイル間のスペース",
      "default": 8
    },
    {
      "type": "color",
      "id": "thumbnail_border_active",
      "label": "アクティブサムネイル境界線色",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "商品情報表示設定"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "ブランド名を表示",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "SKUを表示",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_availability",
      "label": "在庫状況を表示",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_reviews",
      "label": "レビュー表示を有効化",
      "default": true,
      "info": "商品メタフィールドのレビューデータが必要"
    },
    {
      "type": "header",
      "content": "モバイル設定"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "モバイルレイアウト",
      "default": "stacked",
      "options": [
        { "value": "stacked", "label": "縦積み（標準）" },
        { "value": "sidebar_bottom", "label": "サイドバー下部" },
        { "value": "sidebar_hidden", "label": "サイドバー非表示" }
      ]
    },
    {
      "type": "checkbox",
      "id": "mobile_sticky_product_info",
