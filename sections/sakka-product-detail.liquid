    },
    {
      "type": "color",
      "id": "link_color",
      "label": "リンク色",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "リンクホバー色",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "商品タイトル色",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "アクセント色",
      "default": "#3b82f6",
      "info": "フォーカス状態やアクティブ要素に使用"
    },
    {
      "type": "header",
      "content": "フォント設定"
    },
    {
      "type": "range",
      "id": "link_font_size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "サイドバーリンクのフォントサイズ",
      "default": 14
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "商品タイトルのフォントサイズ",
      "default": 28
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "商品タイトルの太さ",
      "default": "600",
      "options": [
        { "value": "400", "label": "通常" },
        { "value": "500", "label": "中程度" },
        { "value": "600", "label": "セミボールド" },
        { "value": "700", "label": "ボールド" }
      ]
    },
    {
      "type": "header",
      "content": "レイアウト設定"
    },
    {
      "type": "range",
      "id": "sidebar_width",
      "min": 160,
      "max": 280,
