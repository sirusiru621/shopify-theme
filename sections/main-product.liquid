  <input type="hidden" name="properties[配送方法]" id="selectedMethod" value="" form="{{ product_form_id }}">
  <input type="hidden" name="properties[希望日時]" id="selectedDateTime" value="" form="{{ product_form_id }}">
  <input type="hidden" name="properties[配送選択]" id="selectedSlotId" value="" form="{{ product_form_id }}">

  <script>
  (() => {
    'use strict';
    
    const config = window.inventoryLinkedConfig || {};
    const { displaySettings, storeSettings, designSettings, messages } = config;
    
    let appState = {
      selectedMethod: null,
      selectedDate: null,
      closeDebugLogs: []
    };

    const elements = {
      methodBtns: document.querySelectorAll('.method-btn'),
      dateSelectionArea: document.querySelector('.date-selection-area'),
      dateOptions: document.getElementById('dateOptions'),
      selectionInfo: document.getElementById('selectionInfo'),
      closeDebugPanel: document.getElementById('closeDebugPanel'),
      closeDebugContent: document.getElementById('closeDebugContent'),
      currentTimeSpan: document.getElementById('currentTime')
    };

    // デバッグログ追加関数
    function addDebugLog(message, data = null) {
      const timestamp = new Date().toLocaleTimeString('ja-JP');
      appState.closeDebugLogs.push({ time: timestamp, message, data });
      console.log(`[CLOSE制御 ${timestamp}] ${message}`, data || '');
    }

    // デバッグパネル表示
    function showDebugPanel() {
      if (!elements.closeDebugPanel || !elements.closeDebugContent) return;
      
      let html = '<div style="font-family: monospace;">';
      appState.closeDebugLogs.forEach(log => {
        html += `<div style="margin-bottom: 8px; padding: 8px; background: rgba(255,255,255,0.5); border-left: 3px solid #856404;">`;
        html += `<strong>[${log.time}]</strong> ${log.message}`;
        if (log.data) {
          html += `<br><span style="color: #666; font-size: 11px;">${JSON.stringify(log.data, null, 2)}</span>`;
        }
        html += `</div>`;
      });
      html += '</div>';
      
      elements.closeDebugContent.innerHTML = html;
      elements.closeDebugPanel.style.display = 'block';
    }

    const utils = {
      formatDateKey: function(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
      },

      formatDateDisplay: function(date) {
        return date.toLocaleDateString('ja-JP', { month: 'long', day: 'numeric', weekday: 'short' });
      },

      formatPickupTime: function(timeStr) {
        const match = /^(\d{1,2}):\d{2}-(\d{1,2}):\d{2}$/.exec(timeStr || '');
        return match ? `受け取り時間：${Number(match[1])}時〜${Number(match[2])}時` : `受け取り時間：${timeStr}`;
      },

      isClosedForDate: function(targetDate, method) {
        const now = new Date();
        const methodSettings = storeSettings[method] || {};
        
        const salesCloseTime = String(methodSettings.salesCloseTime || "23:59");
        const salesCloseDay = parseInt(methodSettings.salesCloseDay, 10);
        const closeBeforeDays = parseInt(methodSettings.closeBeforeDays, 10) || 0;
        
        addDebugLog(`CLOSE判定開始: ${method}`, {
          targetDate: this.formatDateKey(targetDate),
          now: now.toLocaleString('ja-JP'),
          salesCloseDay: salesCloseDay,
          salesCloseTime: salesCloseTime,
          closeBeforeDays: closeBeforeDays
        });

        if (isNaN(salesCloseDay) || salesCloseDay < 0 || salesCloseDay > 6) {
          addDebugLog('❌ 無効な曜日設定', { salesCloseDay });
          return false;
        }

        const baseDate = new Date(targetDate);
        baseDate.setDate(targetDate.getDate() - closeBeforeDays);
        
        addDebugLog('基準日計算完了', {
          targetDate: this.formatDateKey(targetDate),
          closeBeforeDays: closeBeforeDays,
          baseDate: this.formatDateKey(baseDate)
        });

        const closeDateTime = this.getCloseDateTimeForWeek(baseDate, salesCloseDay, salesCloseTime);
        
        addDebugLog('CLOSE日時計算完了', {
          closeDateTime: closeDateTime.toLocaleString('ja-JP'),
          now: now.toLocaleString('ja-JP'),
          isClosed: now >= closeDateTime
        });

        const isClosed = now >= closeDateTime;
        
        if (isClosed) {
          addDebugLog(`✅ CLOSE判定: 受付終了`, {
            reason: `現在時刻(${now.toLocaleString('ja-JP')})が終了時刻(${closeDateTime.toLocaleString('ja-JP')})を超過`
          });
        } else {
          const diffMs = closeDateTime - now;
          const hours = Math.floor(diffMs / (1000 * 60 * 60));
          const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
          addDebugLog(`⏰ CLOSE判定: まだ受付中`, {
            remainingTime: `あと${hours}時間${minutes}分`
          });
        }
        
        return isClosed;
      },

      getCloseDateTimeForWeek: function(referenceDate, targetDayOfWeek, timeStr) {
        const refDate = new Date(referenceDate);
        refDate.setHours(0, 0, 0, 0);
        
        const currentDay = refDate.getDay();
        let daysToAdd = targetDayOfWeek - currentDay;
        
        if (daysToAdd < 0) {
          daysToAdd += 7;
        }
        
        const targetDate = new Date(refDate);
        targetDate.setDate(refDate.getDate() + daysToAdd);
        
        const [hour, minute] = timeStr.split(':').map(Number);
        targetDate.setHours(hour || 0, minute || 0, 0, 0);
        
        addDebugLog('曜日計算完了', {
          referenceDate: this.formatDateKey(refDate),
          currentDay: ['日','月','火','水','木','金','土'][currentDay],
          targetDay: ['日','月','火','水','木','金','土'][targetDayOfWeek],
          daysToAdd: daysToAdd,
          resultDate: targetDate.toLocaleString('ja-JP')
        });
        
        return targetDate;
      },

      getTimeUntilClose: function(targetDate, method) {
        const now = new Date();
        const methodSettings = storeSettings[method] || {};
        
        const salesCloseTime = String(methodSettings.salesCloseTime || "23:59");
        const salesCloseDay = parseInt(methodSettings.salesCloseDay, 10);
        const closeBeforeDays = parseInt(methodSettings.closeBeforeDays, 10) || 0;
        
        const baseDate = new Date(targetDate);
        baseDate.setDate(targetDate.getDate() - closeBeforeDays);
        
        const closeDateTime = this.getCloseDateTimeForWeek(baseDate, salesCloseDay, salesCloseTime);
        
        const diffMs = closeDateTime - now;
        
        if (diffMs <= 0) {
          return { hours: 0, minutes: 0, isPastClose: true };
        }
        
        const hours = Math.floor(diffMs / (1000 * 60 * 60));
        const minutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
        
        return { hours, minutes, isPastClose: false };
      }
    };

    class DateManager {
      isValidPickupDate(date, today = new Date()) {
        const methodSettings = storeSettings.pickup || {};
        const allowedDays = methodSettings.allowedDays || [6, 0]; // デフォルト土日
        
        const baseToday = new Date(today);
        baseToday.setHours(0, 0, 0, 0);
        
        const nextWeekStart = new Date(baseToday);
        const daysUntilNextMonday = (8 - baseToday.getDay()) % 7 || 7;
        nextWeekStart.setDate(baseToday.getDate() + daysUntilNextMonday);
        
        const checkDate = new Date(date);
        checkDate.setHours(0, 0, 0, 0);
        
        // 翌週以降かつ、allowedDaysに含まれる曜日
        if (checkDate < nextWeekStart) return false;
        
        const dayOfWeek = checkDate.getDay();
        return allowedDays.includes(dayOfWeek);
      }

      isValidDeliveryDate(date, today = new Date()) {
        const methodSettings = storeSettings.delivery || {};
        const allowedDays = methodSettings.allowedDays || [3]; // デフォルト水曜
        
        const baseToday = new Date(today);
        baseToday.setHours(0, 0, 0, 0);
        
        const twoWeeksLater = new Date(baseToday);
        twoWeeksLater.setDate(baseToday.getDate() + 14);
        
        const checkDate = new Date(date);
        checkDate.setHours(0, 0, 0, 0);
        
        // 2週間後以降かつ、allowedDaysに含まれる曜日
        if (checkDate < twoWeeksLater) return false;
        
        const dayOfWeek = checkDate.getDay();
        return allowedDays.includes(dayOfWeek);
      }

      isSalesAvailable(dateInfo, method) {
        if (dateInfo.inventory.available <= 0) {
          return {
            available: false,
            reason: 'out_of_stock',
            message: messages.outOfStock || '在庫切れ',
            badgeColor: '#6c757d'
          };
        }
        
        if (utils.isClosedForDate(dateInfo.date, method)) {
          return {
            available: false,
            reason: 'closed',
            message: '受付終了',
            badgeColor: '#dc3545'
          };
        }
        
        return {
          available: true,
          reason: 'available',
          message: null
        };
      }

      generateDateOptions() {
        if (!appState.selectedMethod) return [];

        appState.closeDebugLogs = [];
        addDebugLog(`日時オプション生成開始: ${appState.selectedMethod}`);

        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const dates = [];
        
        const searchDays = 90; // 最大90日分検索

        for (let day = 0; day < searchDays; day++) {
          const date = new Date(today);
          date.setDate(today.getDate() + day);

          let isValid = false;
          if (appState.selectedMethod === 'pickup') {
            isValid = this.isValidPickupDate(date);
          } else if (appState.selectedMethod === 'delivery') {
            isValid = this.isValidDeliveryDate(date);
          }

          if (isValid) {
            const methodSettings = storeSettings[appState.selectedMethod] || {};
            const timeSlot = methodSettings.time || "10:00-16:00";

            dates.push({
              date: date,
              type: appState.selectedMethod,
              time: timeSlot,
              inventory: { allocated: 10, reserved: 0, available: 5 },
              id: `${appState.selectedMethod}_${utils.formatDateKey(date)}`,
              dateKey: utils.formatDateKey(date),
              salesStarted: true
            });
          }
        }

        addDebugLog(`生成完了: ${dates.length}件のオプション`);
        
        const methodSettings = storeSettings[appState.selectedMethod] || {};
        const maxOptions = methodSettings.maxOptions || 0;
        
        // maxOptions=0の場合は全件返す（後続処理で非表示にする）
        if (maxOptions === 0) {
          return dates;
        }
        
        return dates.slice(0, maxOptions);
      }

      updateDateOptions() {
        const dates = this.generateDateOptions();
        if (!elements.dateOptions) return;
        
        elements.dateOptions.innerHTML = '';
        
        const methodSettings = storeSettings[appState.selectedMethod] || {};
        const maxOptions = methodSettings.maxOptions || 0;
        
        // 🆕 maxOptions=0の場合は日程選択エリア全体を非表示
        if (maxOptions === 0) {
          if (elements.dateSelectionArea) {
            elements.dateSelectionArea.style.display = 'none';
          }
          
          // 自動的に配送方法のみ選択済み状態にする
          const methodLabel = appState.selectedMethod === 'pickup' ? '店舗受け取り' : 'オンライン配送';
          
          const methodField = document.getElementById('selectedMethod');
          const dateTimeField = document.getElementById('selectedDateTime');
          const slotIdField = document.getElementById('selectedSlotId');
          
          if (methodField) methodField.value = methodLabel;
          if (dateTimeField) dateTimeField.value = '日時指定なし';
          if (slotIdField) slotIdField.value = `${appState.selectedMethod}_no_date`;
          
          // 選択完了情報を表示
          if (elements.selectionInfo) {
            elements.selectionInfo.innerHTML = `
              <div style="display: flex; align-items: flex-start; gap: 18px;">
                <div style="flex: 1;">
                  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
                    <span style="font-weight: 700; color: #333; font-size: 20px;">選択完了</span>
                    <span style="background:#017C89; color: white; padding: 6px 15px; border-radius: 0px; font-size: 13px; font-weight: 600;">✓ 確定</span>
                  </div>
                  <div style="color: #495057; font-size: 16px; margin-bottom: 6px; font-weight: 500;">${methodLabel}</div>
                  <div style="color: #6c757d; font-size: 15px;">日時指定は不要です</div>
                </div>
              </div>
            `;
            elements.selectionInfo.style.display = 'block';
          }
          
          addDebugLog(`maxOptions=0: 日程選択を非表示`, {
            method: appState.selectedMethod,
            autoSelected: true
          });
          
          return;
        }

        // 通常の日程選択表示
        if (elements.dateSelectionArea) {
          elements.dateSelectionArea.style.display = 'block';
        }

        if (dates.length === 0) {
          this.renderEmptyState();
          return;
        }

        let visibleDates = dates;
        
        if (!displaySettings.showClosedOptions) {
          const beforeFilter = visibleDates.length;
          visibleDates = dates.filter(dateInfo => {
            const salesStatus = this.isSalesAvailable(dateInfo, appState.selectedMethod);
            return salesStatus.reason !== 'closed';
          });
          addDebugLog(`CLOSE済みフィルタ適用`, {
            before: beforeFilter,
            after: visibleDates.length,
            filtered: beforeFilter - visibleDates.length
          });
        }

        if (visibleDates.length === 0) {
          this.renderEmptyState(true);
          showDebugPanel();
          return;
        }

        visibleDates.forEach(dateInfo => {
          this.renderDateOption(dateInfo);
        });

        if (displaySettings.showDebugInfo) {
          showDebugPanel();
        }
      }

      renderEmptyState(allClosed = false) {
        let emptyMessage = '予約可能な日程がありません';
        let emptyDetail = '';
        let iconEmoji = '📅';
        
        if (allClosed) {
          emptyMessage = '受付を終了しました';
          iconEmoji = '🚫';
          
          if (appState.selectedMethod === 'pickup') {
            const methodSettings = storeSettings.pickup || {};
            const closeTime = methodSettings.salesCloseTime || '12:00';
            const closeDayName = ['日', '月', '火', '水', '木', '金', '土'][parseInt(methodSettings.salesCloseDay)] || '金';
            emptyDetail = `店舗受け取りの受付は${closeDayName}曜日${closeTime}に終了します。次回の受付をお待ちください。`;
          } else if (appState.selectedMethod === 'delivery') {
            const methodSettings = storeSettings.delivery || {};
            const closeTime = methodSettings.salesCloseTime || '12:00';
            const closeDayName = ['日', '月', '火', '水', '木', '金', '土'][parseInt(methodSettings.salesCloseDay)] || '水';
            emptyDetail = `オンライン配送の受付は${closeDayName}曜日${closeTime}に終了します。次回の受付をお待ちください。`;
          }
        } else {
          emptyDetail = appState.selectedMethod === 'pickup' 
            ? '店舗受け取り（翌週の指定曜日のみ）の在庫が不足しているか、設定された営業日程がありません'
            : 'オンライン配送（2週間以降の指定曜日）の在庫が不足しているか、設定された配送日程がありません';
        }
        
        elements.dateOptions.innerHTML = `
          <div style="grid-column: 1 / -1; text-align: center; padding: 50px; color: #6c757d; border: 2px dashed #dee2e6; border-radius: 0px; background: #f8f9fa;">
            <div style="font-size: 48px; margin-bottom: 20px; opacity: 0.5;">${iconEmoji}</div>
            <p style="margin: 0 0 10px 0; font-weight: 700; font-size: 20px; color: #495057;">${emptyMessage}</p>
            <p style="margin: 0; font-size: 15px; line-height: 1.5;">${emptyDetail}</p>
          </div>
        `;
      }

      renderDateOption(dateInfo) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'date-option';
        btn.dataset.slotId = dateInfo.id;

        const salesStatus = this.isSalesAvailable(dateInfo, appState.selectedMethod);
        const isSelectable = salesStatus.available;
        
        const dateStr = utils.formatDateDisplay(dateInfo.date);
        const timeDisplay = dateInfo.type === 'pickup' ? 
          utils.formatPickupTime(dateInfo.time) : dateInfo.time;

        btn.style.cssText = `
          padding: 24px; border: 2px solid #e1e5e9;
          border-radius: 0px; text-align: left; transition: all 0.3s ease;
          position: relative; min-height: 180px; display: flex; flex-direction: column;
          justify-content: space-between; box-shadow: 0 3px 10px rgba(0,0,0,0.08); overflow: hidden;
          ${isSelectable ? 'background: #B3B6BC; cursor: pointer;' : 'background: #f8f9fa; cursor: not-allowed; opacity: 0.7;'}
        `;

        if (isSelectable) {
          const timeUntilClose = utils.getTimeUntilClose(dateInfo.date, appState.selectedMethod);
          let countdownHtml = '';
          
          if (displaySettings.showCloseCountdown && !timeUntilClose.isPastClose && timeUntilClose.hours < 24) {
            countdownHtml = `
              <div style="position: absolute; top: 10px; right: 10px; background: #ffc107; color: #000; padding: 4px 8px; border-radius: 0px; font-size: 11px; font-weight: 600;">
                受付終了まで ${timeUntilClose.hours}時間${timeUntilClose.minutes}分
              </div>
            `;
          }

          const pickupHtml = `
            ${countdownHtml}
            <div style="margin-bottom: 18px;">
              <div style="font-weight: 500; font-size: 16px; color: #FFFFFF; margin-bottom: 10px;">${dateStr}</div>
              <div style="font-size: 13px; color:#c7c9d1; margin-bottom: 12px; line-height: 1.4; font-weight: 400;">
                ${timeDisplay}<br><span style="font-size: 12px;"></span>
              </div>
            </div>
            <div style="border-top: 1px solid rgba(255,255,255,0.2); padding-top: 15px;">
              <div style="text-align: center; color: #FFFFFF; font-weight: 600; font-size: 15px;">この日時を選ぶ</div>
            </div>
          `;

          const deliveryHtml = `
            ${countdownHtml}
            <div style="margin-bottom: 18px;">
              <div style="font-weight: 500; font-size: 16px; color: #FFFFFF; margin-bottom: 10px;">${dateStr} 配送</div>
              <div style="font-size: 13px; color:#c7c9d1; margin-bottom: 12px; line-height: 1.4; font-weight: 400;">
                ${timeDisplay}<br><span style="font-size: 12px;"></span>
              </div>
            </div>
            <div style="border-top: 1px solid rgba(255,255,255,0.2); padding-top: 15px;">
              <div style="text-align: center; color: #FFFFFF; font-weight: 600; font-size: 15px;">この配送日時を選ぶ</div>
            </div>
          `;

          btn.innerHTML = appState.selectedMethod === 'pickup' ? pickupHtml : deliveryHtml;

          btn.addEventListener('click', () => this.selectDate(dateInfo, btn));
        } else {
          btn.innerHTML = `
            <div style="margin-bottom: 18px;">
              <div style="font-weight: 500; font-size: 16px; color: #999; margin-bottom: 10px;">${dateStr}</div>
              <div style="font-size: 13px; color: #999; margin-bottom: 12px; font-weight: 400;">${timeDisplay}</div>
              <div style="font-size: 12px; color: ${salesStatus.badgeColor}; background: ${salesStatus.badgeColor}20; padding: 6px 12px; border-radius: 0px; display: inline-block; font-weight: 600;">${salesStatus.message}</div>
            </div>
            <div style="border-top: 1px solid #f0f0f0; padding-top: 15px;">
              <div style="text-align: center; color: #6c757d; font-weight: 600; font-size: 14px;">選択不可</div>
            </div>
          `;
        }

        elements.dateOptions.appendChild(btn);
      }

      selectDate(dateInfo, btn) {
        const salesStatus = this.isSalesAvailable(dateInfo, appState.selectedMethod);
        if (!salesStatus.available) {
          console.warn('この日時は選択できません:', salesStatus.message);
          return;
        }

        document.querySelectorAll('.date-option').forEach(b => {
          b.style.borderColor = '#e1e5e9';
          b.style.backgroundColor = '#B3B6BC';
          b.style.transform = 'translateY(0)';
          b.style.boxShadow = '0 3px 10px rgba(0,0,0,0.08)';
          b.classList.remove('selected');
        });

        btn.style.borderColor = '#007c89';
        btn.style.backgroundColor = '#007c89';
        btn.style.transform = 'translateY(-4px)';
        btn.style.boxShadow = '0 15px 30px rgba(0, 124, 137, 0.25)';
        btn.classList.add('selected');

        appState.selectedDate = dateInfo;

        const methodField = document.getElementById('selectedMethod');
        const dateTimeField = document.getElementById('selectedDateTime');
        const slotIdField = document.getElementById('selectedSlotId');
        
        if (methodField) methodField.value = appState.selectedMethod === 'pickup' ? '店舗受け取り' : 'オンライン配送';
        if (dateTimeField) {
          const cleanTime = dateInfo.time.replace(/^受け取り時間：/, '').trim();
          dateTimeField.value = `${dateInfo.date.toLocaleDateString('ja-JP')} ${cleanTime}`;
        }
        if (slotIdField) slotIdField.value = dateInfo.id;

        this.showSelectionInfo(dateInfo);
      }

      showSelectionInfo(dateInfo) {
        if (!elements.selectionInfo) return;
        
        const methodLabel = appState.selectedMethod === 'pickup' ? '店舗受け取り' : 'オンライン配送';
        const timeDisplay = dateInfo.type === 'pickup' ? utils.formatPickupTime(dateInfo.time) : dateInfo.time;

        elements.selectionInfo.innerHTML = `
          <div style="display: flex; align-items: flex-start; gap: 18px;">
            <div style="flex: 1;">
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
                <span style="font-weight: 700; color: #333; font-size: 20px;">選択完了</span>
                <span style="background:#017C89; color: white; padding: 6px 15px; border-radius: 0px; font-size: 13px; font-weight: 600;">✓ 確定</span>
              </div>
              <div style="color: #495057; font-size: 16px; margin-bottom: 6px; font-weight: 500;">${methodLabel} - ${dateInfo.date.toLocaleDateString('ja-JP')}</div>
              <div style="color: #6c757d; font-size: 15px; margin-bottom: 6px;">時間: ${timeDisplay}</div>
            </div>
          </div>
        `;

        elements.selectionInfo.style.display = 'block';
      }
    }

    // 現在時刻の更新
    function updateCurrentTime() {
      if (elements.currentTimeSpan) {
        elements.currentTimeSpan.textContent = new Date().toLocaleString('ja-JP');
      }
    }

    // 初期化
    function init() {
      if (!config || typeof config.productInventory === 'undefined') {
        console.warn('設定が見つかりません');
        return;
      }

      addDebugLog('初期化開始', {
        config: {
          pickup: storeSettings.pickup,
          delivery: storeSettings.delivery
        }
      });

      try {
        const dateManager = new DateManager();

        updateCurrentTime();
        setInterval(updateCurrentTime, 1000);

        elements.methodBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            addDebugLog(`配送方法選択: ${btn.dataset.method}`);
            
            elements.methodBtns.forEach(b => {
              b.style.borderColor = '#e1e5e9';
              b.style.backgroundColor = '#627793';
              b.style.transform = 'translateY(0)';
            });

            btn.style.borderColor = '#007c89';
            btn.style.backgroundColor = '#007c89';
            btn.style.transform = 'translateY(-3px)';

            appState.selectedMethod = btn.dataset.method;
            appState.selectedDate = null;
            
            if (elements.selectionInfo) elements.selectionInfo.style.display = 'none';
            
            document.dispatchEvent(new CustomEvent('deliveryMethodChange', {
              detail: { method: btn.dataset.method }
            }));
            
            dateManager.updateDateOptions();
          });
        });

      } catch (error) {
        console.error('初期化エラー:', error);
        addDebugLog('初期化エラー', { error: error.message });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
  </script>

  <style>
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
  @keyframes slideInUp {
    from { transform: translateY(30px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  @keyframes glow {
    0%,100% { box-shadow: 0 0 5px rgba(0, 124, 137, 0.5); }
    50% { box-shadow: 0 0 20px rgba(0, 124, 137, 0.8); }
  }

  .date-option { 
    animation: slideInUp 0.4s ease forwards; 
    border-radius: 0px !important; 
  }
  .selection-info { 
    animation: slideInUp 0.5s ease forwards; 
    border-radius: 0px !important; 
  }
  .method-btn { 
    border-radius: 0px !important; 
  }
  .method-btn.selected, .method-btn:hover { 
    animation: glow 1.5s ease-in-out infinite; 
  }

  .date-option:not([disabled]):hover {
    box-shadow: 0 10px 25px rgba(0, 124, 137, 0.15) !important;
    transform: translateY(-4px) !important;
  }

  .method-btn:hover {
    box-shadow: 0 10px 25px rgba(0, 124, 137, 0.15) !important;
    transform: translateY(-3px) !important;
  }

  .date-option.selected {
    border-color: #007c89 !important;
    background-color: #007c89 !important;
    transform: translateY(-4px) !important;
    box-shadow: 0 15px 30px rgba(0, 124, 137, 0.25) !important;
  }

  @media (max-width: 768px) {
    .method-buttons { flex-direction: column !important; }
    .method-btn { margin-bottom: 15px !important; padding: 18px 20px !important; }
    .date-options { grid-template-columns: 1fr !important; gap: 15px !important; }
    .date-option { min-height: 160px !important; padding: 20px !important; }
  }

  .method-btn:focus, .date-option:focus {
    outline: 3px solid #007c89;
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .date-option, .selection-info, .method-btn {
      animation: none !important;
      transition: none !important;
    }
  }
  </style>
</div>


{%- when 'delivery-schedule-picker' -%}
{%- if block.settings.enable_schedule_picker -%}
<div id="DeliverySchedulePicker-{{ block.id }}" 
     class="delivery-schedule-picker" 
     data-delivery-schedule
     data-block-id="{{ block.id }}"
     style="display:none;"
     {{ block.shopify_attributes }}>

  {%- if block.settings.show_heading -%}
  <h3 class="delivery-schedule-heading">
    {{ block.settings.schedule_label | default: 'お届け希望日' }}
  </h3>
  {%- endif -%}

  <!-- 日付選択エリア（カード型） -->
  <div class="date-selection-area" id="dateOptions-{{ block.id }}">
    <!-- JSで動的生成 -->
  </div>
  
  {%- if block.settings.show_cutoff_notice -%}
  <div class="delivery-cutoff-notice">
    {{ block.settings.cutoff_notice_text | default: '15時以降のご注文は翌営業日扱いとなります。' }}
  </div>
  {%- endif -%}
<br>
  <!-- 時間帯選択 -->
  <div class="delivery-schedule-field">
    <label for="delivery-time-{{ block.id }}">お届け希望時間帯</label>
    <select 
      id="delivery-time-{{ block.id }}"
      class="delivery-time-select"
      name="properties[お届け希望時間帯]"
      data-schedule-select="time"
      form="{{ product_form_id }}">
      <option value="指定なし">指定なし</option>
      <option value="午前中">午前中（8時〜12時）</option>
      <option value="14-16">14時〜16時</option>
      <option value="16-18">16時〜18時</option>
      <option value="18-20">18時〜20時</option>
      <option value="19-21">19時〜21時</option>
    </select>
  </div>

  <!-- 選択内容確認パネル -->
  <div class="selection-info" id="selectionInfo-{{ block.id }}" style="display:none;">
    <p class="selection-info-text">
      <strong>選択内容：</strong>
      <span id="selectedDisplay-{{ block.id }}"></span>
    </p>
  </div>

  <!-- カート送信用隠しフィールド -->
  <input type="hidden" 
         name="properties[{{ block.settings.delivery_date_property | default: '配送希望日' }}]" 
         id="deliveryDateHidden-{{ block.id }}"
         form="{{ product_form_id }}">
  <input type="hidden" 
         name="properties[配送スロットID]" 
         id="deliverySlotHidden-{{ block.id }}"
         form="{{ product_form_id }}">
</div>

<style>
.delivery-schedule-picker {
  background: {{ block.settings.bg_color | default: '#ffffff' }};
  border: 2px solid {{ block.settings.border_color | default: '#e0e6ed' }};
  border-radius: 0;
  padding: 24px;
  margin-top: 20px;
  margin-bottom: {{ block.settings.padding_bottom | default: 16 }}px;
  color: {{ block.settings.text_color | default: '#333333' }};
  transition: opacity 0.3s ease;
}

.delivery-schedule-heading {
  font-size: 1.1rem;
  font-weight: 600;
  color: {{ block.settings.primary_color | default: '#007bff' }};
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 2px solid {{ block.settings.border_color | default: '#e0e6ed' }};
}

/* 日付選択エリア */
.delivery-schedule-picker .date-selection-area {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}

@media (max-width: 640px) {
  .delivery-schedule-picker .date-selection-area {
    grid-template-columns: 1fr;
  }
}

/* 日付カード */
.delivery-schedule-picker .date-card {
  background: #fff;
  border: 2px solid {{ block.settings.border_color | default: '#e0e6ed' }};
  border-radius: 0;
  padding: 16px 12px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  animation: slideInUp 0.4s ease forwards;
  opacity: 0;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.delivery-schedule-picker .date-card:hover:not(.disabled) {
  transform: translateY(-4px);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
  border-color: {{ block.settings.primary_color | default: '#007bff' }};
}

.delivery-schedule-picker .date-card.selected {
  background: #B3B6BC!important;
  box-shadow: 0 6px 20px rgba(0, 123, 255, 0.4);
  animation: glow 0.6s ease;
  transform: translateY(-6px) scale(1.02);
  opacity: 1;
}

.delivery-schedule-picker .date-card.selected .date-card-date,
.delivery-schedule-picker .date-card.selected .date-card-day,
.delivery-schedule-picker .date-card.selected .date-card-status {
  color: #fff !important;
}

/* 選択済みマークの強調 */
.delivery-schedule-picker .date-card.selected .date-card-status {
  font-weight: 700;
  font-size: 0.8rem;
}

@keyframes glow {
  0%, 100% { box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3); }
  50% { box-shadow: 0 6px 20px rgba(0, 123, 255, 0.5); }
}

.delivery-schedule-picker .date-card.disabled {
  background: #f5f5f5;
  color: #999;
  cursor: not-allowed;
  opacity: 0.6;
}

