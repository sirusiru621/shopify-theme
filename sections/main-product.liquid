</style>

<script>
(function() {
  'use strict';

  const blockId = '{{ block.id }}';
  const container = document.getElementById(`DeliverySchedulePicker-${blockId}`);
  
  if (!container) {
    console.warn('DeliverySchedulePicker container not found:', blockId);
    return;
  }

  // 🇯🇵 祝日データ（2025〜2027年）
  const holidays = {
  };

  // 📋 ブロック設定値を取得
  const config = {
    allowedWeekdays: [
      {% if block.settings.weekday_sunday %}0,{% endif %}
      {% if block.settings.weekday_monday %}1,{% endif %}
      {% if block.settings.weekday_tuesday %}2,{% endif %}
      {% if block.settings.weekday_wednesday %}3,{% endif %}
      {% if block.settings.weekday_thursday %}4,{% endif %}
      {% if block.settings.weekday_friday %}5,{% endif %}
      {% if block.settings.weekday_saturday %}6{% endif %}
    ].filter(n => n !== undefined),
    advanceDays: {{ block.settings.advance_days | default: 3 }},
    maxDays: {{ block.settings.max_days | default: 14 }},
    cutoffTime: '{{ block.settings.cutoff_time | default: "15:00" }}'
  };

  // 📅 日付計算ロジック
  class DateManager {
    constructor(config, holidays) {
      this.config = config;
      this.holidays = holidays;
      this.selectedDate = null;
      this.selectedTime = null;
    }

    isHoliday(date) {
      const key = this.formatDateKey(date);
      return !!this.holidays[key];
    }

    isAllowedWeekday(date) {
      if (this.config.allowedWeekdays.length === 0) return true;
      return this.config.allowedWeekdays.includes(date.getDay());
    }

    isCutoffPassed() {
      const now = new Date();
      const [hour, minute] = this.config.cutoffTime.split(':').map(Number);
      const cutoff = new Date(now);
      cutoff.setHours(hour, minute, 0, 0);
      return now >= cutoff;
    }

    getStartDate() {
      const today = new Date();
      let start = new Date(today);
      let daysToAdd = this.config.advanceDays;
      
      if (this.isCutoffPassed()) daysToAdd += 1;
      start.setDate(today.getDate() + daysToAdd);
      
      while (!this.isValidDeliveryDate(start)) {
        start.setDate(start.getDate() + 1);
      }
      return start;
    }

    isValidDeliveryDate(date) {
      return this.isAllowedWeekday(date) && !this.isHoliday(date);
    }

    generateDateOptions() {
      const options = [];
      const start = this.getStartDate();
      let current = new Date(start);
      let checked = 0;

      while (options.length < this.config.maxDays && checked < 60) {
        if (this.isValidDeliveryDate(current)) {
          options.push({
            date: new Date(current),
            formatted: this.formatDate(current),
            display: this.formatDisplayDate(current),
            slotId: `delivery_${this.formatDateKey(current)}`
          });
        }
        current.setDate(current.getDate() + 1);
        checked++;
      }
      return options;
    }

    formatDate(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}/${m}/${d}`;
    }

    formatDateKey(date) {
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    formatDisplayDate(date) {
      const weekdays = ['日','月','火','水','木','金','土'];
      return `${date.getMonth()+1}月${date.getDate()}日（${weekdays[date.getDay()]}）`;
    }
  }

  const dateManager = new DateManager(config, holidays);
  const dateOptionsContainer = container.querySelector(`#dateOptions-${blockId}`);
  const timeSelect = container.querySelector(`#delivery-time-${blockId}`);
  const selectionInfo = container.querySelector(`#selectionInfo-${blockId}`);
  const selectedDisplay = container.querySelector(`#selectedDisplay-${blockId}`);
  const hiddenDateField = container.querySelector(`#deliveryDateHidden-${blockId}`);
  const hiddenSlotField = container.querySelector(`#deliverySlotHidden-${blockId}`);

  // 🧩 日付カード描画
  function renderDateOptions() {
    if (!dateOptionsContainer) return;
    const options = dateManager.generateDateOptions();
    dateOptionsContainer.innerHTML = '';

    if (options.length === 0) {
      dateOptionsContainer.innerHTML = `
        <div style="grid-column:1/-1;text-align:center;padding:40px;color:#6c757d;border:2px dashed #dee2e6;background:#f8f9fa;">
          <p style="margin:0;font-size:14px;">配送可能な日程がありません</p>
        </div>`;
      return;
    }

    options.forEach((opt, i) => {
      const card = document.createElement('div');
      card.className = 'date-card';
      card.dataset.date = opt.formatted;
      card.dataset.slotId = opt.slotId;
      card.style.animationDelay = `${i * 0.05}s`;
      card.innerHTML = `
        <div class="date-card-date">${opt.display}</div>
        <div class="date-card-status">選択可能</div>`;
      card.addEventListener('click', () => selectDate(opt, card));
      dateOptionsContainer.appendChild(card);
    });
  }

  // 📦 日付選択
  function selectDate(opt, card) {
    if (dateOptionsContainer) {
      dateOptionsContainer.querySelectorAll('.date-card').forEach(c => {
        c.classList.remove('selected');
        const s = c.querySelector('.date-card-status');
        if (s) s.textContent = '選択可能';
      });
    }
    card.classList.add('selected');
    const s = card.querySelector('.date-card-status');
    if (s) s.textContent = '✓ 選択済み';
    dateManager.selectedDate = opt;
    updateSelection();
  }

  // 🕒 時間帯変更
  if (timeSelect) {
    timeSelect.addEventListener('change', e => {
      dateManager.selectedTime = e.target.value;
      updateSelection();
    });
  }

  // 💾 選択内容更新
  function updateSelection() {
    if (dateManager.selectedDate && dateManager.selectedTime) {
      const timeLabel = timeSelect.options[timeSelect.selectedIndex].text;
      const display = `${dateManager.selectedDate.formatted} ${timeLabel}`;
      if (selectedDisplay) selectedDisplay.textContent = display;
      if (selectionInfo) selectionInfo.style.display = 'block';
      if (hiddenDateField) hiddenDateField.value = `${dateManager.selectedDate.formatted} ${dateManager.selectedTime}`;
      if (hiddenSlotField) hiddenSlotField.value = dateManager.selectedDate.slotId;
    } else {
      if (selectionInfo) selectionInfo.style.display = 'none';
      if (hiddenDateField) hiddenDateField.value = '';
      if (hiddenSlotField) hiddenSlotField.value = '';
    }
  }

  // ✅ 「inventory_options」側からの配送選択イベントに反応
  document.addEventListener('deliveryMethodChange', e => {
    const method = e.detail.method;
    console.log('[deliveryMethodChange event received]', method);
    if (method === 'delivery') {
      container.style.display = 'block';
      renderDateOptions();
    } else {
      container.style.display = 'none';
      dateManager.selectedDate = null;
      dateManager.selectedTime = null;
      if (timeSelect) timeSelect.value = '';
      if (selectionInfo) selectionInfo.style.display = 'none';
      if (hiddenDateField) hiddenDateField.value = '';
      if (hiddenSlotField) hiddenSlotField.value = '';
    }
  });

  // 🚀 初期化
  function init() {
    container.style.display = 'none'; // 初期は非表示
    console.log('DeliverySchedulePicker initialized:', { blockId, config });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{%- endif -%}

