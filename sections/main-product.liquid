    <div class="date-options" id="dateOptions" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 18px;"></div>
    <div class="selection-info" id="selectionInfo" style="margin-top: 25px; padding: 20px; border-radius: 0px; border-left: 4px solid #007c89; background: linear-gradient(135deg, #f8f9fa 0%, #e8f4fd 100%); display: none;"></div>
