          {{ time_clean | json }}: {{ block.settings[capacity_key] | default: 999 }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      },
      "reservationData": {{ reservation_data | json }},
      "biweeklyParity": {{ block.settings.biweekly_parity | default: "odd" | json }}
    }
  </script>
