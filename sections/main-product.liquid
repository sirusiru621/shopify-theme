<script>
(function() {
  'use strict';
  
  const blockId = '{{ block.id }}';
  const NOSHI_PRICE_PER_SHEET = 50;
  
  console.log('🔧 Noshi block initialized:', blockId);
  
  function initNoshiOptions() {
    console.log('🚀 Starting noshi initialization...');
    
    const noshiSelect = document.querySelector(`[data-noshi-type="${blockId}"]`);
    const noshiPreview = document.querySelector(`[data-noshi-preview="${blockId}"]`);
    const noshiImg = document.querySelector(`[data-noshi-image="${blockId}"]`);
    const qtySelect = document.querySelector(`[data-noshi-qty="${blockId}"]`);
    const priceDisplay = document.querySelector(`[data-noshi-price-display="${blockId}"]`);
    const priceInfo = document.getElementById(`noshi-price-${blockId}`);
    const feeHandleInput = document.querySelector(`[data-noshi-fee-handle="${blockId}"]`);
    
    console.log('📌 Elements found:', {
      noshiSelect: !!noshiSelect,
      qtySelect: !!qtySelect,
      priceDisplay: !!priceDisplay,
      feeHandleInput: !!feeHandleInput
    });
    
    if (!noshiSelect || !noshiImg || !noshiPreview) {
      console.error('❌ Required elements not found');
      return;
    }
    
    const productQtyEl = document.querySelector('[name="quantity"]') || 
                        document.querySelector('input[type="number"][id*="quantity"]') ||
                        document.querySelector('.quantity__input');
    
    let noshiImages = {};
    try {
      const mapEl = document.getElementById(`noshi-images-${blockId}`);
      if (mapEl && mapEl.textContent.trim()) {
        noshiImages = JSON.parse(mapEl.textContent.trim());
        console.log('✅ Noshi images loaded:', noshiImages);
      }
    } catch (e) {
      console.error('❌ Noshi images JSON parse error:', e);
    }
    
    // 🆕 商品ハンドルからVariant IDを取得してキャッシュ
    let noshiFeeVariantId = null;
    
    async function getNoshiFeeVariantId() {
      if (noshiFeeVariantId) return noshiFeeVariantId;
      
      const feeHandle = feeHandleInput ? feeHandleInput.value : 'noshi-fee';
      
      try {
        console.log('🔍 Fetching noshi fee product:', feeHandle);
        const response = await fetch(`/products/${feeHandle}.js`);
        if (!response.ok) throw new Error('Product not found');
        
        const product = await response.json();
        if (product.variants && product.variants.length > 0) {
          noshiFeeVariantId = product.variants[0].id;
          console.log('✅ Noshi fee variant ID cached:', noshiFeeVariantId);
          return noshiFeeVariantId;
        }
      } catch (error) {
        console.error('❌ Failed to fetch noshi fee product:', error);
        return null;
      }
    }
    
    // 料金表示更新
    function updateNoshiPrice() {
      if (!qtySelect || !priceDisplay || !priceInfo) return;
      
      const noshiQty = parseInt(qtySelect.value || 0, 10);
      const totalPrice = noshiQty * NOSHI_PRICE_PER_SHEET;
      
      console.log('💰 Calculating price: qty=' + noshiQty + ', total=' + totalPrice);
      
      if (noshiQty > 0) {
        priceDisplay.textContent = '¥' + totalPrice.toLocaleString('ja-JP');
        priceInfo.style.display = 'block';
      } else {
        priceDisplay.textContent = '¥0';
        priceInfo.style.display = 'none';
      }
    }
    
    function updateImage() {
      const selected = (noshiSelect.value || '').trim();
      console.log('🖼️ Selected noshi type:', selected);
      
      if (!selected) {
        noshiImg.removeAttribute('src');
        noshiPreview.style.display = 'none';
        return;
      }
      
      const url = noshiImages[selected];
      if (url) {
        noshiImg.src = url;
        noshiImg.alt = `${selected}のサンプル画像`;
        noshiPreview.style.display = 'block';
        
        noshiPreview.style.opacity = '0';
        setTimeout(() => {
          noshiPreview.style.transition = 'opacity 0.3s ease';
          noshiPreview.style.opacity = '1';
        }, 10);
      } else {
        noshiImg.removeAttribute('src');
        noshiPreview.style.display = 'none';
      }
    }
    
    function updateNoshiQtyOptions() {
      if (!qtySelect || !productQtyEl) return;
      
      const productQty = parseInt(productQtyEl.value || 1, 10);
      const currentValue = qtySelect.value;
      
      qtySelect.innerHTML = '<option value="">選択してください</option>';
      
      for (let i = 1; i <= productQty; i++) {
        const opt = document.createElement('option');
        opt.value = i;
        opt.textContent = `${i}枚`;
        qtySelect.appendChild(opt);
      }
      
      if (currentValue && parseInt(currentValue, 10) <= productQty) {
        qtySelect.value = currentValue;
      }
      
      updateNoshiPrice();
    }
    
    // イベントリスナー
    noshiSelect.addEventListener('change', updateImage);
    
    if (qtySelect) {
      qtySelect.addEventListener('change', updateNoshiPrice);
    }
    
    if (productQtyEl && qtySelect) {
      productQtyEl.addEventListener('change', updateNoshiQtyOptions);
      productQtyEl.addEventListener('input', updateNoshiQtyOptions);
      updateNoshiQtyOptions();
    }
    
    // 🆕 フォーム送信時に料金商品を一緒に追加
    const form = document.querySelector(`#${noshiSelect.getAttribute('form')}`);
    if (form) {
      form.addEventListener('submit', async function(e) {
        // バリデーション
        if (noshiSelect.value && !qtySelect.value) {
          e.preventDefault();
          alert('のし枚数を選択してください');
          qtySelect.focus();
          return;
        }
        
        // のし枚数が選択されている場合、料金商品も追加
        const noshiQty = parseInt(qtySelect.value || 0, 10);
        if (noshiQty > 0) {
          e.preventDefault();
          
          const variantId = await getNoshiFeeVariantId();
          if (!variantId) {
            alert('のし料金商品が見つかりません。管理者にお問い合わせください。');
            return;
          }
          
          // 元のフォームデータを取得
          const formData = new FormData(form);
          const items = [{
            id: formData.get('id'),
            quantity: parseInt(formData.get('quantity') || 1, 10),
            properties: {}
          }];
          
          // properties を追加
          for (let [key, value] of formData.entries()) {
            if (key.startsWith('properties[')) {
              const propName = key.match(/properties\[(.*?)\]/)[1];
              items[0].properties[propName] = value;
            }
          }
          
          // のし料金商品を追加
          items.push({
            id: variantId,
            quantity: noshiQty,
            properties: {
              '_のし料金': 'この商品に対する熨斗料金',
              '_関連商品': items[0].id
            }
          });
          
          console.log('🛒 Adding items to cart:', items);
          
          try {
            // カートに一括追加
            const response = await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: items })
            });
            
            if (!response.ok) throw new Error('Failed to add to cart');
            
            const result = await response.json();
            console.log('✅ Added to cart:', result);
            
            // カートページへリダイレクトまたはドロワーを開く
            if (typeof window.location !== 'undefined') {
              window.location.href = '/cart';
            }
          } catch (error) {
            console.error('❌ Failed to add to cart:', error);
            alert('カートへの追加に失敗しました。もう一度お試しください。');
          }
        }
      });
    }
    
    // 初期化時にVariant IDを取得
    getNoshiFeeVariantId();
    
    updateImage();
    console.log('✅ Noshi initialization complete');
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNoshiOptions);
  } else {
    initNoshiOptions();
  }
})();
</script>
