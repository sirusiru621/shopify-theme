      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>

<script>
(function() {
  'use strict';

  // セクションスコープ（このセクション内の数量にのみ作用）
  var sectionId = {{ section.id | json }};
  var productInfoSelector = '#ProductInfo-' + sectionId;

  // 数量を quantity rule にスナップ（min/ max/ step 準拠）
  function clampToRules(rawValue, input) {
    var min = parseFloat(input.getAttribute('min')) || 1;
    var maxAttr = input.getAttribute('max');
    var max = maxAttr ? parseFloat(maxAttr) : Infinity;
    var step = parseFloat(input.getAttribute('step')) || 1;

    var val = isNaN(rawValue) ? min : rawValue;
    if (val < min) val = min;
    if (Number.isFinite(max) && val > max) val = max;

    // step にスナップ（min 基準）
    var snapped = min + Math.round((val - min) / step) * step;

    // 浮動小数の誤差対策で丸める
    snapped = Number(snapped.toFixed(5));

    if (snapped < min) snapped = min;
    if (Number.isFinite(max) && snapped > max) snapped = max;

    return snapped;
  }

  // + / - クリック（デリゲーション）
  document.addEventListener('click', function(e) {
    var btn = e.target.closest(productInfoSelector + ' quantity-input .quantity__button');
    if (!btn) return;

    var isPlus = btn.name === 'plus';
    var container = btn.closest('quantity-input');
    var input = container ? container.querySelector('.quantity__input') : null;
    if (!input) return;

    // 既存(テーマ)ハンドラに先に処理させ、値が変わらなかった時だけフォールバック
    var before = parseFloat(input.value || input.getAttribute('min') || '1');

    setTimeout(function() {
      var after = parseFloat(input.value);
      var themeHandled = !isNaN(after) && after !== before;
      if (themeHandled) return;

      var step = parseFloat(input.getAttribute('step')) || 1;
      var next = (isNaN(before) ? (parseFloat(input.getAttribute('min')) || 1) : before) + (isPlus ? step : -step);

      next = clampToRules(next, input);

      if (next !== before) {
        input.value = next;
        // 金額/在庫連動など既存処理へ伝播
        input.dispatchEvent(new Event('change', { bubbles: true }));
      }
    }, 0);
  });

  // 手入力時のバリデーション（min/max/step を徹底順守）
  document.addEventListener('change', function(e) {
    var input = e.target.closest(productInfoSelector + ' .quantity__input');
    if (!input) return;
    var fixed = clampToRules(parseFloat(input.value), input);
    // 文字列比較で不要な再設定を避ける
    if (String(fixed) !== input.value) {
      input.value = fixed;
      // 既に change 内なので二重発火は不要
    }
  });

  // 念のため: 動的描画直後でも min/step が空なら既定値を補う（UI変更なし）
  document.addEventListener('shopify:section:load', function(evt) {
    if (!evt || !evt.target || evt.target.id !== ('shopify-section-' + sectionId)) return;
    var input = document.querySelector(productInfoSelector + ' .quantity__input');
    if (input) {
      if (!input.hasAttribute('min')) input.setAttribute('min', '1');
      if (!input.hasAttribute('step')) input.setAttribute('step', '1');
    }
  });
})();
</script>
<!-- 粒単位在庫制御: 雪もち / どら焼き / おはぎ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const productTitle = {{ product.title | json }};
  const targetNames = ["雪もち", "どら焼き", "おはぎ"];
  if (!targetNames.includes(productTitle)) return;

  const variant = {{ product.selected_or_first_available_variant | json }};
  const inventory = variant.inventory_quantity || 0;
  const productHandle = {{ product.handle | json }};
  const soldOutLabel = "売り切れ";

  console.log("在庫監視:", productTitle, "在庫:", inventory);

  // 粒単位在庫に基づく販売可否判定
  const availability = {
    "12個入り": inventory >= 12,
    "9個入り": inventory >= 9,
    "4個入り": inventory >= 4
  };

  // 商品タイトルに基づき在庫状態をラベルに反映
  function updateSoldOutLabel() {
    const titleEl = document.querySelector('.product__title h1');
    const priceEl = document.querySelector('#price-{{ section.id }}');

    if (!availability["12個入り"] && !availability["9個入り"] && !availability["4個入り"]) {
      // 全売り切れ
      if (priceEl) priceEl.insertAdjacentHTML('beforeend', `<span class="soldout-label">${soldOutLabel}</span>`);
    } else if (productTitle.includes("12個") && !availability["12個入り"]) {
      if (priceEl) priceEl.insertAdjacentHTML('beforeend', `<span class="soldout-label">${soldOutLabel}</span>`);
    } else if (productTitle.includes("9個") && !availability["9個入り"]) {
      if (priceEl) priceEl.insertAdjacentHTML('beforeend', `<span class="soldout-label">${soldOutLabel}</span>`);
    } else if (productTitle.includes("4個") && !availability["4個入り"]) {
      if (priceEl) priceEl.insertAdjacentHTML('beforeend', `<span class="soldout-label">${soldOutLabel}</span>`);
    }
  }

  // 「カートに追加」ボタン制御
  function disableAddToCartIfSoldOut() {
    const addBtn = document.querySelector('[name="add"]');
    if (!addBtn) return;

    const title = productTitle;
    let disabled = false;

    if (title.includes("12個") && !availability["12個入り"]) disabled = true;
    if (title.includes("9個") && !availability["9個入り"]) disabled = true;
    if (title.includes("4個") && !availability["4個入り"]) disabled = true;

    if (disabled) {
      addBtn.disabled = true;
      addBtn.classList.add('button--soldout');
      addBtn.textContent = soldOutLabel;
    }
  }

  updateSoldOutLabel();
  disableAddToCartIfSoldOut();
});
</script>

