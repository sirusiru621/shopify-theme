        if (!btn) return;
        let disable = false;
        if (title.includes('雪もち')) {
          if (title.includes('16個') && stock < 16) disable = true;
          if (title.includes('9個') && stock < 9) disable = true;
          if (title.includes('4個') && stock < 4) disable = true;
        }
        if (title.includes('どら焼')) {
          if (title.includes('9個') && stock < 9) disable = true;
          if (title.includes('6個') && stock < 6) disable = true;
          if (title.includes('3個') && stock < 3) disable = true;
