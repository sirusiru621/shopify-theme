<!-- ファイル名: sections/cross-sell-popup.liquid -->
<!-- 機能説明: カート追加時に表示されるクロスセル商品ポップアップシステム -->
<!-- 対応機能: Ajax カート追加、リアルタイム更新、レスポンシブ対応 -->

{{ 'cross-sell-popup.css' | asset_url | stylesheet_tag }}

{%- liquid
  # コレクション設定の取得
  assign cross_sell_collection = collections[section.settings.cross_sell_collection]
  assign max_products = section.settings.max_products | default: 3
  assign current_product = product
  
  # 商品フィルタリング（現在の商品を除外）
  assign filtered_products = cross_sell_collection.products | where: 'available', true
  assign cross_sell_products = filtered_products | where: 'id', '!=', current_product.id
-%}

<!-- クロスセル ポップアップ モーダル -->
<div id="cross-sell-popup" class="cross-sell-popup" style="display: none;" aria-hidden="true" role="dialog" aria-labelledby="cross-sell-title" aria-modal="true">
  
  <!-- オーバーレイ背景 -->
  <div class="cross-sell-overlay" data-close-popup></div>
  
  <!-- ポップアップ コンテンツ -->
  <div class="cross-sell-content">
    
    <!-- ヘッダー部分 -->
    <div class="cross-sell-header">
      <button type="button" class="cross-sell-close" data-close-popup aria-label="{{ 'general.accessibility.close' | t }}">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- 追加された商品情報 -->
    <div class="cross-sell-added-product">
      <div class="added-product-image">
        <div class="product-image-placeholder"></div>
      </div>
      <div class="added-product-info">
        <h3 class="added-product-title"></h3>
        <div class="added-product-price"></div>
      </div>
    </div>

    <!-- カート概要 -->
    <div class="cross-sell-cart-summary">
      <div class="cart-summary-content">
        <span class="cart-subtitle">{{ section.settings.cart_subtitle | default: 'Cart subtotal:' }}</span>
        <span class="cart-total" id="cart-total-display">{{ cart.total_price | money }}</span>
      </div>
      <div class="cart-items-count">
        <span class="cart-items-text">
          (<span id="cart-items-count">{{ cart.item_count }}</span> 
          {%- if cart.item_count == 1 -%}
            {{ section.settings.item_text | default: 'Item' }}
          {%- else -%}
            {{ section.settings.items_text | default: 'Items' }}
          {%- endif -%})
        </span>
      </div>
    </div>

    <!-- アクションボタン -->
    <div class="cross-sell-actions">
      <button type="button" class="checkout-btn" onclick="window.location.href='/checkout'">
        {{ section.settings.checkout_text | default: 'Checkout' }}
      </button>
      <button type="button" class="view-cart-btn" data-close-popup onclick="window.location.href='/cart'">
        {{ section.settings.view_cart_text | default: 'View Cart' }}
      </button>
    </div>

    <!-- クロスセル商品セクション -->
    {%- if cross_sell_products.size > 0 -%}
    <div class="cross-sell-products-section">
      <h4 class="cross-sell-products-title" id="cross-sell-title">
        {{ section.settings.cross_sell_title | default: 'Customers Also Bought' }}
      </h4>
      
      <div class="cross-sell-products-grid">
        {%- for cross_sell_product in cross_sell_products limit: max_products -%}
          {%- liquid
            assign product_variant = cross_sell_product.selected_or_first_available_variant
            assign product_price = product_variant.price
            assign compare_price = product_variant.compare_at_price
            assign product_available = product_variant.available
          -%}
          
          <div class="cross-sell-product-card" data-product-id="{{ cross_sell_product.id }}">
            
            <!-- 商品画像 -->
            <div class="product-card-image">
              {%- if cross_sell_product.featured_image -%}
                <img 
                  src="{{ cross_sell_product.featured_image | image_url: width: 300 }}"
                  srcset="
                    {{ cross_sell_product.featured_image | image_url: width: 150 }} 150w,
                    {{ cross_sell_product.featured_image | image_url: width: 300 }} 300w,
                    {{ cross_sell_product.featured_image | image_url: width: 450 }} 450w
                  "
                  sizes="(max-width: 767px) 150px, 200px"
                  alt="{{ cross_sell_product.featured_image.alt | default: cross_sell_product.title | escape }}"
                  class="product-image"
                  loading="lazy"
                  width="300"
                  height="300"
                >
              {%- else -%}
                <div class="product-image-placeholder">
                  <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21,15 16,10 5,21"/>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            <!-- 商品情報 -->
            <div class="product-card-info">
              <h5 class="product-card-title">{{ cross_sell_product.title | escape }}</h5>
              
              <!-- 価格表示 -->
              <div class="product-card-price">
                {%- if compare_price > product_price -%}
                  <span class="price-compare">{{ compare_price | money }}</span>
                {%- endif -%}
                <span class="price-current">
                  {%- if cross_sell_product.price_varies -%}
                    {{ cross_sell_product.price_min | money }}+
                  {%- else -%}
                    {{ product_price | money }}
                  {%- endif -%}
                </span>
              </div>

              <!-- バリエーション選択 -->
              {%- if cross_sell_product.variants.size > 1 and section.settings.show_variants -%}
                <div class="product-variants">
                  <select class="variant-selector" data-product-id="{{ cross_sell_product.id }}">
                    {%- for variant in cross_sell_product.variants -%}
                      {%- if variant.available -%}
                        <option value="{{ variant.id }}" data-price="{{ variant.price | money }}">
                          {{ variant.title }} - {{ variant.price | money }}
                        </option>
                      {%- endif -%}
                    {%- endfor -%}
                  </select>
                </div>
              {%- endif -%}

              <!-- カート追加ボタン -->
              {%- if product_available -%}
                <button 
                  type="button" 
                  class="add-to-cart-btn" 
                  data-variant-id="{{ product_variant.id }}"
                  data-product-title="{{ cross_sell_product.title | escape }}"
                  data-product-price="{{ product_price | money }}"
                  data-product-image="{{ cross_sell_product.featured_image | image_url: width: 150 }}"
                >
                  <span class="btn-text">{{ section.settings.add_to_cart_text | default: 'Add to cart' }}</span>
                  <span class="btn-loading" style="display: none;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M21 12a9 9 0 11-6.219-8.56"/>
                    </svg>
                  </span>
                  <span class="btn-success" style="display: none;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20,6 9,17 4,12"/>
                    </svg>
                  </span>
                </button>
              {%- else -%}
                <button type="button" class="add-to-cart-btn sold-out" disabled>
                  {{ section.settings.sold_out_text | default: 'Sold out' }}
                </button>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}
  </div>
</div>

<!-- 設定データをJavaScriptに渡す -->
<script type="application/json" id="cross-sell-config">
  {
    "enabled": {{ section.settings.enable_popup | json }},
    "delay": {{ section.settings.popup_delay | default: 500 | json }},
    "autoClose": {{ section.settings.auto_close_delay | default: 0 | json }},
    "showOnMobile": {{ section.settings.show_on_mobile | json }},
    "cartUrl": {{ routes.cart_url | json }},
    "cartAddUrl": {{ routes.cart_add_url | json }},
    "moneyFormat": {{ shop.money_format | json }},
    "debug": {{ section.settings.enable_debug_mode | default: false | json }},
    "messages": {
      "addedToCart": {{ section.settings.added_message | default: 'Added to cart!' | json }},
      "error": {{ section.settings.error_message | default: 'Sorry, something went wrong.' | json }}
    }
  }
</script>

<script src="{{ 'cross-sell-popup.js' | asset_url }}" defer></script>
