{% comment %}
/**
 * 和風フローティング予約バナー
 * 右側固定で表示される予約CTAバナー
 * 和のテイストに合わせた上品なデザイン
 */
{% endcomment %}

<!-- CSS Styles -->
<style>
  .floating-reservation-banner {
    position: fixed;
    right: {{ section.settings.banner_right_position }}px;
    {% if section.settings.position_unit == 'percent' %}
      {% if section.settings.vertical_position_type == 'top' %}
        top: {{ section.settings.vertical_position_percent }}%;
        bottom: auto;
      {% else %}
        bottom: {{ section.settings.vertical_position_percent }}%;
        top: auto;
      {% endif %}
    {% else %}
      bottom: {{ section.settings.banner_bottom_position }}px;
    {% endif %}
    z-index: 9999;
    {% if section.settings.display_style == 'vertical' %}
      width: {{ section.settings.vertical_banner_width }}px;
      height: auto;
      background: linear-gradient(135deg, 
        {{ section.settings.vertical_background_color | default: '#2d1810' }} 0%, 
        {{ section.settings.vertical_background_color_secondary | default: '#3a2318' }} 100%);
    {% else %}
      width: {{ section.settings.banner_width }}px;
      background: linear-gradient(135deg, 
        {{ section.settings.background_color | default: '#2d1810' }} 0%, 
        {{ section.settings.background_color_secondary | default: '#3a2318' }} 100%);
    {% endif %}
    border-radius: 0;
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 2px 8px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    border: 1px solid {{ section.settings.border_color | default: '#5a4234' }};
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    font-family: 'Noto Sans JP', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
    opacity: 0;
    animation: fadeInSlide 0.6s ease-out 0.5s forwards;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .floating-reservation-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, 
      transparent 0%, 
      {{ section.settings.accent_color | default: '#d4af37' }} 50%, 
      transparent 100%);
  }

  .floating-reservation-banner:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 12px 48px rgba(0, 0, 0, 0.4),
      0 4px 16px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .floating-reservation-banner:focus {
    outline: 2px solid {{ section.settings.accent_color | default: '#d4af37' }};
    outline-offset: 2px;
  }

  .floating-reservation-banner:active {
    transform: translateY(-2px);
  }

  .banner-content {
    padding: {{ section.settings.inner_padding }}px;
    text-align: center;
    position: relative;
    {% if section.settings.display_style == 'vertical' %}
      padding: {{ section.settings.vertical_inner_padding }}px;
    {% endif %}
  }

  /* 縦書きスタイル */
  .banner-content.vertical-style {
    writing-mode: vertical-rl;
    text-orientation: upright;
    padding: 20px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 120px;
  }

  .vertical-style .banner-title {
    writing-mode: vertical-rl !important;
    text-orientation: upright !important;
    margin: 30px 0 16px 0 !important;
    line-height: 1.2 !important;
    letter-spacing: 0.3em !important;
    text-align: center !important;
  }

  .vertical-style .banner-subtitle {
    writing-mode: vertical-rl !important;
    text-orientation: upright !important;
    margin: 25px 5px 10px 0 !important;
    font-size: {{ section.settings.vertical_subtitle_font_size | default: 11 }}px !important;
    text-align: center !important;
    line-height: 1.4 !important;
  }

  .vertical-style .banner-cta {
    writing-mode: horizontal-tb !important;
    text-orientation: mixed !important;
    padding: 8px 12px !important;
    font-size: {{ section.settings.vertical_cta_font_size | default: 12 }}px !important;
    border-radius: 0 !important;
    margin-top: 8px !important;
    display: block !important;
    width: auto !important;
    min-width: 60px !important;
  }

  /* 縦書き時のアイコン非表示 */
  .vertical-style .banner-icon {
    display: none;
  }

  .banner-icon {
    width: 32px;
    height: 32px;
    margin: 0 auto 12px;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .banner-title {
    {% if section.settings.display_style == 'vertical' %}
      color: {{ section.settings.vertical_text_color | default: '#f5f3f0' }};
      font-size: {{ section.settings.vertical_title_font_size | default: 18 }}px;
    {% else %}
      color: {{ section.settings.text_color | default: '#f5f3f0' }};
      font-size: {{ section.settings.title_font_size }}px;
    {% endif %}
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 8px;
    letter-spacing: 0.5px;
  }

  .banner-subtitle {
    {% if section.settings.display_style == 'vertical' %}
      color: {{ section.settings.vertical_subtitle_color | default: '#c5b8a8' }};
      font-size: {{ section.settings.vertical_subtitle_font_size | default: 11 }}px;
    {% else %}
      color: {{ section.settings.subtitle_color | default: '#c5b8a8' }};
      font-size: {{ section.settings.subtitle_font_size }}px;
    {% endif %}
    font-weight: 400;
    line-height: 1.4;
    margin: 0 0 16px;
    opacity: 0.9;
  }

  .banner-close {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border: none;
    background: rgba(255, 255, 255, 0.1);
    color: {{ section.settings.text_color | default: '#f5f3f0' }};
    border-radius: 50%;
    cursor: pointer;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.6;
    z-index: 10;
  }

  .banner-close:hover {
    background: rgba(255, 255, 255, 0.2);
    opacity: 1;
  }

  .banner-close:focus {
    outline: 2px solid {{ section.settings.accent_color | default: '#d4af37' }};
    outline-offset: 2px;
  }

  .floating-reservation-banner.hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateX(100px);
  }

  @keyframes fadeInSlide {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* レスポンシブ対応 */
  @media (max-width: 768px) {
    .floating-reservation-banner {
      right: {{ section.settings.mobile_right_position | default: 15 }}px;
      {% if section.settings.position_unit == 'percent' %}
        {% if section.settings.vertical_position_type == 'top' %}
          top: {{ section.settings.mobile_vertical_position_percent | default: section.settings.vertical_position_percent }}%;
          bottom: auto;
        {% else %}
          bottom: {{ section.settings.mobile_vertical_position_percent | default: section.settings.vertical_position_percent }}%;
          top: auto;
        {% endif %}
      {% else %}
        bottom: {{ section.settings.mobile_bottom_position }}px;
      {% endif %}
      {% if section.settings.display_style == 'vertical' %}
        width: {{ section.settings.mobile_vertical_banner_width }}px;
      {% else %}
        width: {{ section.settings.mobile_banner_width }}px;
      {% endif %}
      max-width: calc(100vw - 32px);
    }

    .floating-reservation-banner:hover {
      transform: translateY(-2px);
    }

    .floating-reservation-banner:active {
      transform: translateY(0);
    }

    .banner-content {
      padding: 16px;
    }

    .banner-content.vertical-style {
      padding: 16px 12px;
      min-height: 100px;
    }

    .vertical-style .banner-title {
      font-size: {{ section.settings.mobile_title_font_size }}px !important;
      writing-mode: vertical-rl !important;
      text-orientation: upright !important;
      letter-spacing: 0.3em !important;
      transform: none !important;
    }

    .vertical-style .banner-subtitle {
      font-size: {{ section.settings.mobile_subtitle_font_size }}px !important;
      writing-mode: vertical-rl !important;
      text-orientation: upright !important;
      letter-spacing: 0.2em !important;
      transform: none !important;
    }

    .banner-title {
      font-size: {{ section.settings.mobile_title_font_size }}px;
    }

    .banner-subtitle {
      font-size: {{ section.settings.mobile_subtitle_font_size }}px;
    }
  }

  @media (max-width: 480px) {
    .floating-reservation-banner {
      width: 86px;
        right: 0px;
    }

    .banner-content {
      padding: 12px;
    }
  }

  /* アクセシビリティ対応 */
  @media (prefers-reduced-motion: reduce) {
    .floating-reservation-banner,
    .banner-cta,
    .banner-close {
      transition: none;
      animation: none;
    }

    .floating-reservation-banner {
      opacity: 1;
    }
  }

  /* ハイコントラストモード対応 */
  @media (prefers-contrast: high) {
    .floating-reservation-banner {
      border: 2px solid;
    }
    
    .banner-cta {
      border: 2px solid;
    }
  }/* 2つ目のタイトル用スタイル */
.banner-title-2 {
  {% if section.settings.display_style == 'vertical' %}
    color: {{ section.settings.vertical_text_color_2 | default: section.settings.vertical_text_color | default: '#f5f3f0' }};
    font-size: {{ section.settings.vertical_title_font_size_2 | default: 16 }}px;
  {% else %}
    color: {{ section.settings.text_color_2 | default: section.settings.text_color | default: '#f5f3f0' }};
    font-size: {{ section.settings.title_font_size_2 | default: 16 }}px;
  {% endif %}
  font-weight: {{ section.settings.title_2_font_weight | default: 500 }};
  line-height: 1.3;
  margin: {{ section.settings.title_2_margin_top | default: 4 }}px 0 {{ section.settings.title_2_margin_bottom | default: 8 }}px;
  letter-spacing: 0.5px;
  opacity: {{ section.settings.title_2_opacity | default: 0.95 }};
}

/* 縦書きスタイルの2つ目のタイトル */
.vertical-style .banner-title-2 {
  writing-mode: vertical-rl !important;
  text-orientation: upright !important;
  margin: 30px 0 10px 0 !important;
  line-height: 1.2 !important;
  letter-spacing: 0.25em !important;
  text-align: center !important;
}

/* モバイル用 */
@media (max-width: 768px) {
  .banner-title-2 {
    font-size: {{ section.settings.mobile_title_font_size_2 | default: 14 }}px;
  }
  
  .vertical-style .banner-title-2 {
    font-size: {{ section.settings.mobile_title_font_size_2 | default: 14 }}px !important;
  }
}

</style>

<!-- HTML Structure -->
<a href="{% if section.settings.display_style == 'vertical' %}{{ section.settings.vertical_cta_url | default: '/pages/reservation' }}{% else %}{{ section.settings.cta_url | default: '/pages/reservation' }}{% endif %}" 
   class="floating-reservation-banner" 
   id="floating-reservation-banner"
   role="banner"
   aria-label="{% if section.settings.display_style == 'vertical' %}{{ section.settings.vertical_cta_aria_label | default: '予約ページへ移動' }}{% else %}{{ section.settings.cta_aria_label | default: '予約ページへ移動' }}{% endif %}"
   {% if section.settings.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}>
  
  {% if section.settings.show_close_button %}
    <button class="banner-close" 
            id="banner-close-btn"
            onclick="event.preventDefault(); event.stopPropagation(); closeBanner(); return false;"
            aria-label="バナーを閉じる"
            type="button">
      ×
    </button>
  {% endif %}

  <div class="banner-content{% if section.settings.display_style == 'vertical' %} vertical-style{% endif %}">
    {% if section.settings.icon_svg and section.settings.display_style != 'vertical' %}
      <div class="banner-icon">
        {{ section.settings.icon_svg }}
      </div>
    {% endif %}

    {% if section.settings.display_style == 'vertical' %}
      <h2 class="banner-title">
        {{ section.settings.vertical_title_line_1 | default: section.settings.vertical_title | default: '予約' }}
        {% assign vt2 = section.settings.vertical_title_line_2 | default: '' | strip %}
        {% if vt2 != '' %}<br>{{ vt2 }}{% endif %}
      </h2>
      <!-- 2つ目のタイトルを追加（既存機能維持） -->
      {% if section.settings.vertical_title_2 %}
        <h3 class="banner-title banner-title-2">{{ section.settings.vertical_title_2 }}</h3>
      {% endif %}

      {% if section.settings.vertical_subtitle %}
        <p class="banner-subtitle">{{ section.settings.vertical_subtitle }}</p>
      {% endif %}
    {% else %}
      <h2 class="banner-title">
        {{ section.settings.title_line_1 | default: section.settings.title | default: 'ご予約' }}
        {% assign t2 = section.settings.title_line_2 | default: '' | strip %}
        {% if t2 != '' %}<br>{{ t2 }}{% endif %}
      </h2>
      <!-- 2つ目のタイトルを追加（既存機能維持） -->
      {% if section.settings.title_2 %}
        <h3 class="banner-title banner-title-2">{{ section.settings.title_2 }}</h3>
      {% endif %}
    
      {% if section.settings.subtitle %}
        <p class="banner-subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    {% endif %}
  </div>
</a>

<!-- JavaScript -->
<script>
(function() {
  'use strict';
  
  // IntersectionObserver for scroll-based visibility
  let banner = document.getElementById('floating-reservation-banner');
  let isVisible = true;
  let scrollTimeout;
  let isBannerClosed = false; // ページレベルの変数（リロード時にリセット）

  function initBanner() {
    // ページレベルの変数をチェック（リロード時は常にfalse）
    if (isBannerClosed) {
      banner.classList.add('hidden');
      return;
    }

    // 表示スタイルの適用
    const displayStyle = '{{ section.settings.display_style }}';
    const bannerContent = banner.querySelector('.banner-content');
    
    console.log('Display style:', displayStyle); // デバッグ用
    
    if (displayStyle === 'vertical' && bannerContent) {
      bannerContent.classList.add('vertical-style');
      console.log('Vertical style applied'); // デバッグ用
      
      // 各要素に縦書きスタイルを確実に適用
      const title = bannerContent.querySelector('.banner-title');
      const subtitle = bannerContent.querySelector('.banner-subtitle');
      const cta = bannerContent.querySelector('.banner-cta');
      
      if (title) {
        title.style.writingMode = 'vertical-rl';
        title.style.textOrientation = 'upright';
        title.style.letterSpacing = '0.3em';
        title.style.lineHeight = '1.2';
        title.style.color = '{{ section.settings.vertical_text_color | default: "#f5f3f0" }}';
        title.style.fontSize = '{{ section.settings.vertical_title_font_size | default: 18 }}px';
      }
      if (subtitle) {
        subtitle.style.writingMode = 'vertical-rl';
        subtitle.style.textOrientation = 'upright';
        subtitle.style.letterSpacing = '0.2em';
        subtitle.style.color = '{{ section.settings.vertical_subtitle_color | default: "#c5b8a8" }}';
        subtitle.style.fontSize = '{{ section.settings.vertical_subtitle_font_size | default: 11 }}px';
      }
      if (cta) {
        cta.style.writingMode = 'horizontal-tb';
        cta.style.textOrientation = 'mixed';
        cta.style.marginTop = '12px';
        cta.style.fontSize = '{{ section.settings.vertical_cta_font_size | default: 12 }}px';
      }
    }

    // 閉じるボタンのイベントリスナー
    const closeBtn = document.getElementById('banner-close-btn');
    if (closeBtn) {
      closeBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        closeBanner();
      });
    }

    // スクロール方向の検出
    let lastScrollY = window.scrollY;
    
    function handleScroll() {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const currentScrollY = window.scrollY;
        const scrollingDown = currentScrollY > lastScrollY;
        const scrolledPastThreshold = currentScrollY > {{ section.settings.scroll_threshold | default: 200 }};

        if (scrollingDown && scrolledPastThreshold && isVisible) {
          // 下にスクロール中で閾値を超えた場合は非表示
          if ({{ section.settings.hide_on_scroll_down | default: false }}) {
            banner.style.opacity = '0.3';
          }
        } else if (!scrollingDown && isVisible) {
          // 上にスクロール中は表示
          banner.style.opacity = '1';
        }

        lastScrollY = currentScrollY;
      }, 100);
    }

    // イベントリスナー
    window.addEventListener('scroll', handleScroll, { passive: true });

    // キーボードアクセシビリティ
    banner.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeBanner();
      }
    });

    // ホバーエフェクト強化
    banner.addEventListener('mouseenter', function() {
      if (window.innerWidth > 768) {
        this.style.transform = 'translateY(-4px)';
      }
    });

    banner.addEventListener('mouseleave', function() {
      if (window.innerWidth > 768) {
        this.style.transform = 'translateY(0)';
      }
    });
  }

  // バナーを閉じる関数（グローバルスコープ）
  window.closeBanner = function() {
    console.log('closeBanner function called'); // デバッグ用
    
    if (banner) {
      banner.classList.add('hidden');
      isBannerClosed = true; // ページレベルの変数を更新
      isVisible = false;
      
      // アナリティクス追跡（GA4対応）
      if (typeof gtag !== 'undefined') {
        gtag('event', 'floating_banner_closed', {
          event_category: 'engagement',
          event_label: 'reservation_banner'
        });
      }
      
      console.log('Banner closed successfully'); // デバッグ用
    } else {
      console.log('Banner element not found'); // デバッグ用
    }
  };

  // CTAクリック追跡（バナー全体のクリック）
  banner.addEventListener('click', function(e) {
    // 閉じるボタンのクリックの場合は何もしない
    if (e.target.closest('.banner-close')) {
      return;
    }
    
    // アナリティクス追跡
    if (typeof gtag !== 'undefined') {
      gtag('event', 'floating_banner_click', {
        event_category: 'conversion',
        event_label: 'reservation_cta',
        value: 1
      });
    }
  });

  // DOM読み込み完了後に初期化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBanner);
  } else {
    initBanner();
  }

  // ページ離脱時のクリーンアップ
  window.addEventListener('beforeunload', function() {
    // 注意: handleScroll は initBanner 内で定義されているため removeEventListener は不要/無害
  });

})();
</script>

{% schema %}
{
  "name": "和風フローティング予約バナー",
  "tag": "section",
  "class": "floating-reservation-section",
  "settings": [
    {
      "type": "header",
      "content": "表示スタイル"
    },
    {
      "type": "select",
      "id": "display_style",
      "label": "表示形式",
      "options": [
        {
          "value": "horizontal",
          "label": "横書き（標準）"
        },
        {
          "value": "vertical", 
          "label": "縦書き（シンプル）"
        }
      ],
      "default": "horizontal",
      "info": "バナーの文字レイアウトを選択"
    },
    {
      "type": "header",
      "content": "基本設定"
    },
    {
      "type": "header",
      "content": "横書き用設定"
    },
    {
      "type": "text",
      "id": "title",
      "label": "横書き用タイトル（従来）",
      "default": "ご予約",
      "info": "従来の単一行タイトル（後方互換）"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "横書きタイトル（1行目）",
      "default": "ご予約",
      "info": "横書き表示時のタイトル1行目"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "横書きタイトル（2行目）",
      "default": "イベント",
      "info": "2行目を表示しない場合は空欄のままにしてください"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "横書き用サブタイトル",
      "default": "心に残るひとときを",
      "info": "横書き表示時の説明文"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "横書き用リンク先URL",
      "default": "/pages/reservation",
      "info": "横書き表示時のリンク先URL"
    },
    {
      "type": "header",
      "content": "縦書き用設定"
    },
    {
      "type": "text",
      "id": "vertical_title",
      "label": "縦書き用タイトル（従来）",
      "default": "予約",
      "info": "従来の単一行タイトル（後方互換）"
    },
    {
      "type": "text",
      "id": "vertical_title_line_1",
      "label": "縦書きタイトル（1行目）",
      "default": "予約",
      "info": "縦書き表示時のタイトル1行目"
    },
    {
      "type": "text",
      "id": "vertical_title_line_2",
      "label": "縦書きタイトル（2行目）",
      "default": "イベント",
      "info": "2行目を表示しない場合は空欄のままにしてください"
    },
    {
      "type": "textarea",
      "id": "vertical_subtitle",
      "label": "縦書き用サブタイトル",
      "default": "承り中",
      "info": "縦書き表示時の説明文（短いテキスト推奨）"
    },
    {
      "type": "text",
      "id": "vertical_cta_url",
      "label": "縦書き用リンク先URL",
      "default": "/pages/reservation",
      "info": "縦書き表示時のリンク先URL"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "新しいタブで開く",
      "default": false
    },
    {
      "type": "html",
      "id": "icon_svg",
      "label": "アイコンSVG",
      "info": "バナー上部に表示するSVGアイコン",
      "default": "<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M12 3L2 12h3v8h14v-8h3L12 3zm0 2.236L18 11v8h-4v-6h-4v6H6v-8l6-5.764z\"/></svg>"
