{% comment %} Product grid enhanced section for Dawn 10+ {% endcomment %}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

{%- style -%}
.section-{{ section.id }}-padding{padding-top:{{ section.settings.padding_top | times: 0.75 | round: 0 }}px;padding-bottom:{{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px}
@media screen and (min-width:750px){.section-{{ section.id }}-padding{padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px}}
.product-grid-{{ section.id }}{display:grid;gap:{{ section.settings.grid_gap }}px}
.product-grid-{{ section.id }}{grid-template-columns:repeat({{ section.settings.desktop_columns }},minmax(0,1fr))}
@media screen and (max-width:749px){
.product-grid-{{ section.id }}{grid-template-columns:repeat({% if section.settings.mobile_columns == 'two' %}2{% else %}1{% endif %},minmax(0,1fr))}
}
.card-{{ section.id }}{display:flex;flex-direction:column;height:100%;background:rgb(var(--color-background));border:1px solid rgba(var(--color-foreground),0.08);border-radius:{{ section.settings.card_radius }}px;overflow:hidden}
.card-{{ section.id }} .card__media{position:relative;width:100%;padding-top:{{ 100 | divided_by: section.settings.image_ratio | round: 2 }}%}
.card-{{ section.id }} .card__media img{position:absolute;inset:0;width:100%;height:100%;object-fit:{% if section.settings.image_fit == 'cover' %}cover{% else %}contain{% endif %}}
.card-{{ section.id }} .card__body{padding:1.2rem 1.2rem 1.6rem}
.card-{{ section.id }} .card__vendor{opacity:.7;font-size:1.2rem;margin:0 0 .4rem 0}
.card-{{ section.id }} .card__title{margin:0 0 .4rem 0;font-size:1.5rem;line-height:1.3;word-break:break-word}
.card-{{ section.id }} .price{margin:.2rem 0 .6rem 0}
.card-{{ section.id }} .card__desc{font-size:1.3rem;line-height:1.5;color:rgba(var(--color-foreground),0.8);margin:.4rem 0 0 0;white-space:pre-wrap}
.card-{{ section.id }} .card__actions{margin-top:auto;display:flex;gap:.6rem;padding: 2rem 0;}
.card-{{ section.id }} .button{width:100%}
.card-{{ section.id }} form {width: 100%;}
h3.card__title a {
    color: black;
}
.card-{{ section.id }} .badge{position:absolute;left:.8rem;top:.8rem;background:rgb(var(--color-background));border:1px solid rgba(var(--color-foreground),0.08);border-radius:999px;padding:.3rem .8rem;font-size:1.1rem}
{%- endstyle -%}

<section class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} {% if section.settings.secondary_background %}background-secondary{% else %}gradient{% endif %}"> <div class="page-width"> {% if section.settings.heading != blank %} <h2 class="{{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2> {% endif %}
<div class="product-grid-{{ section.id }}">
  {%- for block in section.blocks -%}
    {%- if block.type == 'product_card' -%}
      {%- assign p = block.settings.product -%}
      <article class="card-{{ section.id }}" {{ block.shopify_attributes }}>
        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <span class="badge">{{ block.settings.badge_text | escape }}</span>
        {% endif %}

        {% if block.settings.show_image %}
          <a class="card__media" href="{{ p.url | default: '#' }}" aria-label="{{ p.title | escape }}">
            {%- if p != blank and p.featured_image != blank -%}
              <img
                src="{{ p.featured_image | image_url: width: 800 }}"
                srcset="{{ p.featured_image | image_url: width: 400 }} 400w, {{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 800 }} 800w"
                sizes="(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw"
                alt="{{ p.title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
        {% endif %}

        <div class="card__body">
          {% if block.settings.show_vendor and p.vendor != blank %}
            <div class="card__vendor">{{ p.vendor | escape }}</div>
          {% endif %}

          {% if block.settings.show_title %}
            <h3 class="card__title">
              <a href="{{ p.url | default: '#' }}">{{ block.settings.title_override | default: p.title | escape }}</a>
            </h3>
          {% endif %}

          {% if block.settings.show_price %}
            <div class="card__price">
              {% render 'price', product: p, use_variant: true, price_class: 'price--large' %}
            </div>
          {% endif %}

          {% if block.settings.custom_description != blank %}
            <div class="card__desc">{{ block.settings.custom_description }}</div>
          {% endif %}

          <div class="card__actions">
            {% if block.settings.show_view_button %}
              <a class="button button--secondary" href="{{ p.url | default: '#' }}">{{ block.settings.view_label }}</a>
            {% endif %}
            {% if block.settings.show_add_button and p != blank and p.available %}
              <form method="post" action="/cart/add">
                <input type="hidden" name="id" value="{{ p.selected_or_first_available_variant.id }}">
                <button type="submit" class="button">{{ block.settings.add_label }}</button>
              </form>
            {% endif %}
          </div>
        </div>
      </article>
    {%- endif -%}
  {%- endfor -%}
</div>

</div> </section>

{% schema %}
{
"name": "Product grid enhanced",
"tag": "section",
"class": "section product-grid-enhanced",
"disabled_on": { "groups": ["header","footer"] },
"settings": [
{ "type": "text", "id": "heading", "label": "見出し", "default": "おすすめ商品" },
{ "type": "select","id":"heading_size","label":"見出しサイズ","default":"h2","options":[{"value":"h2","label":"H2"},{"value":"h1","label":"H1"},{"value":"h0","label":"H0"}]},
{ "type": "color_scheme", "id": "color_scheme", "label": "配色", "default": "background-1" },
{ "type": "checkbox", "id": "secondary_background", "default": false, "label": "セクション背景（セカンダリ）" },
{ "type": "range", "id": "grid_gap", "label": "カード間隔(px)", "min": 0, "max": 48, "step": 2, "default": 16 },
{ "type": "range", "id": "desktop_columns", "label": "デスクトップ列数", "min": 2, "max": 6, "step": 1, "default": 3 },
{ "type": "select", "id": "mobile_columns", "label": "モバイル列数", "default": "one", "options": [ { "value": "one", "label": "1列" }, { "value": "two", "label": "2列" } ] },
{ "type": "select", "id": "image_fit", "label": "画像フィット", "default": "cover", "options": [ { "value": "cover", "label": "カバー" }, { "value": "contain", "label": "コンテイン" } ] },
{ "type": "range", "id": "image_ratio", "label": "画像アスペクト比（W:H）Wを1としたHの値", "min": 0.5, "max": 2.0, "step": 0.1, "default": 1.0 },
{ "type": "range", "id": "card_radius", "label": "カード角丸(px)", "min": 0, "max": 24, "step": 2, "default": 12 },
{ "type": "header", "content": "セクション余白" },
{ "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "上余白", "default": 36 },
{ "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "下余白", "default": 36 }
],
"blocks": [
{
"type": "product_card",
"name": "商品カード",
"limit": 24,
"settings": [
{ "type": "product", "id": "product", "label": "商品を選択" },
{ "type": "checkbox", "id": "show_image", "label": "商品画像を表示", "default": true },
{ "type": "checkbox", "id": "show_vendor", "label": "ベンダーを表示", "default": false },
{ "type": "checkbox", "id": "show_title", "label": "商品名を表示", "default": true },
{ "type": "text", "id": "title_override", "label": "商品名（上書き・任意）" },
{ "type": "checkbox", "id": "show_price", "label": "価格を表示", "default": true },
{ "type": "textarea", "id": "custom_description", "label": "価格下テキスト（商品説明・自由入力）", "default": "商品説明" },
{ "type": "checkbox", "id": "show_view_button", "label": "詳細ボタンを表示", "default": true },
{ "type": "text", "id": "view_label", "label": "詳細ボタン文言", "default": "詳細を見る" },
{ "type": "checkbox", "id": "show_add_button", "label": "カートに追加ボタンを表示", "default": false },
{ "type": "text", "id": "add_label", "label": "追加ボタン文言", "default": "カートに追加" },
{ "type": "checkbox", "id": "show_badge", "label": "バッジを表示", "default": false },
{ "type": "text", "id": "badge_text", "label": "バッジ文言", "default": "NEW" }
]
}
],
"presets": [
{
"name": "Product grid enhanced",
"blocks": [
{ "type": "product_card" },
{ "type": "product_card" },
{ "type": "product_card" }
]
}
]
}
{% endschema %}