<!-- ファイル名: bulk-order-form.liquid -->
<!-- まとまったご注文フォームセクション - 和菓子店向けカスタム注文フォーム（熨斗・見積もり機能付き） -->
<!-- 機能説明: お客様が10個以上の商品を注文する際の専用フォーム + 熨斗選択 + リアルタイム見積もり -->

{{ 'bulk-order-form.css' | asset_url | stylesheet_tag }}

<style>
  #bulk-order-{{ section.id }} {
    --section-bg-color: {{ section.settings.section_bg_color }};
    --section-text-color: {{ section.settings.text_color }};
    --section-accent-color: {{ section.settings.accent_color }};
    --section-border-color: {{ section.settings.border_color }};
    --section-button-bg: {{ section.settings.button_bg_color }};
    --section-button-text: {{ section.settings.button_text_color }};
    --section-desktop-font-size: {{ section.settings.desktop_font_size }}px;
    --section-mobile-font-size: {{ section.settings.mobile_font_size }}px;
    --section-title-size: {{ section.settings.title_font_size }}px;
    --section-section-padding-top: {{ section.settings.section_padding_top }}px;
    --section-section-padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
</style>

<section class="bulk-order-section" id="bulk-order-{{ section.id }}">
  <div class="bulk-order-container">
    
    <!-- セクションヘッダー -->
    {% if section.settings.section_title != blank %}
      <header class="bulk-order-header">
        <h2 class="bulk-order-title">{{ section.settings.section_title }}</h2>
        {% if section.settings.section_description != blank %}
          <div class="bulk-order-description">
            {{ section.settings.section_description }}
          </div>
        {% endif %}
      </header>
    {% endif %}

    <!-- 注文説明テキスト -->
    <div class="bulk-order-info">
      <div class="bulk-order-info-content">
        {{ section.settings.order_info_text }}
      </div>
      <!-- 改善版プロセスフロー -->
<div class="process-flow" role="progressbar" aria-label="注文プロセス" aria-valuenow="3" aria-valuemin="1" aria-valuemax="4">
  
  <!-- ステップ1: お問合 -->
  <div class="process-step" data-step="1" role="listitem">
    <div class="process-circle" aria-label="お問合せ段階">
      <span class="process-text">お問合</span>
    </div>
    <div class="process-text-container">
      <div class="process-label">お問合せ</div>
      <div class="process-sublabel">{{ section.settings.estimate_period | default: '通常営業日' }}</div>
      {% if section.settings.quote_duration != blank %}
        <div class="process-duration">{{ section.settings.quote_duration }}</div>
      {% endif %}
    </div>
  </div>
  
  <!-- ステップ2: お見積 -->
  <div class="process-step" data-step="2" role="listitem">
    <div class="process-circle" aria-label="お見積もり段階">
      <span class="process-text">お見積</span>
    </div>
    <div class="process-text-container">
      <div class="process-label">お見積もり</div>
      <div class="process-sublabel">金額確認</div>
    </div>
  </div>
  
  <!-- ステップ3: お振込（アクティブ） -->
  <div class="process-step active" data-step="3" role="listitem" aria-current="step">
    <div class="process-circle" aria-label="お振込み段階（現在）">
      <span class="process-text">お振込</span>
    </div>
    <div class="process-text-container">
      <div class="process-label">お振込み</div>
      <div class="process-sublabel">お客様の工程</div>
      {% if section.settings.payment_note != blank %}
        <div class="process-note">{{ section.settings.payment_note }}</div>
      {% endif %}
    </div>
  </div>
  
  <!-- ステップ4: 発送 -->
  <div class="process-step" data-step="4" role="listitem">
    <div class="process-circle" aria-label="商品発送段階">
      <span class="process-text">発送</span>
    </div>
    <div class="process-text-container">
      <div class="process-label">商品発送</div>
      <div class="process-sublabel">{{ section.settings.shipping_period | default: '営業日以内' }}</div>
      {% if section.settings.shipping_schedule != blank %}
        <div class="process-schedule">{{ section.settings.shipping_schedule }}</div>
      {% endif %}
    </div>
  </div>
</div>

<!-- プロセス説明（モバイル用補助情報） -->
<div class="process-explanation" role="region" aria-labelledby="process-explanation-title">
  <h4 id="process-explanation-title" class="process-explanation-title">ご注文の流れ</h4>
  <div class="process-explanation-content">
    <ol class="process-explanation-list">
      <li><strong>お問合せ</strong>: フォームからご連絡いただきます</li>
      <li><strong>お見積もり</strong>: {{ section.settings.quote_duration | default: '3日程度' }}でお見積もりをお送りします</li>
      <li><strong>お振込み</strong>: {{ section.settings.payment_note | default: '発送の2日前まで' }}にお振込みをお願いします</li>
      <li><strong>発送</strong>: {{ section.settings.shipping_schedule | default: '毎週木曜日' }}に発送いたします</li>
    </ol>
  </div>
</div>

<style>
/* プロセス説明セクション（モバイルで補助表示） */
.process-explanation {
  display: none;
  margin-top: 2rem;
  padding: 1.5rem;
  background: rgba(248, 250, 252, 0.8);
  border-radius: 12px;
  border: 1px solid rgba(220, 200, 180, 0.3);
}

.process-explanation-title {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--bulk-order-text, #5D4037);
  margin: 0 0 1rem 0;
  text-align: center;
}

.process-explanation-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.process-explanation-list li {
  padding: 0.5rem 0;
  font-size: 0.875rem;
  line-height: 1.5;
  color: var(--bulk-order-text, #6D4C41);
  border-bottom: 1px solid rgba(220, 200, 180, 0.2);
}

.process-explanation-list li:last-child {
  border-bottom: none;
}

.process-explanation-list strong {
  color: var(--bulk-order-primary, #8B4513);
  font-weight: 600;
}

/* モバイルでプロセス説明を表示 */
@media (max-width: 767px) {
  .process-explanation {
    display: block;
  }
}

/* 極小スマホでは非表示（スペース節約） */
@media (max-width: 480px) {
  .process-explanation {
    display: none;
  }
}
</style>
      
      <!-- 追加情報 -->
      <div class="bulk-order-note">
        {{ section.settings.additional_note }}
      </div>
    </div>

    <!-- 注文フォーム -->
    <form class="bulk-order-form" action="{{ routes.root_url }}contact" method="post" accept-charset="UTF-8" novalidate>
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="bulk-order">

      <!-- お客様情報セクション -->
      <fieldset class="form-section customer-info">
        <legend class="form-section-title">お客様情報</legend>
        
        <div class="form-row">
          <div class="form-group required">
            <label for="customer-name-{{ section.id }}" class="form-label">
              お名前 <span class="required-mark">※必須</span>
            </label>
            <input 
              type="text" 
              id="customer-name-{{ section.id }}" 
              name="contact[name]" 
              class="form-input"
              required
              aria-describedby="name-error-{{ section.id }}"
              autocomplete="name"
            >
            <div class="form-error" id="name-error-{{ section.id }}" role="alert" aria-live="polite"></div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="company-name-{{ section.id }}" class="form-label">会社名</label>
            <input 
              type="text" 
              id="company-name-{{ section.id }}" 
              name="contact[company]" 
              class="form-input"
              autocomplete="organization"
            >
          </div>
        </div>

        <div class="form-row">
          <div class="form-group required">
            <label for="customer-email-{{ section.id }}" class="form-label">
              メールアドレス <span class="required-mark">※必須</span>
            </label>
            <input 
              type="email" 
              id="customer-email-{{ section.id }}" 
              name="contact[email]" 
              class="form-input"
              required
              aria-describedby="email-error-{{ section.id }}"
              autocomplete="email"
            >
            <div class="form-error" id="email-error-{{ section.id }}" role="alert" aria-live="polite"></div>
          </div>
        </div>
          
        <div class="form-row">
          <div class="form-group required">
            <label for="customer-phone-{{ section.id }}" class="form-label">
              電話番号 <span class="required-mark">※必須</span>
            </label>
            <input 
              type="tel" 
              id="customer-phone-{{ section.id }}" 
              name="contact[phone]" 
              class="form-input"
              required
              aria-describedby="phone-error-{{ section.id }}"
              autocomplete="tel"
            >
            <div class="form-error" id="phone-error-{{ section.id }}" role="alert" aria-live="polite"></div>
          </div>
        </div>
      </fieldset>

      <!-- 配送・請求情報セクション -->
