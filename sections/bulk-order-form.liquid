<fieldset class="form-section product-selection">
  <legend class="form-section-title">ご希望の商品</legend>
  
  {% for i in (1..3) %}
    <div class="product-row" data-product-index="{{ i }}">
      <h4 class="product-row-title">ご希望の商品{{ i }}</h4>
      
      <div class="product-row-content">
        <!-- 商品選択フィールド -->
        <div class="form-group">
          <label for="product-{{ i }}-{{ section.id }}" class="form-label">
            商品名
            {% if i == 1 %}<span class="required-mark">※必須</span>{% endif %}
          </label>
          <select 
            id="product-{{ i }}-{{ section.id }}" 
            name="contact[product_{{ i }}]" 
            class="form-select product-select"
            data-product-index="{{ i }}"
            {% if i == 1 %}required{% endif %}
            aria-describedby="product-{{ i }}-description-{{ section.id }}"
          >
            <option value="">商品を選択してください</option>
            
            {% comment %} 商品コレクションから動的に取得 {% endcomment %}
            {% if section.settings.product_collection != blank %}
              {% assign collection = collections[section.settings.product_collection] %}
              {% for product in collection.products limit: 50 %}
                <option 
                  value="{{ product.title | escape }}" 
                  data-product-id="{{ product.id }}" 
                  data-price="{{ product.price | divided_by: 100.0 }}"
                >
                  {{ product.title }}{% if product.price > 0 %} (¥{{ product.price | money_without_currency }}){% endif %}
                </option>
              {% endfor %}
            {% else %}
              {% comment %} フォールバック: 手動設定商品 {% endcomment %}
              {% assign fallback_products = section.settings.fallback_products | newline_to_br | split: '<br />' %}
              {% for product in fallback_products %}
                {% unless product == blank %}
                  <option value="{{ product | strip | escape }}" data-price="0">{{ product | strip }}</option>
                {% endunless %}
              {% endfor %}
            {% endif %}
          </select>
          <div id="product-{{ i }}-description-{{ section.id }}" class="form-description">
            上記リストから商品をお選びください
          </div>
        </div>
        
        <!-- 数量入力フィールド -->
        <div class="form-group">
          <label for="quantity-{{ i }}-{{ section.id }}" class="form-label">個数</label>
          <input 
            type="number" 
            id="quantity-{{ i }}-{{ section.id }}" 
            name="contact[quantity_{{ i }}]" 
            class="form-input quantity-input"
            data-product-index="{{ i }}"
            min="1"
            max="999"
            step="1"
            placeholder="数量を入力"
            disabled
            aria-describedby="quantity-{{ i }}-description-{{ section.id }}"
          >
          <div id="quantity-{{ i }}-description-{{ section.id }}" class="form-description">
            商品を選択後に入力できます
          </div>
        </div>
        
        <!-- 熨斗選択フィールド -->
        <div class="form-group">
          <label for="noshi-{{ i }}-{{ section.id }}" class="form-label">熨斗</label>
          <select 
            id="noshi-{{ i }}-{{ section.id }}" 
            name="contact[noshi_{{ i }}]" 
            class="form-select noshi-select"
            data-product-index="{{ i }}"
            disabled
            aria-describedby="noshi-{{ i }}-description-{{ section.id }}"
          >
            <option value="">選択してください</option>
            <option value="なし">なし</option>
            <option value="あり">あり（+50円）</option>
          </select>
          <div id="noshi-{{ i }}-description-{{ section.id }}" class="form-description">
            商品を選択後に選択できます
          </div>
        </div>
        
        <!-- 熨斗イメージ表示エリア -->
        <div class="noshi-image-display" id="noshi-image-{{ i }}-{{ section.id }}" style="display: none;" role="img" aria-labelledby="noshi-caption-{{ i }}-{{ section.id }}">
          <div class="noshi-image-container">
            {% if section.settings.noshi_sample_image != blank %}
              <img class="noshi-preview-image" src="{{ section.settings.noshi_sample_image | image_url }}" alt="熨斗サンプル" loading="lazy" />
            {% else %}
              <div class="noshi-placeholder">熨斗サンプル画像</div>
            {% endif %}
            <div class="noshi-image-caption" id="noshi-caption-{{ i }}-{{ section.id }}">熨斗のサンプル</div>
          </div>
        </div>
      </div>
    </div>
  {% endfor %}
  
  <!-- 見積もり表示セクション -->
  <div class="estimate-summary" id="estimate-summary-{{ section.id }}" role="region" aria-labelledby="estimate-title-{{ section.id }}">
    <div class="estimate-header">
      <h3 class="estimate-title" id="estimate-title-{{ section.id }}">概算お見積もり金額</h3>
      <p class="estimate-note">※送料別・税込価格</p>
    </div>
    
    <div class="estimate-content">
      <div class="estimate-items" id="estimate-items-{{ section.id }}" role="list" aria-label="選択された商品一覧">
        <div class="estimate-placeholder">
          商品を選択すると、こちらに概算金額が表示されます
        </div>
      </div>
      
      <div class="estimate-total">
        <div class="total-row">
          <span class="total-label">小計（税込）</span>
          <span class="total-amount" id="total-amount-{{ section.id }}" aria-live="polite">¥0</span>
        </div>
        <div class="shipping-note">
          ※送料は配送先により異なります。お見積もり時にご案内いたします。
        </div>
      </div>
    </div>
  </div>
</fieldset>

<!-- 領収書情報セクション（修正版） -->
<fieldset class="form-section receipt-info">
  <legend class="form-section-title">領収書について</legend>
  
  <div class="form-row">
    <div class="form-group">
      <label for="receipt-required-{{ section.id }}" class="form-label">領収書の発行</label>
      <select 
        id="receipt-required-{{ section.id }}" 
        name="contact[receipt_required]" 
        class="form-select receipt-select"
        aria-describedby="receipt-description-{{ section.id }}"
        aria-controls="receipt-details-{{ section.id }}"
      >
        <option value="">選択してください</option>
        <option value="必要">必要</option>
        <option value="不要">不要</option>
      </select>
      <div id="receipt-description-{{ section.id }}" class="form-description">
        領収書が必要な場合は「必要」を選択してください
      </div>
    </div>
  </div>
  
  <!-- 領収書詳細（初期状態で非表示） -->
  <div class="form-row receipt-details" id="receipt-details-{{ section.id }}" style="display: none;" aria-expanded="false">
    <div class="form-group">
      <label for="receipt-name-{{ section.id }}" class="form-label">
        領収書の宛名
      </label>
      <input 
        type="text" 
        id="receipt-name-{{ section.id }}" 
        name="contact[receipt_name]" 
        class="form-input"
        placeholder="例：株式会社○○ 又は ○○様"
        aria-describedby="receipt-name-description-{{ section.id }}"
      >
      <div id="receipt-name-description-{{ section.id }}" class="form-description">
        領収書に記載する宛名をご入力ください。空欄の場合はお名前が使用されます。
      </div>
    </div>
  </div>
</fieldset>

      <!-- 追加オプション -->
      <fieldset class="form-section additional-options">
        <legend class="form-section-title">追加オプション</legend>
        
        <div class="form-row">
          <div class="form-group">
            <label for="bag-option-{{ section.id }}" class="form-label">手提げの有無</label>
            <select 
              id="bag-option-{{ section.id }}" 
              name="contact[bag_option]" 
              class="form-select"
            >
              <option value="">選択してください</option>
              <option value="あり">あり</option>
              <option value="なし">なし</option>
            </select>
          </div>
        </div>
      </fieldset>

      <!-- その他のご要望 -->
      <fieldset class="form-section">
        <legend class="form-section-title">その他のご要望</legend>
        
        <div class="form-row">
          <div class="form-group">
            <label for="additional-requests-{{ section.id }}" class="form-label">
              その他のご要望
            </label>
            <textarea 
              id="additional-requests-{{ section.id }}" 
              name="contact[body]" 
              class="form-textarea"
              rows="6"
              placeholder="ご要望やご質問がございましたら、こちらにご記入ください。"
              aria-describedby="textarea-description-{{ section.id }}"
            ></textarea>
            <div id="textarea-description-{{ section.id }}" class="form-description">
              {{ section.settings.form_note | default: '領収書は入金確認後にメールにてお送りいたします。発送日や但し書きはお気軽にご相談ください。' }}
            </div>
          </div>
        </div>
      </fieldset>

      <!-- 送信ボタン -->
      <div class="form-submit">
        <button type="submit" class="submit-button" aria-describedby="submit-description-{{ section.id }}">
          <span class="submit-text">{{ section.settings.submit_button_text | default: 'お問い合わせを送信' }}</span>
          <span class="submit-spinner" aria-hidden="true"></span>
        </button>
        <div id="submit-description-{{ section.id }}" class="form-description">
          送信後、3営業日以内にお見積もりをお送りいたします。
        </div>
      </div>

      <!-- フォーム送信結果表示エリア -->
      <div class="form-message" role="alert" aria-live="polite"></div>
    </form>
  </div>
</section>

<script src="{{ 'bulk-order-form.js' | asset_url }}" defer></script>
{% schema %}
{
