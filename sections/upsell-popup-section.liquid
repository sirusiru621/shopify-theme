<!-- ファイル名: upsell-popup-section.liquid -->
<!-- アップセル対応カスタムセクション - カラム表示と画像上テキスト配置機能付き -->

{{ 'upsell-popup-section.css' | asset_url | stylesheet_tag }}

<div class="upsell-section" id="upsell-section-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="upsell-section__header">
      <h2 class="upsell-section__title">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="upsell-section__content">
    <div class="upsell-columns">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'column' -%}
            <div class="upsell-column" {{ block.shopify_attributes }}>
              <div class="upsell-column__image-wrapper">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    srcset="{{ block.settings.image | image_url: width: 300 }} 300w,
                            {{ block.settings.image | image_url: width: 600 }} 600w,
                            {{ block.settings.image | image_url: width: 900 }} 900w"
                    sizes="(max-width: 767px) 100vw, (max-width: 1199px) 50vw, 33vw"
                    alt="{{ block.settings.image.alt | escape }}"
                    class="upsell-column__image"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'upsell-column__image placeholder-svg' }}
                {%- endif -%}
                
                {%- if block.settings.show_text_overlay and block.settings.overlay_text != blank -%}
                  <div class="upsell-column__overlay upsell-column__overlay--{{ block.settings.text_position }}">
                    <div class="upsell-column__overlay-content">
                      <h3 
                        class="upsell-column__overlay-title"
                        style="font-size: {{ block.settings.overlay_font_size }}px;"
                      >
                        {{ block.settings.overlay_text }}
                      </h3>
                      {%- if block.settings.overlay_description != blank -%}
                        <p 
                          class="upsell-column__overlay-description"
                          style="font-size: {{ block.settings.overlay_description_size }}px;"
                        >
                          {{ block.settings.overlay_description }}
                        </p>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank or block.settings.text != blank -%}
                <div class="upsell-column__content">
                  {%- if block.settings.title != blank -%}
                    <h3 class="upsell-column__title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div class="upsell-column__text">{{ block.settings.text }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- アップセルポップアップ -->
<div class="upsell-popup" id="upsell-popup-{{ section.id }}" style="display: none;">
  <div class="upsell-popup__overlay"></div>
  <div class="upsell-popup__content">
    <button class="upsell-popup__close" aria-label="閉じる">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    
    <div class="upsell-popup__header">
      <h3 class="upsell-popup__title" style="font-size: {{ section.settings.popup_title_size }}px;">
        {{ section.settings.popup_title }}
      </h3>
      {%- if section.settings.popup_description != blank -%}
        <p class="upsell-popup__description" style="font-size: {{ section.settings.popup_description_size }}px;">
          {{ section.settings.popup_description }}
        </p>
      {%- endif -%}
    </div>

    <div class="upsell-popup__products" id="upsell-products-container">
      <!-- JavaScript で動的に商品を挿入 -->
    </div>
  </div>
</div>

<script src="{{ 'upsell-popup-section.js' | asset_url }}" defer></script>

{%- liquid
  assign upsell_collection = collections[section.settings.upsell_collection]
  if upsell_collection != blank
    echo '<script type="application/json" id="upsell-collection-data-' | append: section.id | append: '">'
    echo '{'
    echo '"products": ['
    for product in upsell_collection.products limit: 6
      echo '{'
      echo '"id": ' | append: product.id | append: ','
      echo '"title": "' | append: product.title | json | append: '",'
      echo '"handle": "' | append: product.handle | append: '",'
      echo '"price": ' | append: product.price | append: ','
      echo '"featured_image": "' | append: product.featured_image | image_url: width: 300 | append: '",'
      echo '"variants": ['
      for variant in product.variants limit: 1
        echo '{'
        echo '"id": ' | append: variant.id | append: ','
        echo '"available": ' | append: variant.available | append: ','
        echo '"price": ' | append: variant.price
        echo '}'
      endfor
      echo ']'
      echo '}'
      unless forloop.last
        echo ','
      endunless
    endfor
    echo ']'
    echo '}'
    echo '</script>'
  endif
-%}
          
{% schema %}
{
  "name": "アップセル対応カスタムセクション",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "セクション見出し",
      "default": "特集商品"
    },
    {
      "type": "collection",
      "id": "upsell_collection",
      "label": "アップセル商品コレクション",
      "info": "カート追加後に表示するアップセル商品のコレクションを選択してください"
    },
    {
      "type": "header",
      "content": "ポップアップ設定"
    },
    {
      "type": "text",
      "id": "popup_title",
      "label": "ポップアップタイトル",
      "default": "おすすめ商品を追加しませんか？"
    },
    {
      "type": "range",
      "id": "popup_title_size",
      "label": "ポップアップタイトル文字サイズ",
      "min": 16,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "textarea",
      "id": "popup_description",
      "label": "ポップアップ説明文",
      "default": "以下の商品もいかがですか？"
    },
    {
      "type": "range",
      "id": "popup_description_size",
      "label": "ポップアップ説明文字サイズ",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "カラム",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "カラムタイトル"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "テキスト",
          "default": "<p>カラムの説明テキストをここに入力してください。</p>"
        },
        {
          "type": "header",
          "content": "画像オーバーレイ設定"
        },
        {
          "type": "checkbox",
          "id": "show_text_overlay",
          "label": "画像上にテキストを表示",
          "default": false
        },
        {
          "type": "text",
          "id": "overlay_text",
          "label": "オーバーレイタイトル",
          "default": "オーバーレイテキスト"
        },
        {
          "type": "range",
          "id": "overlay_font_size",
          "label": "オーバーレイタイトル文字サイズ",
          "min": 16,
          "max": 48,
          "step": 1,
          "unit": "px",
          "default": 24
        },
        {
          "type": "textarea",
          "id": "overlay_description",
          "label": "オーバーレイ説明文"
        },
        {
          "type": "range",
          "id": "overlay_description_size",
          "label": "オーバーレイ説明文字サイズ",
          "min": 12,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "テキスト配置位置",
          "options": [
            {
              "value": "top-left",
              "label": "左上"
            },
            {
              "value": "top-center",
              "label": "中央上"
            },
            {
              "value": "top-right",
              "label": "右上"
            },
            {
              "value": "center-left",
              "label": "左中央"
            },
            {
              "value": "center",
              "label": "中央"
            },
            {
              "value": "center-right",
              "label": "右中央"
            },
            {
              "value": "bottom-left",
              "label": "左下"
            },
            {
              "value": "bottom-center",
              "label": "中央下"
            },
            {
              "value": "bottom-right",
              "label": "右下"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "アップセル対応カスタムセクション",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}