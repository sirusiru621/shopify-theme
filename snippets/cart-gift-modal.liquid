<!-- ファイル名: snippets/cart-gift-modal.liquid -->
<!-- 機能説明: 調整版ギフト設定モーダルUI -->
<!-- 熨斗・表書き削除、数量連動・熨斗サンプル・宛名入力追加 -->

<div id="gift-modal" class="gift-modal hidden" aria-hidden="true" role="dialog" aria-labelledby="gift-modal-title" aria-describedby="gift-modal-description">
  <div class="gift-modal__backdrop" aria-hidden="true"></div>
  
  <div class="gift-modal__container">
    <div class="gift-modal__content">
      <header class="gift-modal__header">
        <h2 id="gift-modal-title" class="gift-modal__title">
          ギフト設定
        </h2>
        <p id="gift-modal-description" class="gift-modal__description">
          贈り物としての包装設定を行えます
        </p>
        <button 
          type="button" 
          class="gift-modal__close" 
          data-gift-modal-close
          aria-label="ギフト設定を閉じる"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </header>

      <form id="gift-settings-form" class="gift-modal__form" novalidate>
        <div class="gift-modal__body">
          {%- comment -%} ギフト数量設定（商品個数連動） {%- endcomment -%}
          <div class="gift-form-group">
            <label for="gift-quantity" class="gift-form-label">
              ギフト数量
              <span class="gift-form-required" aria-label="必須項目">*</span>
            </label>
            <select id="gift-quantity" name="gift-quantity" class="gift-form-select" required aria-describedby="gift-quantity-help">
              <!-- 動的に生成される -->
            </select>
            <div id="gift-quantity-help" class="gift-form-help">
              ギフトとして包装する商品の数量を選択してください（カート内数量に応じて表示）
            </div>
          </div>

          {%- comment -%} 用途設定とのしサンプル表示 {%- endcomment -%}
          <div class="gift-form-group">
            <label for="gift-purpose" class="gift-form-label">
              用途
              <span class="gift-form-required" aria-label="必須項目">*</span>
            </label>
            <select id="gift-purpose" name="gift-purpose" class="gift-form-select" required aria-describedby="gift-purpose-help">
              <option value="その他">その他</option>
              <option value="お中元">お中元</option>
              <option value="お歳暮">お歳暮</option>
              <option value="お祝い">お祝い</option>
              <option value="お返し">お返し</option>
              <option value="お礼">お礼</option>
              <option value="ご挨拶">ご挨拶</option>
              <option value="結婚祝い">結婚祝い</option>
              <option value="出産祝い">出産祝い</option>
              <option value="新築祝い">新築祝い</option>
              <option value="開店祝い">開店祝い</option>
            </select>
            <div id="gift-purpose-help" class="gift-form-help">
              贈り物の用途を選択してください
            </div>
            
            {%- comment -%} のしサンプル画像表示エリア {%- endcomment -%}
            <div class="gift-noshi-samples" id="gift-noshi-samples">
              <div class="gift-noshi-sample" data-purpose="その他">
                <img src="{{ 'noshi-sonota.png' | asset_url }}" alt="その他用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">汎用のし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="お中元">
                <img src="{{ 'noshi-ochugen.png' | asset_url }}" alt="お中元用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">お中元のし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="お歳暮">
                <img src="{{ 'noshi-oseibo.png' | asset_url }}" alt="お歳暮用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">お歳暮のし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="お祝い">
                <img src="{{ 'noshi-oiwai.png' | asset_url }}" alt="お祝い用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">お祝いのし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="お返し">
                <img src="{{ 'noshi-ogaeshi.png' | asset_url }}" alt="お返し用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">お返しのし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="お礼">
                <img src="{{ 'noshi-orei.png' | asset_url }}" alt="お礼用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">お礼のし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="ご挨拶">
                <img src="{{ 'noshi-goaisatsu.png' | asset_url }}" alt="ご挨拶用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">ご挨拶のし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="結婚祝い">
                <img src="{{ 'noshi-kekkon.png' | asset_url }}" alt="結婚祝い用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">結婚祝いのし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="出産祝い">
                <img src="{{ 'noshi-shussan.png' | asset_url }}" alt="出産祝い用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">出産祝いのし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="新築祝い">
                <img src="{{ 'noshi-shinchiku.png' | asset_url }}" alt="新築祝い用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">新築祝いのし紙</span>
              </div>
              <div class="gift-noshi-sample hidden" data-purpose="開店祝い">
                <img src="{{ 'noshi-kaiten.png' | asset_url }}" alt="開店祝い用のし" class="gift-noshi-image" loading="lazy">
                <span class="gift-noshi-caption">開店祝いのし紙</span>
              </div>
            </div>
          </div>

          {%- comment -%} 宛名書き設定 {%- endcomment -%}
          <div class="gift-form-group">
            <label for="gift-addressee" class="gift-form-label">
              宛名書き
              <span class="gift-form-optional">（任意）</span>
            </label>
            <input 
              type="text" 
              id="gift-addressee" 
              name="gift-addressee" 
              class="gift-form-input"
              placeholder="例：田中様、山田太郎様"
              maxlength="20"
              aria-describedby="gift-addressee-help"
            >
            <div id="gift-addressee-help" class="gift-form-help">
              のし紙に記載する宛名を入力してください（20文字以内）
              <br>
              <small class="gift-form-help-detail">
                空欄の場合は宛名なしでお届けします
              </small>
            </div>
          </div>
        </div>

        <footer class="gift-modal__footer">
          <button 
            type="button" 
            class="gift-modal__button gift-modal__button--secondary" 
            data-gift-modal-cancel
          >
            キャンセル
          </button>
          <button 
            type="button" 
            class="gift-modal__button gift-modal__button--primary" 
            data-gift-modal-save
          >
            設定を保存
          </button>
        </footer>
      </form>
    </div>
  </div>
</div>

{%- comment -%} ローディング用のオーバーレイ {%- endcomment -%}
<div id="gift-modal-loading" class="gift-modal-loading hidden" aria-hidden="true">
  <div class="gift-modal-loading__backdrop"></div>
  <div class="gift-modal-loading__content">
    <div class="gift-modal-loading__spinner">
      <svg
        aria-hidden="true"
        focusable="false"
        class="spinner"
        viewBox="0 0 66 66"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
      </svg>
    </div>
    <p class="gift-modal-loading__text">
      ギフト設定を保存中...
    </p>
  </div>
</div>

{%- comment -%} 成功・エラー通知用のトースト {%- endcomment -%}
<div id="gift-toast-container" class="gift-toast-container" aria-live="polite" aria-atomic="true">
  <!-- 動的に通知が挿入されます -->
</div>