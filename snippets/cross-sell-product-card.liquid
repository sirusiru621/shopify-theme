<!-- ファイル名: snippets/cross-sell-product-card.liquid -->
<!-- 機能説明: クロスセル商品カードの再利用可能コンポーネント -->
<!-- 使用方法: {% render 'cross-sell-product-card', product: product, show_variants: true %} -->

{%- liquid
  assign card_product = product
  assign product_variant = card_product.selected_or_first_available_variant
  assign product_price = product_variant.price
  assign compare_price = product_variant.compare_at_price
  assign product_available = product_variant.available
  assign show_variants = show_variants | default: false
  assign button_text = button_text | default: 'Add to cart'
  assign sold_out_text = sold_out_text | default: 'Sold out'
-%}

<div class="cross-sell-product-card" data-product-id="{{ card_product.id }}">
  
  <!-- 商品画像 -->
  <div class="product-card-image">
    {%- if card_product.featured_image -%}
      <img 
        src="{{ card_product.featured_image | image_url: width: 300 }}"
        srcset="
          {{ card_product.featured_image | image_url: width: 150 }} 150w,
          {{ card_product.featured_image | image_url: width: 300 }} 300w,
          {{ card_product.featured_image | image_url: width: 450 }} 450w
        "
        sizes="(max-width: 767px) 150px, 200px"
        alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
        class="product-image"
        loading="lazy"
        width="300"
        height="300"
      >
    {%- else -%}
      <div class="product-image-placeholder">
        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21,15 16,10 5,21"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  <!-- 商品情報 -->
  <div class="product-card-info">
    <!-- 商品タイトル -->
    <h5 class="product-card-title">{{ card_product.title | escape }}</h5>
    
    <!-- 価格表示 -->
    <div class="product-card-price">
      {%- if compare_price > product_price -%}
        <span class="price-compare">{{ compare_price | money }}</span>
      {%- endif -%}
      <span class="price-current">
        {%- if card_product.price_varies -%}
          {{ card_product.price_min | money }}+
        {%- else -%}
          {{ product_price | money }}
        {%- endif -%}
      </span>
    </div>

    <!-- バリエーション選択 -->
    {%- if card_product.variants.size > 1 and show_variants -%}
      <div class="product-variants">
        <select class="variant-selector" data-product-id="{{ card_product.id }}" aria-label="バリエーションを選択">
          {%- for variant in card_product.variants -%}
            {%- if variant.available -%}
              <option 
                value="{{ variant.id }}" 
                data-price="{{ variant.price | money }}"
                {%- if variant == product_variant -%} selected{%- endif -%}
              >
                {{ variant.title }} - {{ variant.price | money }}
              </option>
            {%- endif -%}
          {%- endfor -%}
        </select>
      </div>
    {%- endif -%}

    <!-- カート追加ボタン -->
    {%- if product_available -%}
      <button 
        type="button" 
        class="add-to-cart-btn" 
        data-variant-id="{{ product_variant.id }}"
        data-product-title="{{ card_product.title | escape }}"
        data-product-price="{{ product_price | money }}"
        data-product-image="{{ card_product.featured_image | image_url: width: 150 }}"
        aria-label="{{ card_product.title | escape }}をカートに追加"
      >
        <span class="btn-text">{{ button_text }}</span>
        <span class="btn-loading" style="display: none;" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12a9 9 0 11-6.219-8.56"/>
          </svg>
        </span>
        <span class="btn-success" style="display: none;" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20,6 9,17 4,12"/>
          </svg>
        </span>
      </button>
    {%- else -%}
      <button type="button" class="add-to-cart-btn sold-out" disabled aria-label="{{ card_product.title | escape }}は売り切れです">
        {{ sold_out_text }}
      </button>
    {%- endif -%}
  </div>
</div>