{% doc %}
Validates grain inventory for cart line items.
@example
{% render 'grain-inventory-cart' %}
{% enddoc %}

{%- assign has_grain_items = false -%}
{%- for item in cart.items -%}
  {%- assign grain_prop = item.properties._grain_inventory_enabled -%}
  {%- if grain_prop == 'true' -%}
    {%- assign has_grain_items = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_grain_items -%}
  <div class="grain-inventory-cart-notice" id="grainInventoryCartNotice" hidden></div>

  <script type="application/json" id="grain-inventory-cart-data">
    [
      {%- assign first_grain_item = true -%}
      {%- for item in cart.items -%}
        {%- if item.properties._grain_inventory_enabled == 'true' -%}
          {%- unless first_grain_item -%},{%- endunless -%}
          {
            "key": {{ item.key | json }},
            "group": {{ item.properties._grain_inventory_group | json }},
            "method": {{ item.properties._grain_stock_method | default: 'delivery' | json }},
            "unitsPerItem": {{ item.properties._grain_units_per_item | default: 0 }},
            "quantity": {{ item.quantity }}
          }
          {%- assign first_grain_item = false -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  </script>

  <script>
    (function() {
      var dataEl = document.getElementById('grain-inventory-cart-data');
      var noticeEl = document.getElementById('grainInventoryCartNotice');
      if (!dataEl || !noticeEl) return;

      var items = JSON.parse(dataEl.textContent || '[]').filter(function(item) {
        return item.group && item.method && parseInt(item.unitsPerItem, 10) > 0 && item.quantity > 0;
      });
      var groupTotals = {};
      if (!items.length) return;

      items.forEach(function(item) {
        var key = item.group + ':' + item.method;
        if (!groupTotals[key]) {
          groupTotals[key] = { group: item.group, method: item.method, required: 0 };
        }
        groupTotals[key].required += (parseInt(item.unitsPerItem, 10) || 0) * item.quantity;
      });

      fetch('/apps/mochi/grain-stock/check', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({
          items: Object.values(groupTotals).map(function(g) {
            return { groupName: g.group, method: g.method, unitsPerItem: 1, quantity: g.required };
          })
        })
      }).then(function(res) {
        if (!res.ok) throw new Error('grain stock check failed');
        return res.json();
      }).then(function(result) {
        if (result.allAvailable === false) {
          noticeEl.hidden = false;
          noticeEl.className = 'grain-inventory-cart-notice grain-inventory-cart-notice--error';
          noticeEl.textContent = '粒単位の在庫が不足している商品があります。数量を調整してください。';
          var checkoutBtn = document.getElementById('checkout') || document.querySelector('.cart__checkout-button');
          if (checkoutBtn) checkoutBtn.setAttribute('disabled', 'disabled');
        }
      }).catch(function() {
        // Development previews may not be able to reach the app proxy. Do not block checkout on transport errors.
      });
    })();
  </script>

  <style>
    .grain-inventory-cart-notice {
      margin: 16px 0;
      padding: 12px 16px;
      border-radius: 4px;
      font-size: 14px;
    }
    .grain-inventory-cart-notice--error {
      background: #ffebee;
      color: #c62828;
      border-left: 4px solid #f44336;
    }
  </style>
{%- endif -%}
